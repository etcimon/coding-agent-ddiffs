# =============================================================================
# 17. STYLES  --  app/globals.css keyframes (COPY VERBATIM)
# =============================================================================
# intent: the widget is styled entirely with inline Tailwind classes (reproduced
# in section 1's JSX). The only global CSS it needs is these two keyframes.
# `animate-fade-in-up` is applied to each message wrapper with an inline
# style={{animationDelay:`${idx*40}ms`}} so a burst of history cascades in.

@keyframes fade-in-up {
  0%   { opacity: 0; transform: translateY(8px); }
  100% { opacity: 1; transform: translateY(0); }
}
.animate-fade-in-up { animation: fade-in-up 0.3s ease-out both; }

@keyframes chat-pulse {
  0%, 100% { transform: scale(1); }
  50%      { transform: scale(1.15); }
}
.animate-chat-pulse { animation: chat-pulse 1.5s ease-in-out infinite; }

# =============================================================================
# 18. TESTS  --  tests/chat.test.ts + tests/chat-attachments.test.ts (bun:test)
# =============================================================================
# intent: two suites, run SEPARATELY (bun's mock.module is process-global; the
# two files register different "@/lib/chat/db" + "@/lib/chat/storage" mocks that
# would collide in one invocation). package.json scripts: "test:chat" and
# "test:chat-attachments". Route handlers are imported and called directly with a
# hand-built NextRequest; globalThis.fetch is mocked and branched on URL; Redis is
# forced off so the in-memory bus + local rate-limit buckets are used.
#
# --- tests/chat.test.ts (inbound webhook direction) --------------------------
# MOCKS (mock.module):
#   "@/lib/redis"        -> ensureRedis: async () => null
#   "@/lib/chat/db"      -> in-memory: Maps for sessions/messages; toMessageDto
#                           maps attachment* -> attachment DTO
#   "@/lib/chat/storage" -> STUB recording calls (no disk):
#       const savedFiles: { sessionId: string; name: string; bytes: number }[] = [];
#       const deletedSessions: string[] = [];
#       saveChatFile: async (sessionId, name, data) => {
#         savedFiles.push({ sessionId, name, bytes: data.byteLength });
#         return `${sessionId}/${name}`;
#       },
#       deleteSessionFiles: async (sessionId) => { deletedSessions.push(sessionId); },
# HELPERS: build a Telegram webhook POST with the secret header + a JSON body,
#   call POST(req), then assert on published events (captured via the pubsub
#   in-memory bus) and on savedFiles/deletedSessions.
# CASES (attachment-related, alongside the pre-existing text/close cases):
#   test("ignores messages with neither text nor media"):
#     POST an update whose message has no text and no photo/doc/etc -> { ok: true }
#     and NO createChatMessage call.
#   test("deletes stored attachments when the topic is closed"):
#     POST a message with forum_topic_closed (or text "/close") for a known
#     session -> expect deletedSessions to contain session.id AND a status:closed
#     event to be published.
#   test("downloads and relays an inbound photo, choosing the largest size"):
#     fetchMock branches: /getFile -> { ok:true, result:{ file_path:"photos/f.jpg" } };
#     the file host URL -> a Response with an ArrayBuffer body.
#     POST an update with message.photo = [smallSize, largeSize].
#     expect: one published "message" event with attachment.type==="image",
#     text === caption, savedFiles.length === 1, and the getFile call used the
#     LARGEST photo's file_id.
#     (fetch mock signature: (url: string, _init?: RequestInit) so the second arg
#      is accepted when reading fetchMock.mock.calls.)
#   test("relays an inbound document with its file name and mime"):
#     expect attachment.type==="document" and name/mime preserved from the doc.
#
# --- tests/chat-attachments.test.ts (storage + helpers + upload + serving) ---
# SETUP:
#   process.env.CHAT_UPLOAD_DIR = a fresh os.tmpdir() folder; afterAll rm -rf.
#   mock.module("@/lib/redis", ensureRedis -> null).
#   mock.module("@/lib/chat/db", <in-memory>) — a COMPLETE superset of the module:
#     sessions/messages Maps + findChatSessionByVisitorId, findChatSessionById,
#     findChatSessionByThreadId, findChatSessionByTelegramMessageId,
#     createChatSession, updateChatSession, updateChatSessionThread,
#     createChatMessage, listChatMessages, getChatMessageWithSession,
#     closeChatSession, closeChatSessionByVisitorId, toMessageDto, toSessionDto.
#   (This superset is required so the OTHER suite's expectations still resolve if
#    both are ever loaded in one process.)
#
# describe("chat storage")  — REAL lib/chat/storage:
#   test("saves and reads a file under the session folder"):
#     const rel = await saveChatFile("sess_1", "hello.png", new Uint8Array([1,2,3]));
#     expect(rel.startsWith("sess_1/")).toBe(true);
#     expect([...(await readChatFile(rel))]).toEqual([1,2,3]);
#   test("deletes all files for a session"):
#     saveChatFile then deleteSessionFiles -> readChatFile rejects / dir gone.
#   test("guards against path traversal"):
#     expect(() => resolveStoredPath("../../etc/passwd")).toThrow();
#   test("maps MIME types to attachment kinds"):
#     attachmentTypeFromMime("image/png")==="image"; "video/mp4"==="video";
#     "audio/mpeg"==="audio"; "application/pdf"==="document".
#   test("reflects the attachments-enabled env flag"):
#     default true; set "false" -> clientAttachmentsEnabled() === false.
#
# describe("telegram media helpers")  — REAL lib/chat/telegram, fetch mocked:
#   test("extractMedia selects the largest photo size"):
#     photo:[{file_size:100,...},{file_size:900,...}] -> ref.fileId is the 900 one.
#   test("extractMedia handles documents and returns null for plain text"):
#     a document message -> type "document"; a text-only message -> null.
#   test("getTelegramFile resolves a file_path"):
#     fetch -> { ok:true, result:{ file_path } }; assert returned file_path.
#   test("downloadTelegramFile fetches from the file host"):
#     assert the request URL contains "/file/bot" + the path; returns a Buffer.
#   test("sendMediaToTopic posts multipart to the correct method"):
#     type "image" -> fetch URL ends with /sendPhoto and body is FormData.
#
# describe("chat send route: uploads")  — REAL send route + storage + telegram; db mock:
#   HELPER: build a multipart NextRequest with a Blob under "file".
#   test("rejects uploads with a 403 when attachments are disabled"):
#     set NEXT_PUBLIC_LIVE_CHAT_ATTACHMENTS_ENABLED="false" -> POST -> 403.
#   test("rejects a request with no file"):
#     multipart without "file" -> 400.
#   test("stores an uploaded image, relays it, returns the attachment DTO"):
#     fetch mock: /createForumTopic -> thread; /sendPhoto -> { ok:true, result:{ message_id } }.
#     POST image -> 200; data.messages[last].attachment.type==="image";
#     text === caption; errorText undefined; bytes readable from disk via the
#     persisted attachmentPath.
#   test("persists the attachment with an errorText when Telegram delivery fails"):
#     /sendDocument -> { ok:false, description:"Bad Request" } -> still 200; the
#     persisted message has errorText containing the Telegram description
#     (store-first contract) and the file still exists on disk.
#
# describe("chat attachment endpoint")  — REAL GET + storage; db mock:
#   SETUP: seed a session (visitorId "vis_ok") + a message whose attachmentPath
#     points at a real stored file.
#   test("serves bytes inline for the owning visitor"):
#     GET ?visitorId=vis_ok -> 200; Content-Type image/png;
#     Content-Disposition starts with "inline"; body bytes match.
#   test("forces download when ?download=1"):
#     Content-Disposition starts with "attachment".
#   test("denies access to a different visitor"):
#     GET ?visitorId=vis_other -> 403.
#   test("requires a visitorId"):
#     GET with no visitorId -> 400.
#
# VERIFY (copy-paste):
#   bun run test:chat
#   bun run test:chat-attachments
#   # or directly:
#   bun test tests/chat.test.ts
#   bun test tests/chat-attachments.test.ts

