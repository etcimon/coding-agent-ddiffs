# wysiwyg-richtext.full.ddiff  (narrowed)
#
# Full-code coding-agent diff of the ISOLATED rich authoring + display subsystem.
# Narrowed to the relevant parts: unrelated files (admin article-editor modal) and
# unrelated sections (share modal, feed loader, terminal caret, scrollbar CSS;
# SiteSettings/Tag/Comment models; feed-card pin/publish/comment chrome) are removed.
# Sliced files carry a NOTE + "omitted lines" markers; kept code is byte-exact.
# Companion: docs/port/wysiwyg-richtext.intent.diff (intent/contract/invariants).
#
# Apply order = dependency order (leaves first). Seams to rewire: (1) requireAdmin
# in src/app/api/upload/route.ts; (2) cache/DB (remember/invalidate + prisma) in
# src/lib/grok.ts. Deps: marked@^12 (pin), turndown@^7, highlight.js@^11,
# lucide-react, react, react-hook-form, zod.
# ============================================================================

diff --git a/src/lib/embeds.ts b/src/lib/embeds.ts
new file mode 100644
--- /dev/null
+++ b/src/lib/embeds.ts
@@ -0,0 +1,1165 @@
+/**
+ * Attachment embeds: inline file/video/audio blocks for the WYSIWYG editor and
+ * the rendered article body.
+ *
+ * Storage format is HTML (the article body is HTML). To survive the editor's
+ * HTML <-> Markdown round-trip (turndown / marked) and to work with remotely
+ * hosted files, every embed is also representable by a single custom Markdown
+ * tag:
+ *
+ *     @[filename.ext](https://host/path/file.ext)
+ *
+ * Size can be specified after the filename:
+ *
+ *     @[filename.ext 640x360](url)           // explicit width x height in pixels
+ *     @[filename.ext 50%](url)              // percentage width
+ *     @[filename.ext small](url)            // preset size (small/medium/large)
+ *     @[filename.ext width=640](url)       // named width parameter
+ *     @[filename.ext width=640 height=360](url)  // named width and height
+ *
+ * The rendered HTML carries `data-embed="1"`, `data-name`, `data-src`, and
+ * `data-size` so the turndown rule can collapse it back to the `@[...]( ...)` tag
+ * losslessly, and the marked extension can expand the tag back into the same HTML.
+ *
+ * No new runtime dependencies: native <video>/<audio> players and inline SVG
+ * icons (lucide path data) keep the footprint small and the look native.
+ *
+ * External URL embeds build on the exact same `@[...]( ...)` grammar. When the
+ * href is an external http(s) page (not a local upload and not a remote file
+ * with a known media extension) the tag is treated as a *URL embed*: recognized
+ * platforms (YouTube, Vimeo, Rumble, Twitch, X, Facebook, Instagram,
+ * SoundCloud, YouTube Music) render a rich provider embed via `ext-embeds`,
+ * everything else renders a generic link-preview card with a "Visit site"
+ * button hydrated by `/api/link-preview`. The bracket carries only the optional
+ * size spec and an optional `urlOnly` keyword (which suppresses the preview and
+ * renders a plain link), keeping the round-trip lossless:
+ *
+ *     @[](https://youtu.be/ID)                 // rich embed, default preview
+ *     @[640x360](https://youtu.be/ID)          // sized rich embed
+ *     @[urlOnly](https://example.com/post)     // plain link, no preview
+ */
+import { buildProviderEmbed } from "@/lib/ext-embeds";
+
+export type EmbedKind = "video" | "audio" | "file";
+export type FileCategory =
+  | "video"
+  | "audio"
+  | "document"
+  | "spreadsheet"
+  | "slides"
+  | "archive"
+  | "generic";
+
+/** Size specification for embeds. */
+export type EmbedSize =
+  | { type: "pixels"; width: number; height: number }
+  | { type: "percent"; width: number }
+  | { type: "preset"; size: "small" | "medium" | "large" }
+  | { type: "none" };
+
+/**
+ * State machine parser for size specifications in markdown embed tags.
+ * Parses formats like:
+ * - "640x360" -> { type: "pixels", width: 640, height: 360 }
+ * - "50%" -> { type: "percent", width: 50 }
+ * - "small" -> { type: "preset", size: "small" }
+ * - "width=640" -> { type: "pixels", width: 640, height: 0 }
+ * - "width=640 height=360" -> { type: "pixels", width: 640, height: 360 }
+ */
+export function parseSizeSpec(input: string): EmbedSize {
+  const trimmed = input.trim();
+  if (!trimmed) return { type: "none" };
+
+  // State machine states
+  type State =
+    | "start"
+    | "digit"
+    | "after_digit"
+    | "x"
+    | "after_x"
+    | "percent"
+    | "preset"
+    | "named_key"
+    | "named_equals"
+    | "named_value"
+    | "named_after_value"
+    | "space";
+
+  let state: State = "start";
+  let width = 0;
+  let height = 0;
+  let currentNumber = "";
+  let currentKey = "";
+  let presetName = "";
+
+  for (let i = 0; i < trimmed.length; i++) {
+    const char = trimmed[i];
+
+    switch (state) {
+      case "start":
+        if (char >= "0" && char <= "9") {
+          state = "digit";
+          currentNumber = char;
+        } else if (char === "s" || char === "S") {
+          state = "preset";
+          presetName = char.toLowerCase();
+        } else if (char === "m" || char === "M") {
+          state = "preset";
+          presetName = char.toLowerCase();
+        } else if (char === "l" || char === "L") {
+          state = "preset";
+          presetName = char.toLowerCase();
+        } else if (char === "w" || char === "W") {
+          state = "named_key";
+          currentKey = char.toLowerCase();
+        } else if (char === " ") {
+          state = "space";
+        } else {
+          return { type: "none" };
+        }
+        break;
+
+      case "digit":
+        if (char >= "0" && char <= "9") {
+          currentNumber += char;
+        } else if (char === "x" || char === "X") {
+          width = parseInt(currentNumber, 10);
+          state = "x";
+          currentNumber = "";
+        } else if (char === "%") {
+          width = parseInt(currentNumber, 10);
+          return { type: "percent", width };
+        } else if (char === " ") {
+          width = parseInt(currentNumber, 10);
+          state = "after_digit";
+          currentNumber = "";
+        } else {
+          return { type: "none" };
+        }
+        break;
+
+      case "after_digit":
+        if (char === "x" || char === "X") {
+          state = "x";
+        } else if (char === " ") {
+          // continue
+        } else {
+          return { type: "none" };
+        }
+        break;
+
+      case "x":
+        if (char >= "0" && char <= "9") {
+          state = "after_x";
+          currentNumber = char;
+        } else if (char === " ") {
+          // continue
+        } else {
+          return { type: "none" };
+        }
+        break;
+
+      case "after_x":
+        if (char >= "0" && char <= "9") {
+          currentNumber += char;
+        } else if (char === " " || i === trimmed.length - 1) {
+          height = parseInt(currentNumber, 10);
+          state = "space";
+        } else {
+          return { type: "none" };
+        }
+        break;
+
+
+      case "preset":
+        if (char >= "a" && char <= "z") {
+          presetName += char;
+        } else if (char === " " || i === trimmed.length - 1) {
+          if (presetName === "small" || presetName === "medium" || presetName === "large") {
+            return { type: "preset", size: presetName as "small" | "medium" | "large" };
+          }
+          return { type: "none" };
+        } else {
+          return { type: "none" };
+        }
+        break;
+
+      case "named_key":
+        if (char >= "a" && char <= "z") {
+          currentKey += char;
+        } else if (char === "=") {
+          state = "named_equals";
+        } else {
+          return { type: "none" };
+        }
+        break;
+
+      case "named_equals":
+        if (char >= "0" && char <= "9") {
+          state = "named_value";
+          currentNumber = char;
+        } else {
+          return { type: "none" };
+        }
+        break;
+
+      case "named_value":
+        if (char >= "0" && char <= "9") {
+          currentNumber += char;
+        } else if (char === " " || i === trimmed.length - 1) {
+          const value = parseInt(currentNumber, 10);
+          if (currentKey === "width") {
+            width = value;
+          } else if (currentKey === "height") {
+            height = value;
+          }
+          currentKey = "";
+          currentNumber = "";
+          state = "named_after_value";
+        } else {
+          return { type: "none" };
+        }
+        break;
+
+      case "named_after_value":
+        if (char === " ") {
+          // continue
+        } else if (char >= "a" && char <= "z") {
+          state = "named_key";
+          currentKey = char.toLowerCase();
+        } else {
+          return { type: "none" };
+        }
+        break;
+
+      case "space":
+        if (char === " ") {
+          // continue
+        } else if (char >= "0" && char <= "9") {
+          state = "digit";
+          currentNumber = char;
+        } else if (char === "s" || char === "S" || char === "m" || char === "M" || char === "l" || char === "L") {
+          state = "preset";
+          presetName = char.toLowerCase();
+        } else if (char === "w" || char === "W") {
+          state = "named_key";
+          currentKey = char.toLowerCase();
+        } else {
+          return { type: "none" };
+        }
+        break;
+    }
+  }
+
+  // Handle end of string
+  if (state === "digit") {
+    width = parseInt(currentNumber, 10);
+    return { type: "pixels", width, height: 0 };
+  }
+  if (state === "after_x") {
+    height = parseInt(currentNumber, 10);
+    return { type: "pixels", width, height };
+  }
+  if (state === "preset") {
+    if (presetName === "small" || presetName === "medium" || presetName === "large") {
+      return { type: "preset", size: presetName as "small" | "medium" | "large" };
+    }
+    return { type: "none" };
+  }
+  if (state === "named_value") {
+    const value = parseInt(currentNumber, 10);
+    if (currentKey === "width") {
+      width = value;
+    } else if (currentKey === "height") {
+      height = value;
+    }
+    return { type: "pixels", width, height };
+  }
+
+  return { type: "none" };
+}
+
+/**
+ * Convert an EmbedSize back to its markdown string representation.
+ */
+export function sizeSpecToString(size: EmbedSize): string {
+  switch (size.type) {
+    case "pixels":
+      if (size.height > 0) {
+        return `${size.width}x${size.height}`;
+      }
+      return `width=${size.width}`;
+    case "percent":
+      return `${size.width}%`;
+    case "preset":
+      return size.size;
+    case "none":
+      return "";
+  }
+}
+
+/** Extension -> rendering kind. Anything not listed renders as a file card. */
+const VIDEO_EXTS = ["mp4", "webm", "mov", "avi", "mkv", "ogv", "m4v"];
+const AUDIO_EXTS = ["mp3", "wav", "ogg", "m4a", "flac", "aac", "opus"];
+const DOCUMENT_EXTS = ["pdf", "doc", "docx", "odt", "rtf", "txt", "md"];
+const SPREADSHEET_EXTS = ["xls", "xlsx", "csv", "ods"];
+const SLIDES_EXTS = ["ppt", "pptx", "odp"];
+const ARCHIVE_EXTS = ["zip", "rar", "7z", "tar", "gz"];
+
+/** All extensions accepted by the file upload button. */
+export const ALLOWED_FILE_EXTS: string[] = [
+  ...VIDEO_EXTS,
+  ...AUDIO_EXTS,
+  ...DOCUMENT_EXTS,
+  ...SPREADSHEET_EXTS,
+  ...SLIDES_EXTS,
+  ...ARCHIVE_EXTS,
+];
+
+/** Comma-separated `accept` attribute value for the file <input>. */
+export const FILE_ACCEPT = ALLOWED_FILE_EXTS.map((e) => `.${e}`).join(",");
+
+/** MIME type per extension (used by the upload + file-serving routes). */
+export const CONTENT_TYPES: Record<string, string> = {
+  // images
+  jpg: "image/jpeg",
+  jpeg: "image/jpeg",
+  png: "image/png",
+  gif: "image/gif",
+  svg: "image/svg+xml",
+  webp: "image/webp",
+  // video
+  mp4: "video/mp4",
+  webm: "video/webm",
+  mov: "video/quicktime",
+  avi: "video/x-msvideo",
+  mkv: "video/x-matroska",
+  ogv: "video/ogg",
+  m4v: "video/x-m4v",
+  // audio
+  mp3: "audio/mpeg",
+  wav: "audio/wav",
+  ogg: "audio/ogg",
+  m4a: "audio/mp4",
+  flac: "audio/flac",
+  aac: "audio/aac",
+  opus: "audio/opus",
+  // documents
+  pdf: "application/pdf",
+  doc: "application/msword",
+  docx: "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
+  odt: "application/vnd.oasis.opendocument.text",
+  rtf: "application/rtf",
+  txt: "text/plain",
+  md: "text/markdown",
+  // spreadsheets
+  xls: "application/vnd.ms-excel",
+  xlsx: "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
+  csv: "text/csv",
+  ods: "application/vnd.oasis.opendocument.spreadsheet",
+  // slides
+  ppt: "application/vnd.ms-powerpoint",
+  pptx: "application/vnd.openxmlformats-officedocument.presentationml.presentation",
+  odp: "application/vnd.oasis.opendocument.presentation",
+  // archives
+  zip: "application/zip",
+  rar: "application/vnd.rar",
+  "7z": "application/x-7z-compressed",
+  tar: "application/x-tar",
+  gz: "application/gzip",
+};
+
+/** Extract a lowercased file extension from a name or URL (no leading dot). */
+export function extOf(nameOrUrl: string): string {
+  const clean = nameOrUrl.split(/[?#]/)[0] ?? "";
+  const dot = clean.lastIndexOf(".");
+  if (dot === -1 || dot === clean.length - 1) return "";
+  return clean.slice(dot + 1).toLowerCase();
+}
+
+export function kindForExt(ext: string): EmbedKind {
+  if (VIDEO_EXTS.includes(ext)) return "video";
+  if (AUDIO_EXTS.includes(ext)) return "audio";
+  return "file";
+}
+
+export function categoryForExt(ext: string): FileCategory {
+  if (VIDEO_EXTS.includes(ext)) return "video";
+  if (AUDIO_EXTS.includes(ext)) return "audio";
+  if (DOCUMENT_EXTS.includes(ext)) return "document";
+  if (SPREADSHEET_EXTS.includes(ext)) return "spreadsheet";
+  if (SLIDES_EXTS.includes(ext)) return "slides";
+  if (ARCHIVE_EXTS.includes(ext)) return "archive";
+  return "generic";
+}
+
+/* ---------------------------- url detection ------------------------------ */
+const IMAGE_EXTS = ["jpg", "jpeg", "png", "gif", "svg", "webp", "avif", "bmp", "ico"];
+
+/** Extensions that identify a *file* (media/doc) rather than an HTML page. */
+const FILE_LIKE_EXTS = new Set<string>([...ALLOWED_FILE_EXTS, ...IMAGE_EXTS]);
+
+/** True for an absolute http(s) URL. */
+export function isExternalHttpUrl(s: string): boolean {
+  return /^https?:\/\//i.test(s.trim());
+}
+
+/**
+ * Decide whether an `@[...]( href)` tag should render as a *URL embed* (rich
+ * provider embed or generic link preview) rather than a file/media embed.
+ *
+ * A URL embed is any external http(s) href that is neither a local upload
+ * (`/api/uploads/...`) nor a direct link to a file with a known media/document
+ * extension (those keep rendering as native <video>/<audio>/file cards).
+ */
+export function shouldTreatAsUrlEmbed(href: string): boolean {
+  if (!isExternalHttpUrl(href)) return false;
+  if (href.includes("/api/uploads/")) return false;
+  const ext = extOf(href);
+  if (ext && FILE_LIKE_EXTS.has(ext)) return false;
+  return true;
+}
+
+/* --------------------------------- icons --------------------------------- */
+// Inline lucide path data (stroke uses currentColor). 24x24 viewBox.
+const ICON_PATHS: Record<FileCategory, string> = {
+  document:
+    '<path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/>',
+  spreadsheet:
+    '<rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M3 15h18"/><path d="M9 3v18"/><path d="M15 3v18"/>',
+  slides:
+    '<path d="M2 3h20"/><path d="M21 3v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V3"/><path d="m7 21 5-5 5 5"/>',
+  archive:
+    '<rect width="20" height="5" x="2" y="3" rx="1"/><path d="M4 8v11a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8"/><path d="M10 12h4"/>',
+  video:
+    '<path d="m22 8-6 4 6 4V8Z"/><rect width="14" height="12" x="2" y="6" rx="2"/>',
+  audio: '<path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>',
+  generic:
+    '<path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/>',
+};
+
+const DOWNLOAD_ICON =
+  '<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/>';
+
+function svg(paths: string): string {
+  return (
+    '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" ' +
+    'fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" ' +
+    'stroke-linejoin="round" aria-hidden="true">' +
+    paths +
+    "</svg>"
+  );
+}
+
+/* ------------------------------- escaping -------------------------------- */
+function escapeHtml(s: string): string {
+  return s
+    .replace(/&/g, "&amp;")
+    .replace(/</g, "&lt;")
+    .replace(/>/g, "&gt;")
+    .replace(/"/g, "&quot;")
+    .replace(/'/g, "&#39;");
+}
+
+function escapeAttr(s: string): string {
+  return escapeHtml(s);
+}
+
+/* ----------------------------- HTML builder ------------------------------ */
+export interface EmbedInput {
+  /** Display name / title (usually the original filename). */
+  name: string;
+  /** File URL (local `/api/uploads/...` or any remote URL). */
+  src: string;
+  /** Optional size specification. */
+  size?: EmbedSize;
+}
+
+/**
+ * Build the stored/rendered HTML for an attachment. The output is self-styling
+ * via `.cb-embed*` classes (see globals.scss) and carries data attributes so it
+ * round-trips losslessly through turndown/marked.
+ */
+export function buildEmbedHtml({ name, src, size }: EmbedInput): string {
+  const ext = extOf(name) || extOf(src);
+  const kind = kindForExt(ext);
+  const safeName = escapeHtml(name || src);
+  const aName = escapeAttr(name || src);
+  const aSrc = escapeAttr(src);
+  const sizeSpec = size ? sizeSpecToString(size) : "";
+  const dataAttrs = `data-embed="1" data-name="${aName}" data-src="${aSrc}" data-size="${escapeAttr(
+    sizeSpec,
+  )}"`;
+
+  // Build size class and inline styles
+  let sizeClass = "";
+  let sizeStyle = "";
+  if (size) {
+    switch (size.type) {
+      case "pixels":
+        sizeClass = "cb-embed--size-pixels";
+        sizeStyle = `width: ${size.width}px;`;
+        if (size.height > 0) {
+          sizeStyle += ` height: ${size.height}px;`;
+        }
+        break;
+      case "percent":
+        sizeClass = "cb-embed--size-percent";
+        sizeStyle = `width: ${size.width}%;`;
+        break;
+      case "preset":
+        sizeClass = `cb-embed--size-${size.size}`;
+        break;
+      case "none":
+        break;
+    }
+  }
+
+  const baseClass = `cb-embed cb-embed--${kind} ${sizeClass}`.trim();
+
+  if (kind === "video") {
+    const mediaStyle = sizeStyle ? ` style="${sizeStyle}"` : "";
+    return (
+      `<figure class="${baseClass}" contenteditable="false" ${dataAttrs}>` +
+      `<video class="cb-embed__media" controls preload="metadata" src="${aSrc}"${mediaStyle}>` +
+      `<a href="${aSrc}">${safeName}</a></video>` +
+      `<figcaption class="cb-embed__caption">${safeName}</figcaption>` +
+      `</figure>`
+    );
+  }
+
+  if (kind === "audio") {
+    const mediaStyle = sizeStyle ? ` style="${sizeStyle}"` : "";
+    return (
+      `<figure class="${baseClass}" contenteditable="false" ${dataAttrs}>` +
+      `<figcaption class="cb-embed__caption">${safeName}</figcaption>` +
+      `<audio class="cb-embed__media" controls preload="metadata" src="${aSrc}"${mediaStyle}>` +
+      `<a href="${aSrc}">${safeName}</a></audio>` +
+      `</figure>`
+    );
+  }
+
+  const category = categoryForExt(ext);
+  const typeLabel = ext ? ext.toUpperCase() : "FILE";
+  const containerStyle = sizeStyle ? ` style="${sizeStyle}"` : "";
+  return (
+    `<div class="${baseClass}" contenteditable="false" ${dataAttrs} data-ext="${escapeAttr(
+      ext,
+    )}"${containerStyle}>` +
+    `<span class="cb-embed__icon">${svg(ICON_PATHS[category])}</span>` +
+    `<span class="cb-embed__meta">` +
+    `<span class="cb-embed__name">${safeName}</span>` +
+    `<span class="cb-embed__type">${typeLabel}</span>` +
+    `</span>` +
+    `<a class="cb-embed__btn" href="${aSrc}" download title="Download ${aName}">` +
+    `${svg(DOWNLOAD_ICON)}<span>Download</span></a>` +
+    `</div>`
+  );
+}
+
+/* --------------------------- markdown tag form --------------------------- */
+/** `@[name](url)` â€” the canonical Markdown representation of an embed. */
+export function buildEmbedMarkdown({ name, src, size }: EmbedInput): string {
+  const sizeSpec = size ? sizeSpecToString(size) : "";
+  if (sizeSpec) {
+    return `@[${name} ${sizeSpec}](${src})`;
+  }
+  return `@[${name}](${src})`;
+}
+
+/* ----------------------------- url embeds -------------------------------- */
+/** Prefetched Open Graph metadata used to hydrate a generic preview card. */
+export interface LinkMeta {
+  title?: string;
+  description?: string;
+  image?: string;
+  siteName?: string;
+}
+
+export interface UrlEmbedInput {
+  /** The external page URL. */
+  url: string;
+  /** Optional size specification (applies to rich embeds + preview cards). */
+  size?: EmbedSize;
+  /** When true, render only a plain link (no rich embed, no preview card). */
+  urlOnly?: boolean;
+  /** Optional prefetched metadata to bake into the generic preview card. */
+  meta?: LinkMeta;
+}
+
+/** Parse the bracket of a URL embed into its size spec + `urlOnly` flag. */
+export function parseUrlBracket(bracket: string): { size: EmbedSize; urlOnly: boolean } {
+  const tokens = bracket.trim().split(/\s+/).filter(Boolean);
+  let urlOnly = false;
+  const rest: string[] = [];
+  for (const t of tokens) {
+    if (t.toLowerCase() === "urlonly") urlOnly = true;
+    else rest.push(t);
+  }
+  const sizeSpec = rest.join(" ").trim();
+  const size = sizeSpec ? parseSizeSpec(sizeSpec) : { type: "none" as const };
+  return { size, urlOnly };
+}
+
+/**
+ * `@[size? urlOnly?](url)` â€” the canonical Markdown for a URL embed. Only the
+ * URL, the optional size, and the optional `urlOnly` keyword are stored; the
+ * bracket is empty for a bare rich embed (`@[](url)`), keeping the round-trip
+ * deterministic (metadata is re-derived / re-fetched, never serialized).
+ */
+export function buildUrlEmbedMarkdown({ url, size, urlOnly }: UrlEmbedInput): string {
+  const tokens: string[] = [];
+  const sizeSpec = size ? sizeSpecToString(size) : "";
+  if (sizeSpec) tokens.push(sizeSpec);
+  if (urlOnly) tokens.push("urlOnly");
+  return `@[${tokens.join(" ")}](${url})`;
+}
+
+/** Hostname (sans leading www.) for a URL, or the raw string on parse failure. */
+function urlHost(url: string): string {
+  try {
+    return new URL(url).hostname.replace(/^www\./i, "");
+  } catch {
+    return url;
+  }
+}
+
+/**
+ * Map a size spec to the inline style applied to a URL-embed figure. Rich
+ * embeds fill this width and derive height from the shape's aspect ratio;
+ * explicit pixel height (WxH) forces a fixed frame height.
+ */
+function urlEmbedSize(size?: EmbedSize): { cls: string; figureStyle: string; frameStyle: string } {
+  if (!size || size.type === "none") return { cls: "", figureStyle: "", frameStyle: "" };
+  switch (size.type) {
+    case "pixels": {
+      const figureStyle = `width: ${size.width}px;`;
+      const frameStyle = size.height > 0 ? `height: ${size.height}px;` : "";
+      return { cls: "cb-embed--size-pixels", figureStyle, frameStyle };
+    }
+    case "percent":
+      return { cls: "cb-embed--size-percent", figureStyle: `width: ${size.width}%;`, frameStyle: "" };
+    case "preset":
+      return { cls: `cb-embed--size-${size.size}`, figureStyle: "", frameStyle: "" };
+    default:
+      return { cls: "", figureStyle: "", frameStyle: "" };
+  }
+}
+
+// Lucide "external-link" glyph for the Visit-site button.
+const EXTERNAL_LINK_ICON =
+  '<path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>';
+
+/** Common data attributes so a URL embed round-trips via the turndown rule. */
+function urlDataAttrs(url: string, size?: EmbedSize, urlOnly?: boolean): string {
+  const sizeSpec = size ? sizeSpecToString(size) : "";
+  return (
+    `data-embed="1" data-embed-type="url" data-src="${escapeAttr(url)}" ` +
+    `data-size="${escapeAttr(sizeSpec)}"${urlOnly ? ' data-url-only="1"' : ""}`
+  );
+}
+
+/**
+ * Build the stored/rendered HTML for a URL embed. Three branches:
+ *  - `urlOnly` -> a plain anchor (no preview),
+ *  - recognized provider -> a rich `.cb-embed__frame` (iframe / blockquote),
+ *  - otherwise -> a generic link-preview card (thumbnail, title, host, Visit
+ *    site) marked `data-link-hydrate="1"` for client-side metadata enrichment.
+ *
+ * All three carry the same `data-embed`/`data-embed-type`/`data-src`/`data-size`
+ * attributes, so a single turndown rule collapses any of them back to the tag.
+ */
+export function buildUrlEmbedHtml({ url, size, urlOnly, meta }: UrlEmbedInput): string {
+  const aUrl = escapeAttr(url);
+  const data = urlDataAttrs(url, size, urlOnly);
+  const { cls: sizeCls, figureStyle, frameStyle } = urlEmbedSize(size);
+
+  // Plain-link branch: no preview at all.
+  if (urlOnly) {
+    return (
+      `<a class="cb-embed cb-embed--urlonly" contenteditable="false" ${data} ` +
+      `href="${aUrl}" target="_blank" rel="noopener noreferrer">${escapeHtml(url)}</a>`
+    );
+  }
+
+  // Rich provider branch.
+  const frame = buildProviderEmbed(url);
+  if (frame) {
+    const figClass = `cb-embed cb-embed--url cb-embed--rich cb-embed--${frame.provider} ${sizeCls}`.trim();
+    const figStyle = figureStyle ? ` style="${figureStyle}"` : "";
+    const frStyle = frameStyle ? ` style="${frameStyle}"` : "";
+    const scriptAttr = frame.script ? ` data-embed-script="${escapeAttr(frame.script)}"` : "";
+    return (
+      `<figure class="${figClass}" contenteditable="false" ${data} ` +
+      `data-provider="${escapeAttr(frame.provider)}" data-shape="${frame.shape}"${scriptAttr}${figStyle}>` +
+      `<div class="cb-embed__frame cb-embed__frame--${frame.shape}"${frStyle}>${frame.html}</div>` +
+      `<figcaption class="cb-embed__caption">` +
+      `<a href="${aUrl}" target="_blank" rel="noopener noreferrer">${escapeHtml(frame.label)} â€” ${escapeHtml(urlHost(url))}</a>` +
+      `</figcaption>` +
+      `</figure>`
+    );
+  }
+
+  // Generic link-preview branch (fallback with a Visit-site button).
+  const host = urlHost(url);
+  const title = meta?.title ? escapeHtml(meta.title) : escapeHtml(host);
+  const desc = meta?.description ? escapeHtml(meta.description) : "";
+  const img = meta?.image ? escapeAttr(meta.image) : "";
+  const site = meta?.siteName ? escapeHtml(meta.siteName) : escapeHtml(host);
+  const figClass = `cb-embed cb-embed--url cb-embed--link ${sizeCls}`.trim();
+  const figStyle = figureStyle ? ` style="${figureStyle}"` : "";
+  const thumb = img
+    ? `<img class="cb-embed__thumb" src="${img}" alt="" loading="lazy" />`
+    : `<span class="cb-embed__thumb cb-embed__thumb--empty" aria-hidden="true">${svg(ICON_PATHS.generic)}</span>`;
+
+  return (
+    `<figure class="${figClass}" contenteditable="false" ${data} data-link-hydrate="1"${figStyle}>` +
+    `<a class="cb-embed__link" href="${aUrl}" target="_blank" rel="noopener noreferrer">` +
+    thumb +
+    `<span class="cb-embed__meta">` +
+    `<span class="cb-embed__site">${site}</span>` +
+    `<span class="cb-embed__title">${title}</span>` +
+    (desc ? `<span class="cb-embed__desc">${desc}</span>` : "") +
+    `<span class="cb-embed__url">${escapeHtml(host)}</span>` +
+    `</span>` +
+    `</a>` +
+    `<a class="cb-embed__btn cb-embed__visit" href="${aUrl}" target="_blank" rel="noopener noreferrer" title="Visit ${escapeAttr(host)}">` +
+    `${svg(EXTERNAL_LINK_ICON)}<span>Visit site</span></a>` +
+    `</figure>`
+  );
+}
+
+/* ---------------------------- sized images ------------------------------ */
+/**
+ * Input for a sized inline image. Mirrors `EmbedInput` but for the standard
+ * Markdown image syntax with a trailing size spec:
+ *
+ *     ![alt](url){small}
+ *     ![alt](url){width=250 height=300}
+ *     ![alt](url){50%}
+ *     ![alt](url){640x360}
+ *
+ * The size spec reuses the same grammar as embeds via `parseSizeSpec` /
+ * `sizeSpecToString`, so both features stay in lockstep.
+ */
+export interface ImageInput {
+  /** Alt text. */
+  alt: string;
+  /** Image URL. */
+  src: string;
+  /** Optional size specification. */
+  size?: EmbedSize;
+}
+
+/**
+ * Build the stored/rendered HTML for a sized image. Carries `data-cb-img="1"`
+ * plus `data-alt`, `data-src`, `data-size` so the turndown rule can collapse it
+ * back to `![alt](url){spec}` losslessly.
+ */
+export function buildImageHtml({ alt, src, size }: ImageInput): string {
+  const aAlt = escapeAttr(alt);
+  const aSrc = escapeAttr(src);
+  const sizeSpec = size ? sizeSpecToString(size) : "";
+
+  let sizeClass = "";
+  let sizeStyle = "";
+  if (size) {
+    switch (size.type) {
+      case "pixels":
+        sizeClass = "cb-img--size-pixels";
+        sizeStyle = `width: ${size.width}px;`;
+        if (size.height > 0) {
+          sizeStyle += ` height: ${size.height}px;`;
+        }
+        break;
+      case "percent":
+        sizeClass = "cb-img--size-percent";
+        sizeStyle = `width: ${size.width}%;`;
+        break;
+      case "preset":
+        sizeClass = `cb-img--size-${size.size}`;
+        break;
+      case "none":
+        break;
+    }
+  }
+
+  const cls = `cb-img ${sizeClass}`.trim();
+  const styleAttr = sizeStyle ? ` style="${sizeStyle}"` : "";
+  return (
+    `<img class="${cls}" src="${aSrc}" alt="${aAlt}" ` +
+    `data-cb-img="1" data-alt="${aAlt}" data-src="${aSrc}" ` +
+    `data-size="${escapeAttr(sizeSpec)}"${styleAttr} />`
+  );
+}
+
+/** `![alt](url){spec}` â€” the canonical Markdown representation of a sized image. */
+export function buildImageMarkdown({ alt, src, size }: ImageInput): string {
+  const sizeSpec = size ? sizeSpecToString(size) : "";
+  if (sizeSpec) {
+    return `![${alt}](${src}){${sizeSpec}}`;
+  }
+  return `![${alt}](${src})`;
+}
+
+/**
+ * Matches a Markdown image immediately followed by a `{size}` spec at the start
+ * of the input: `![alt](url){spec}`.
+ */
+const SIZED_IMAGE_RULE = /^!\[([^\]]*)\]\(\s*([^)\s]+)\s*\)\{([^}]+)\}/;
+
+/**
+ * Register the `![alt](url){spec}` inline tokenizer + renderer on a marked
+ * instance. Idempotent per-instance via a private flag. Images without a valid
+ * `{spec}` fall through to marked's default image handling.
+ */
+export function registerImageSizeExtension(marked: {
+  use: (...args: import("marked").MarkedExtension[]) => typeof marked;
+}): void {
+  const flagged = marked as unknown as { __cbImgSize?: boolean };
+  if (flagged.__cbImgSize) return;
+  flagged.__cbImgSize = true;
+
+  marked.use({
+    extensions: [
+      {
+        name: "sizedImage",
+        level: "inline",
+        start(src: string) {
+          const i = src.indexOf("![");
+          return i < 0 ? undefined : i;
+        },
+        tokenizer(src: string) {
+          const m = SIZED_IMAGE_RULE.exec(src);
+          if (!m) return undefined;
+          const alt = m[1] ?? "";
+          const href = m[2] ?? "";
+          const spec = (m[3] ?? "").trim();
+          const size = parseSizeSpec(spec);
+          // Unknown spec -> let the default image tokenizer handle it (the
+          // literal `{spec}` will remain as trailing text).
+          if (size.type === "none") return undefined;
+          return {
+            type: "sizedImage",
+            raw: m[0],
+            alt,
+            href,
+            size,
+          };
+        },
+        renderer(token: import("marked").Tokens.Generic) {
+          const t = token as unknown as { alt: string; href: string; size?: EmbedSize };
+          return buildImageHtml({ alt: t.alt, src: t.href, size: t.size });
+        },
+      },
+    ],
+  });
+}
+
+/**
+ * Add a turndown rule that collapses sized-image HTML back into the
+ * `![alt](url){spec}` tag. Only applies to `<img data-cb-img="1">`; plain
+ * images fall through to turndown's default image handling.
+ */
+export function addImageTurndownRule(turndown: {
+  addRule: (key: string, rule: unknown) => void;
+}): void {
+  turndown.addRule("cbImg", {
+    filter: (node: HTMLElement) =>
+      node.nodeType === 1 &&
+      node.nodeName === "IMG" &&
+      typeof node.getAttribute === "function" &&
+      node.getAttribute("data-cb-img") === "1",
+    replacement: (_content: string, node: HTMLElement) => {
+      const alt = node.getAttribute("data-alt") ?? node.getAttribute("alt") ?? "";
+      const src = node.getAttribute("data-src") ?? node.getAttribute("src") ?? "";
+      const sizeSpec = node.getAttribute("data-size") || "";
+      const size = sizeSpec ? parseSizeSpec(sizeSpec) : { type: "none" as const };
+      return buildImageMarkdown({ alt, src, size });
+    },
+  });
+}
+
+/* -------------------------- preview separator ---------------------------- */
+/**
+ * `--END PREVIEW--` on its own line marks where the feed preview should stop.
+ * It renders as an <hr> carrying `data-preview-end="1"` so it round-trips back
+ * to the marker via turndown, and so the feed can split the stored HTML on it
+ * (see `extractPreviewHtml`) to show everything before it â€” full code blocks and
+ * all â€” instead of the automatic character-truncated preview.
+ */
+export const PREVIEW_END_MARKER = "--END PREVIEW--";
+
+/** Canonical HTML for the preview separator. */
+export function buildPreviewEndHtml(): string {
+  return `<hr data-preview-end="1" class="cb-preview-end" />`;
+}
+
+/** Matches the stored preview-separator <hr> (any attribute order). */
+export const PREVIEW_END_HTML_RE = /<hr\b[^>]*\bdata-preview-end\b[^>]*>/i;
+
+/**
+ * If `html` contains the preview separator, return the HTML *before* it
+ * (trimmed); otherwise return null. Used by the feed to render an HTML preview
+ * that stops exactly at the marker rather than truncating plain text.
+ */
+export function extractPreviewHtml(html: string): string | null {
+  const m = PREVIEW_END_HTML_RE.exec(html);
+  if (!m) return null;
+  return html.slice(0, m.index).trim();
+}
+
+/** Matches the `--END PREVIEW--` marker as its own block at the input start. */
+const PREVIEW_END_RULE = /^--END PREVIEW--[ \t]*(?:\n+|$)/;
+
+/**
+ * Register the `--END PREVIEW--` block tokenizer + renderer on a marked
+ * instance. Idempotent per-instance via a private flag.
+ */
+export function registerPreviewEndExtension(marked: {
+  use: (...args: import("marked").MarkedExtension[]) => typeof marked;
+}): void {
+  const flagged = marked as unknown as { __cbPreviewEnd?: boolean };
+  if (flagged.__cbPreviewEnd) return;
+  flagged.__cbPreviewEnd = true;
+
+  marked.use({
+    extensions: [
+      {
+        name: "previewEnd",
+        level: "block",
+        start(src: string) {
+          const i = src.indexOf("--END PREVIEW--");
+          return i < 0 ? undefined : i;
+        },
+        tokenizer(src: string) {
+          const m = PREVIEW_END_RULE.exec(src);
+          if (!m) return undefined;
+          return { type: "previewEnd", raw: m[0] };
+        },
+        renderer() {
+          return `${buildPreviewEndHtml()}\n`;
+        },
+      },
+    ],
+  });
+}
+
+/**
+ * Add a turndown rule that collapses the preview-separator <hr> back into the
+ * `--END PREVIEW--` marker. Only matches HRs carrying `data-preview-end`; plain
+ * horizontal rules fall through to turndown's default handling.
+ */
+export function addPreviewEndTurndownRule(turndown: {
+  addRule: (key: string, rule: unknown) => void;
+}): void {
+  turndown.addRule("cbPreviewEnd", {
+    filter: (node: HTMLElement) =>
+      node.nodeType === 1 &&
+      node.nodeName === "HR" &&
+      typeof node.getAttribute === "function" &&
+      node.getAttribute("data-preview-end") != null,
+    replacement: () => `\n\n${PREVIEW_END_MARKER}\n\n`,
+  });
+}
+
+/**
+ * Matches a single `@[bracket](url)` tag at the start of the input. The bracket
+ * is optional (`*`) so bare URL embeds (`@[](url)`) tokenize as well as file
+ * embeds (`@[name.ext](url)`).
+ */
+const ATTACHMENT_RULE = /^@\[([^\]]*)\]\(\s*([^)\s]+)\s*\)/;
+
+/**
+ * Register the `@[name](url)` block tokenizer + renderer on a marked instance.
+ * Idempotent per-instance via a private flag.
+ */
+export function registerEmbedExtension(marked: {
+  use: (...args: import("marked").MarkedExtension[]) => typeof marked;
+}): void {
+  // Sized images share the same markdown feature set; register them here so
+  // every embed-enabled marked instance also understands `![alt](url){spec}`.
+  registerImageSizeExtension(marked);
+  // The `--END PREVIEW--` separator is part of the same authoring toolkit.
+  registerPreviewEndExtension(marked);
+
+  const flagged = marked as unknown as { __cbEmbed?: boolean };
+  if (flagged.__cbEmbed) return;
+  flagged.__cbEmbed = true;
+
+  marked.use({
+    extensions: [
+      {
+        name: "attachment",
+        level: "block",
+        start(src: string) {
+          const i = src.indexOf("@[");
+          return i < 0 ? undefined : i;
+        },
+        tokenizer(src: string) {
+          const m = ATTACHMENT_RULE.exec(src);
+          if (!m) return undefined;
+          const bracketContent = m[1] ?? "";
+          const href = m[2] ?? "";
+
+          // External http(s) pages (not local uploads / not direct file links)
+          // are URL embeds: the bracket carries only size + `urlOnly`.
+          if (shouldTreatAsUrlEmbed(href)) {
+            const { size, urlOnly } = parseUrlBracket(bracketContent);
+            return {
+              type: "attachment",
+              raw: m[0],
+              embedType: "url",
+              href,
+              size,
+              urlOnly,
+            };
+          }
+
+          // Parse the bracket content to separate name from size spec
+          // Format: "name size" or just "name"
+          const trimmed = bracketContent.trim();
+          let name = trimmed;
+          let sizeSpec = "";
+
+          // Try to find a size spec at the end
+          // Size specs are: WxH, W%, small/medium/large, width=W, etc.
+          const sizePatterns = [
+            /\s+(\d+x\d+)\s*$/i,           // 640x360
+            /\s+(\d+%)\s*$/,               // 50%
+            /\s+(small|medium|large)\s*$/i, // preset
+            /\s+(width=\d+(?:\s+height=\d+)?)\s*$/i, // named params
+          ];
+
+          for (const pattern of sizePatterns) {
+            const match = trimmed.match(pattern);
+            if (match) {
+              sizeSpec = match[1];
+              name = trimmed.slice(0, match.index).trim();
+              break;
+            }
+          }
+
+          const size = sizeSpec ? parseSizeSpec(sizeSpec) : { type: "none" as const };
+          return {
+            type: "attachment",
+            raw: m[0],
+            embedType: "file",
+            name,
+            href,
+            size,
+          };
+        },
+        renderer(token: import("marked").Tokens.Generic) {
+          const t = token as unknown as {
+            embedType?: string;
+            name?: string;
+            href: string;
+            size?: EmbedSize;
+            urlOnly?: boolean;
+          };
+          if (t.embedType === "url") {
+            return buildUrlEmbedHtml({ url: t.href, size: t.size, urlOnly: t.urlOnly });
+          }
+          return buildEmbedHtml({ name: t.name ?? "", src: t.href, size: t.size });
+        },
+      },
+    ],
+  });
+}
+
+/**
+ * Add a turndown rule that collapses embed HTML back into the `@[name](url)`
+ * tag. Pass the turndown instance (kept generic to avoid a hard type import).
+ */
+export function addEmbedTurndownRule(turndown: {
+  addRule: (key: string, rule: unknown) => void;
+}): void {
+  // Sized images belong to the same round-trip system; register their rule so
+  // every embed-enabled turndown instance collapses them back to markdown.
+  addImageTurndownRule(turndown);
+  // Collapse the preview-separator <hr> back to `--END PREVIEW--`.
+  addPreviewEndTurndownRule(turndown);
+
+  turndown.addRule("cbEmbed", {
+    filter: (node: HTMLElement) =>
+      node.nodeType === 1 &&
+      typeof node.getAttribute === "function" &&
+      node.getAttribute("data-embed") === "1",
+    replacement: (_content: string, node: HTMLElement) => {
+      const src = node.getAttribute("data-src") || "";
+      const sizeSpec = node.getAttribute("data-size") || "";
+      const size = sizeSpec ? parseSizeSpec(sizeSpec) : { type: "none" as const };
+
+      // URL embeds (rich provider, generic preview, or plain link) collapse to
+      // `@[size? urlOnly?](url)`; file/media embeds collapse to `@[name size](url)`.
+      if (node.getAttribute("data-embed-type") === "url") {
+        const urlOnly = node.getAttribute("data-url-only") === "1";
+        return `\n\n${buildUrlEmbedMarkdown({ url: src, size, urlOnly })}\n\n`;
+      }
+
+      const name = node.getAttribute("data-name") || "";
+      return `\n\n${buildEmbedMarkdown({ name, src, size })}\n\n`;
+    },
+  });
+
+  // Add rule for code blocks to preserve the language and the preview/collapse
+  // line count. Handles both bare `<pre><code>` blocks and the `.cb-code`
+  // wrapper used for collapsible blocks, round-tripping back to fenced markdown.
+  turndown.addRule("codeBlock", {
+    filter: (node: HTMLElement) =>
+      node.nodeType === 1 &&
+      node.nodeName === "PRE" &&
+      node.firstChild?.nodeName === "CODE",
+    replacement: (_content: string, node: HTMLElement) => {
+      const code = node.firstChild as HTMLElement;
+      const langMatch = code.className.match(/language-([\w+#-]+)/);
+      const lang = langMatch ? langMatch[1] : "";
+
+      // Extract code content without extra whitespace
+      const codeContent = (code.textContent || "").replace(/\n$/, "");
+
+      // `.cb-code` wrappers carry the optional size (data-size) and, when
+      // collapsible, the line count + keyword (preview/collapse). Reconstruct
+      // the info string as `lang [size] [preview|collapse=N]`.
+      const wrapper = node.closest(".cb-code") as HTMLElement | null;
+      const size = wrapper?.getAttribute("data-size");
+      const previewLines = wrapper?.getAttribute("data-preview-lines");
+      const kind = wrapper?.getAttribute("data-collapse-kind") || "preview";
+
+      let info = lang;
+      if (size) info += ` ${size}`;
+      if (previewLines) info += ` ${kind}=${previewLines}`;
+
+      return `\n\n\`\`\`${info}\n${codeContent}\n\`\`\`\n\n`;
+    },
+  });
+
+  // Skip the language header so its label/icon never leak into markdown.
+  turndown.addRule("codeBlockHeader", {
+    filter: (node: HTMLElement) =>
+      node.nodeType === 1 &&
+      node.nodeName === "DIV" &&
+      node.classList.contains("cb-code__header"),
+    replacement: () => "",
+  });
+
+  // Skip the collapse/expand toggle bar so it never leaks into markdown.
+  turndown.addRule("codeBlockToggle", {
+    filter: (node: HTMLElement) =>
+      node.nodeType === 1 &&
+      node.nodeName === "BUTTON" &&
+      node.classList.contains("cb-code__toggle"),
+    replacement: () => "",
+  });
+
+  // Unwrap the `.cb-code` container, leaving its inner <pre> to be handled by
+  // the codeBlock rule above.
+  turndown.addRule("codeBlockWrapper", {
+    filter: (node: HTMLElement) =>
+      node.nodeType === 1 &&
+      node.nodeName === "DIV" &&
+      node.classList.contains("cb-code"),
+    replacement: (content: string) => content,
+  });
+}

diff --git a/src/lib/ext-embeds.ts b/src/lib/ext-embeds.ts
new file mode 100644
--- /dev/null
+++ b/src/lib/ext-embeds.ts
@@ -0,0 +1,316 @@
+/**
+ * ext-embeds: platform-specific rich embed generation for external URLs.
+ *
+ * This library is the single source of truth for turning a recognized platform
+ * URL (YouTube, Vimeo, Rumble, Twitch, X, Facebook, Instagram, SoundCloud,
+ * YouTube Music) into the provider's canonical embed markup. It is deliberately
+ * pure and dependency-free so it can run identically on the server (SSR article
+ * render), in the browser (WYSIWYG marked rendering), and under jsdom (the
+ * round-trip unit tests).
+ *
+ * Contract: given a raw URL, `buildProviderEmbed(url)` returns an `EmbedFrame`
+ * describing the inner HTML to place inside a `.cb-embed__frame`, the visual
+ * shape (video / audio / post) used for aspect-ratio styling, and an optional
+ * external `script` the client hydrator must load (X / Instagram widgets). When
+ * no provider matches â€” or a matched provider cannot yield a usable id â€” it
+ * returns `null`, signalling the caller (`src/lib/embeds.ts`) to fall back to a
+ * generic link-preview card instead.
+ *
+ * Round-trip safety: the embed markup is derived deterministically from the URL
+ * alone; no fetched metadata is baked in. The canonical Markdown tag stores only
+ * the URL (+ size + urlOnly), so `markdown -> HTML -> markdown` is stable.
+ */
+
+export type ProviderName =
+  | "youtube"
+  | "youtubemusic"
+  | "vimeo"
+  | "rumble"
+  | "twitch"
+  | "x"
+  | "facebook"
+  | "instagram"
+  | "soundcloud";
+
+/** Visual shape drives the aspect-ratio / height used by the frame container. */
+export type EmbedShape = "video" | "audio" | "post";
+
+export interface EmbedFrame {
+  provider: ProviderName;
+  /** Inner HTML to place inside `.cb-embed__frame`. */
+  html: string;
+  /** Aspect shape used for CSS sizing. */
+  shape: EmbedShape;
+  /** Human label for the provider (used in captions / a11y). */
+  label: string;
+  /** Optional external script URL the client hydrator must inject once. */
+  script?: string;
+}
+
+/* ------------------------------- escaping -------------------------------- */
+function esc(s: string): string {
+  return s
+    .replace(/&/g, "&amp;")
+    .replace(/</g, "&lt;")
+    .replace(/>/g, "&gt;")
+    .replace(/"/g, "&quot;")
+    .replace(/'/g, "&#39;");
+}
+
+/** Parse a URL safely; returns null on malformed input. */
+function parse(url: string): URL | null {
+  try {
+    return new URL(url);
+  } catch {
+    return null;
+  }
+}
+
+/** Lowercased host with a leading `www.` stripped. */
+function host(u: URL): string {
+  return u.hostname.replace(/^www\./i, "").toLowerCase();
+}
+
+/**
+ * The `parent` domain Twitch requires on every player iframe. Baked into the
+ * stored HTML at author time (browser), falling back to localhost for SSR/tests.
+ */
+function twitchParent(): string {
+  if (typeof window !== "undefined" && window.location?.hostname) {
+    return window.location.hostname;
+  }
+  return "localhost";
+}
+
+/* ---------------------------- id extraction ------------------------------ */
+/** YouTube (and YouTube Music) video id from any of its URL shapes. */
+function youtubeId(u: URL): string | null {
+  const h = host(u);
+  if (h === "youtu.be") {
+    const seg = u.pathname.split("/").filter(Boolean)[0];
+    return seg || null;
+  }
+  const v = u.searchParams.get("v");
+  if (v) return v;
+  const parts = u.pathname.split("/").filter(Boolean);
+  // /embed/ID, /shorts/ID, /live/ID, /v/ID
+  const marker = parts.findIndex((p) => ["embed", "shorts", "live", "v"].includes(p));
+  if (marker >= 0 && parts[marker + 1]) return parts[marker + 1]!;
+  return null;
+}
+
+/** Vimeo numeric id from vimeo.com/ID or player.vimeo.com/video/ID. */
+function vimeoId(u: URL): string | null {
+  const m = u.pathname.match(/(?:\/video)?\/(\d+)/);
+  return m ? m[1]! : null;
+}
+
+/** Rumble embed id (`vXXXXX`) from the article slug or an /embed/ID path. */
+function rumbleId(u: URL): string | null {
+  const parts = u.pathname.split("/").filter(Boolean);
+  const embedIdx = parts.indexOf("embed");
+  if (embedIdx >= 0 && parts[embedIdx + 1]) return parts[embedIdx + 1]!;
+  // Article URLs look like /vABC123-some-title.html -> take the leading token.
+  const slug = parts[parts.length - 1] || "";
+  const m = slug.match(/^(v[a-z0-9]+)/i);
+  return m ? m[1]! : null;
+}
+
+/** Instagram post/reel id from /p/ID/, /reel/ID/, /tv/ID/. */
+function instagramId(u: URL): string | null {
+  const m = u.pathname.match(/\/(?:p|reel|tv)\/([^/]+)/);
+  return m ? m[1]! : null;
+}
+
+/* ---------------------------- frame builders ----------------------------- */
+function iframe(src: string, extra = "", cls = "cb-embed__frame-el"): string {
+  return (
+    `<iframe class="${cls}" src="${esc(src)}" loading="lazy" ` +
+    `frameborder="0" ${extra}></iframe>`
+  );
+}
+
+function youtubeFrame(u: URL, music: boolean): EmbedFrame | null {
+  const id = youtubeId(u);
+  if (!id) return null;
+  const src = `https://www.youtube.com/embed/${encodeURIComponent(id)}`;
+  return {
+    provider: music ? "youtubemusic" : "youtube",
+    label: music ? "YouTube Music" : "YouTube",
+    shape: "video",
+    html: iframe(
+      src,
+      `title="YouTube video player" ` +
+        `allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" ` +
+        `referrerpolicy="strict-origin-when-cross-origin" allowfullscreen`,
+    ),
+  };
+}
+
+function vimeoFrame(u: URL): EmbedFrame | null {
+  const id = vimeoId(u);
+  if (!id) return null;
+  return {
+    provider: "vimeo",
+    label: "Vimeo",
+    shape: "video",
+    html: iframe(
+      `https://player.vimeo.com/video/${encodeURIComponent(id)}`,
+      `title="Vimeo video player" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen`,
+    ),
+  };
+}
+
+function rumbleFrame(u: URL): EmbedFrame | null {
+  const id = rumbleId(u);
+  if (!id) return null;
+  return {
+    provider: "rumble",
+    label: "Rumble",
+    shape: "video",
+    html: iframe(
+      `https://rumble.com/embed/${encodeURIComponent(id)}/`,
+      `title="Rumble video player" allowfullscreen`,
+    ),
+  };
+}
+
+function twitchFrame(u: URL): EmbedFrame | null {
+  const parent = twitchParent();
+  const parts = u.pathname.split("/").filter(Boolean);
+  const h = host(u);
+  let src: string | null = null;
+
+  if (h === "clips.twitch.tv" && parts[0]) {
+    src = `https://clips.twitch.tv/embed?clip=${encodeURIComponent(parts[0])}&parent=${encodeURIComponent(parent)}`;
+  } else if (parts[0] === "videos" && parts[1]) {
+    src = `https://player.twitch.tv/?video=${encodeURIComponent(parts[1])}&parent=${encodeURIComponent(parent)}`;
+  } else if (parts[1] === "clip" && parts[2]) {
+    src = `https://clips.twitch.tv/embed?clip=${encodeURIComponent(parts[2])}&parent=${encodeURIComponent(parent)}`;
+  } else if (parts[0]) {
+    src = `https://player.twitch.tv/?channel=${encodeURIComponent(parts[0])}&parent=${encodeURIComponent(parent)}`;
+  }
+  if (!src) return null;
+  return {
+    provider: "twitch",
+    label: "Twitch",
+    shape: "video",
+    html: iframe(src, `title="Twitch player" allowfullscreen`),
+  };
+}
+
+function soundcloudFrame(u: URL): EmbedFrame {
+  // The SoundCloud widget resolves a track by its permalink; strip tracking
+  // params for the player src while the canonical Markdown keeps the original.
+  const clean = `${u.origin}${u.pathname}`;
+  const params =
+    `url=${encodeURIComponent(clean)}` +
+    `&color=%23ff5500&auto_play=false&hide_related=false` +
+    `&show_comments=true&show_user=true&show_reposts=false&show_teaser=true`;
+  return {
+    provider: "soundcloud",
+    label: "SoundCloud",
+    shape: "audio",
+    html: iframe(
+      `https://w.soundcloud.com/player/?${params}`,
+      `title="SoundCloud player" allow="autoplay" scrolling="no"`,
+    ),
+  };
+}
+
+function instagramFrame(u: URL): EmbedFrame | null {
+  const id = instagramId(u);
+  if (!id) return null;
+  const kind = u.pathname.includes("/reel/") ? "reel" : "p";
+  return {
+    provider: "instagram",
+    label: "Instagram",
+    shape: "post",
+    html: iframe(
+      `https://www.instagram.com/${kind}/${encodeURIComponent(id)}/embed`,
+      `title="Instagram post" scrolling="no" allowtransparency="true"`,
+    ),
+  };
+}
+
+function facebookFrame(u: URL): EmbedFrame {
+  const isVideo = /\/videos?\//.test(u.pathname) || u.pathname.includes("watch");
+  const base = isVideo
+    ? "https://www.facebook.com/plugins/video.php"
+    : "https://www.facebook.com/plugins/post.php";
+  const src = `${base}?href=${encodeURIComponent(u.href)}&show_text=true`;
+  return {
+    provider: "facebook",
+    label: "Facebook",
+    shape: "post",
+    html: iframe(src, `title="Facebook post" scrolling="no" allowtransparency="true" allowfullscreen`),
+  };
+}
+
+function xFrame(u: URL): EmbedFrame {
+  // X/Twitter uses widgets.js to upgrade a blockquote into a rendered tweet.
+  return {
+    provider: "x",
+    label: "X",
+    shape: "post",
+    script: "https://platform.twitter.com/widgets.js",
+    html:
+      `<blockquote class="twitter-tweet" data-dnt="true">` +
+      `<a href="${esc(u.href)}"></a></blockquote>`,
+  };
+}
+
+/* ------------------------------- dispatch -------------------------------- */
+/**
+ * Detect which provider (if any) a URL belongs to, without building markup.
+ * Useful for lightweight checks (e.g. deciding whether an external URL will
+ * render as a rich embed vs. a generic preview).
+ */
+export function detectProvider(url: string): ProviderName | null {
+  const u = parse(url);
+  if (!u) return null;
+  const h = host(u);
+  if (h === "music.youtube.com") return "youtubemusic";
+  if (h === "youtube.com" || h === "m.youtube.com" || h === "youtu.be") return "youtube";
+  if (h === "vimeo.com" || h === "player.vimeo.com") return "vimeo";
+  if (h === "rumble.com") return "rumble";
+  if (h === "twitch.tv" || h === "clips.twitch.tv" || h === "player.twitch.tv") return "twitch";
+  if (h === "x.com" || h === "twitter.com") return "x";
+  if (h === "facebook.com" || h === "fb.watch") return "facebook";
+  if (h === "instagram.com") return "instagram";
+  if (h === "soundcloud.com") return "soundcloud";
+  return null;
+}
+
+/**
+ * Build the provider-specific embed frame for a URL, or null when no provider
+ * matches or a matched provider cannot produce a usable id (caller then renders
+ * the generic link-preview fallback).
+ */
+export function buildProviderEmbed(url: string): EmbedFrame | null {
+  const u = parse(url);
+  if (!u) return null;
+  const provider = detectProvider(url);
+  switch (provider) {
+    case "youtube":
+      return youtubeFrame(u, false);
+    case "youtubemusic":
+      return youtubeFrame(u, true);
+    case "vimeo":
+      return vimeoFrame(u);
+    case "rumble":
+      return rumbleFrame(u);
+    case "twitch":
+      return twitchFrame(u);
+    case "soundcloud":
+      return soundcloudFrame(u);
+    case "instagram":
+      return instagramFrame(u);
+    case "facebook":
+      return facebookFrame(u);
+    case "x":
+      return xFrame(u);
+    default:
+      return null;
+  }
+}

diff --git a/src/lib/link-preview.ts b/src/lib/link-preview.ts
new file mode 100644
--- /dev/null
+++ b/src/lib/link-preview.ts
@@ -0,0 +1,141 @@
+/**
+ * Pure helpers for the link-preview endpoint: the response shape, an SSRF
+ * guard, and an Open Graph / Twitter Card / <title> metadata parser.
+ *
+ * Kept out of the route module because Next.js route files may only export
+ * request handlers (GET/POST/â€¦) plus a small set of config symbols; exporting
+ * these helpers there breaks the generated route type. They also unit-test more
+ * easily as a standalone module.
+ */
+import { lookup } from "node:dns/promises";
+import { isIP } from "node:net";
+import { AppError } from "@/lib/errors";
+
+export interface LinkPreview {
+  url: string;
+  title?: string;
+  description?: string;
+  image?: string;
+  siteName?: string;
+}
+
+/** Reject private, loopback, link-local, and unique-local addresses. */
+export function isPrivateAddress(ip: string): boolean {
+  const v = isIP(ip);
+  if (v === 4) {
+    const [a, b] = ip.split(".").map((n) => parseInt(n, 10));
+    if (a === 10) return true;
+    if (a === 127) return true;
+    if (a === 0) return true;
+    if (a === 169 && b === 254) return true; // link-local
+    if (a === 172 && b >= 16 && b <= 31) return true;
+    if (a === 192 && b === 168) return true;
+    return false;
+  }
+  if (v === 6) {
+    const low = ip.toLowerCase();
+    if (low === "::1" || low === "::") return true;
+    if (low.startsWith("fe80")) return true; // link-local
+    if (low.startsWith("fc") || low.startsWith("fd")) return true; // unique-local
+    // IPv4-mapped (::ffff:a.b.c.d)
+    const mapped = low.match(/::ffff:(\d+\.\d+\.\d+\.\d+)$/);
+    if (mapped) return isPrivateAddress(mapped[1]!);
+    return false;
+  }
+  return true; // unknown format -> treat as unsafe
+}
+
+/** Validate the URL and confirm its host resolves to a public address. */
+export async function assertSafeUrl(raw: string): Promise<URL> {
+  let u: URL;
+  try {
+    u = new URL(raw);
+  } catch {
+    throw new AppError("Invalid URL", 400, "INVALID_URL");
+  }
+  if (u.protocol !== "http:" && u.protocol !== "https:") {
+    throw new AppError("Only http(s) URLs are supported", 400, "INVALID_SCHEME");
+  }
+  const host = u.hostname.toLowerCase();
+  if (host === "localhost" || host.endsWith(".localhost")) {
+    throw new AppError("Refused to fetch a private host", 400, "SSRF_BLOCKED");
+  }
+  // If the host is a literal IP, check it directly; otherwise resolve it.
+  if (isIP(host)) {
+    if (isPrivateAddress(host)) {
+      throw new AppError("Refused to fetch a private address", 400, "SSRF_BLOCKED");
+    }
+    return u;
+  }
+  try {
+    const results = await lookup(host, { all: true });
+    if (results.some((r) => isPrivateAddress(r.address))) {
+      throw new AppError("Refused to fetch a private address", 400, "SSRF_BLOCKED");
+    }
+  } catch (e) {
+    if (e instanceof AppError) throw e;
+    throw new AppError("Could not resolve host", 400, "DNS_ERROR");
+  }
+  return u;
+}
+
+/** Decode a handful of common HTML entities found in meta content. */
+export function decodeEntities(s: string): string {
+  return s
+    .replace(/&amp;/g, "&")
+    .replace(/&lt;/g, "<")
+    .replace(/&gt;/g, ">")
+    .replace(/&quot;/g, '"')
+    .replace(/&#39;/g, "'")
+    .replace(/&#x27;/gi, "'")
+    .replace(/&nbsp;/g, " ");
+}
+
+/** Read a `<meta>` content value for any of the given property/name keys. */
+function metaContent(html: string, keys: string[]): string | undefined {
+  for (const key of keys) {
+    // Match <meta ... (property|name)="key" ... content="...">  (either order)
+    const re = new RegExp(`<meta[^>]+(?:property|name)\\s*=\\s*["']${key}["'][^>]*>`, "i");
+    const tag = re.exec(html)?.[0];
+    if (!tag) continue;
+    const content = /content\s*=\s*["']([^"']*)["']/i.exec(tag)?.[1];
+    if (content) return decodeEntities(content.trim());
+  }
+  return undefined;
+}
+
+/** Extract preview metadata from an HTML document string. */
+export function parseHtmlMeta(html: string, url: string): LinkPreview {
+  const title =
+    metaContent(html, ["og:title", "twitter:title"]) ??
+    /<title[^>]*>([^<]*)<\/title>/i.exec(html)?.[1]?.trim();
+  const description = metaContent(html, [
+    "og:description",
+    "twitter:description",
+    "description",
+  ]);
+  let image = metaContent(html, [
+    "og:image:secure_url",
+    "og:image",
+    "twitter:image",
+    "twitter:image:src",
+  ]);
+  const siteName = metaContent(html, ["og:site_name"]);
+
+  // Resolve a relative image URL against the page URL.
+  if (image && !/^https?:\/\//i.test(image)) {
+    try {
+      image = new URL(image, url).href;
+    } catch {
+      image = undefined;
+    }
+  }
+
+  return {
+    url,
+    title: title ? decodeEntities(title) : undefined,
+    description,
+    image,
+    siteName,
+  };
+}

diff --git a/src/lib/link-embeds.ts b/src/lib/link-embeds.ts
new file mode 100644
--- /dev/null
+++ b/src/lib/link-embeds.ts
@@ -0,0 +1,114 @@
+/**
+ * Client-side hydration for URL embeds.
+ *
+ * Two responsibilities, both idempotent and safe to call after every (re)render
+ * of a surface that may contain embeds (WYSIWYG rich body, Markdown preview, and
+ * the rendered article body):
+ *
+ *  1. Generic link-preview cards (`[data-link-hydrate="1"]`) are enriched by
+ *     fetching Open Graph metadata from `/api/link-preview` and filling in the
+ *     real title / description / thumbnail. The base HTML already shows the host
+ *     + a Visit-site button, so hydration is purely additive and network
+ *     failures leave a usable card.
+ *
+ *  2. Script-driven providers (currently X via `widgets.js`) declare their
+ *     external script through `data-embed-script`. Each unique script is
+ *     injected at most once; after load, the provider's widget factory is asked
+ *     to upgrade any blockquotes in the root.
+ */
+import { api } from "@/lib/api-client";
+import type { LinkPreview } from "@/lib/link-preview";
+
+/** Scripts already injected (module-scoped so it survives re-renders). */
+const loadedScripts = new Set<string>();
+
+interface TwitterWidgets {
+  widgets?: { load?: (el?: HTMLElement) => void };
+}
+
+function loadScriptOnce(src: string): Promise<void> {
+  if (loadedScripts.has(src)) return Promise.resolve();
+  loadedScripts.add(src);
+  return new Promise((resolve) => {
+    const s = document.createElement("script");
+    s.src = src;
+    s.async = true;
+    s.charset = "utf-8";
+    s.addEventListener("load", () => resolve());
+    s.addEventListener("error", () => resolve());
+    document.head.appendChild(s);
+  });
+}
+
+function setText(root: ParentNode, selector: string, value: string): void {
+  const el = root.querySelector<HTMLElement>(selector);
+  if (el) el.textContent = value;
+}
+
+/** Enrich a single generic preview card in place. */
+async function hydrateCard(card: HTMLElement): Promise<void> {
+  if (card.getAttribute("data-link-hydrated") === "1") return;
+  const url = card.getAttribute("data-src");
+  if (!url) return;
+  // Mark first to avoid duplicate in-flight requests across rapid re-renders.
+  card.setAttribute("data-link-hydrated", "1");
+
+  let meta: LinkPreview;
+  try {
+    meta = await api.get<LinkPreview>(`/api/link-preview?url=${encodeURIComponent(url)}`);
+  } catch {
+    return; // Leave the base card (host + Visit site) untouched.
+  }
+
+  if (meta.title) setText(card, ".cb-embed__title", meta.title);
+  if (meta.siteName) setText(card, ".cb-embed__site", meta.siteName);
+  if (meta.description) {
+    let desc = card.querySelector<HTMLElement>(".cb-embed__desc");
+    if (!desc) {
+      desc = document.createElement("span");
+      desc.className = "cb-embed__desc";
+      card.querySelector(".cb-embed__url")?.before(desc);
+    }
+    desc.textContent = meta.description;
+  }
+  if (meta.image) {
+    const existing = card.querySelector<HTMLImageElement>("img.cb-embed__thumb");
+    if (existing) {
+      existing.src = meta.image;
+    } else {
+      const placeholder = card.querySelector(".cb-embed__thumb--empty");
+      const img = document.createElement("img");
+      img.className = "cb-embed__thumb";
+      img.src = meta.image;
+      img.alt = "";
+      img.loading = "lazy";
+      placeholder?.replaceWith(img);
+    }
+  }
+}
+
+/**
+ * Hydrate every URL embed inside `root`. Enriches generic preview cards and
+ * loads any provider scripts they declare. Idempotent.
+ */
+export function hydrateLinkEmbeds(root: HTMLElement | null | undefined): void {
+  if (!root || typeof window === "undefined") return;
+
+  // 1. Generic preview cards.
+  root
+    .querySelectorAll<HTMLElement>('[data-link-hydrate="1"]:not([data-link-hydrated="1"])')
+    .forEach((card) => void hydrateCard(card));
+
+  // 2. Script-driven providers (X / Twitter, etc.).
+  const scripts = new Set<string>();
+  root.querySelectorAll<HTMLElement>("[data-embed-script]").forEach((el) => {
+    const src = el.getAttribute("data-embed-script");
+    if (src) scripts.add(src);
+  });
+  scripts.forEach((src) => {
+    void loadScriptOnce(src).then(() => {
+      const tw = (window as unknown as { twttr?: TwitterWidgets }).twttr;
+      tw?.widgets?.load?.(root);
+    });
+  });
+}

diff --git a/src/lib/code-block-render.ts b/src/lib/code-block-render.ts
new file mode 100644
--- /dev/null
+++ b/src/lib/code-block-render.ts
@@ -0,0 +1,156 @@
+/**
+ * Shared code-block rendering utilities used by both the WYSIWYG editor
+ * (client-side live preview) and the Grok translation pipeline (server-side
+ * markdownâ†’HTML conversion). Extracting these here guarantees translated
+ * articles produce the same `.cb-code` wrapper structure as the editor, so
+ * collapse/expand toggles, preview line limiting, and size constraints all
+ * work identically regardless of whether the HTML was authored or translated.
+ */
+import { parseSizeSpec, sizeSpecToString, type EmbedSize } from "@/lib/embeds";
+
+export interface CodeBlockInfo {
+  language: string;
+  previewLines?: number;
+  collapseKind: "preview" | "collapse";
+  size: EmbedSize;
+}
+
+/**
+ * Parse a code block info string into its language, optional preview/collapse
+ * line count, and optional size. Tokens after the language can appear in any
+ * order, e.g. "ts small preview=5", "python width=300 collapse=8".
+ */
+export function parseCodeBlockInfo(info: string): CodeBlockInfo {
+  const trimmed = info.trim();
+  const tokens = trimmed.split(/\s+/).filter(Boolean);
+  const language = tokens[0] || "plaintext";
+
+  let previewLines: number | undefined;
+  let collapseKind: "preview" | "collapse" = "preview";
+  const pc = trimmed.match(/\b(preview|collapse)=(\d+)/i);
+  if (pc) {
+    collapseKind = pc[1].toLowerCase() as "preview" | "collapse";
+    previewLines = parseInt(pc[2], 10);
+  }
+
+  const sizeSpec = tokens
+    .slice(1)
+    .filter((t) => !/^(preview|collapse)=\d+$/i.test(t))
+    .join(" ")
+    .trim();
+  const size: EmbedSize = sizeSpec ? parseSizeSpec(sizeSpec) : { type: "none" };
+
+  return { language, previewLines, collapseKind, size };
+}
+
+/** Escape raw code for safe insertion when highlight.js hasn't highlighted it. */
+export function escapeCode(s: string): string {
+  return s
+    .replace(/&/g, "&amp;")
+    .replace(/</g, "&lt;")
+    .replace(/>/g, "&gt;");
+}
+
+const LANG_LABELS: Record<string, string> = {
+  javascript: "JavaScript",
+  typescript: "TypeScript",
+  tsx: "TSX",
+  jsx: "JSX",
+  python: "Python",
+  ruby: "Ruby",
+  bash: "Bash",
+  shell: "Shell",
+  json: "JSON",
+  yaml: "YAML",
+  xml: "HTML",
+  html: "HTML",
+  css: "CSS",
+  scss: "SCSS",
+  markdown: "Markdown",
+  cpp: "C++",
+  csharp: "C#",
+  fsharp: "F#",
+  go: "Go",
+  rust: "Rust",
+  kotlin: "Kotlin",
+  swift: "Swift",
+  java: "Java",
+  php: "PHP",
+  sql: "SQL",
+  d: "D",
+  plaintext: "Text",
+};
+
+export function langLabel(lang: string): string {
+  const key = (lang || "plaintext").toLowerCase();
+  return LANG_LABELS[key] || lang.toUpperCase();
+}
+
+const CODE_ICON_SVG =
+  "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"16 18 22 12 16 6\"></polyline><polyline points=\"8 6 2 12 8 18\"></polyline></svg>";
+
+const CARET_SVG =
+  "<svg class=\"cb-code__caret\" xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"6 9 12 15 18 9\"></polyline></svg>";
+
+function codeSizeStyle(size: EmbedSize): { cls: string; style: string } {
+  switch (size.type) {
+    case "pixels":
+      return { cls: "cb-code--size-pixels", style: `max-width:${size.width}px;` };
+    case "percent":
+      return { cls: "cb-code--size-percent", style: `width:${size.width}%;` };
+    case "preset":
+      return { cls: `cb-code--size-${size.size}`, style: "" };
+    default:
+      return { cls: "", style: "" };
+  }
+}
+
+/**
+ * Build the rendered HTML for a code block. Every block gets a header showing a
+ * code icon + the language name. When a preview/collapse count is given and the
+ * code is longer than it, a bottom toggle bar is appended and the block starts
+ * collapsed; the collapsed height is N lines expressed in `em` (font-size
+ * aware) via the `--cb-preview-lines` custom property. Optional sizes constrain
+ * the block width.
+ */
+export function buildCodeBlock(
+  bodyHtml: string,
+  lang: string,
+  totalLines: number,
+  info: Pick<CodeBlockInfo, "previewLines" | "collapseKind" | "size">,
+  highlighted = false,
+): string {
+  const { previewLines, collapseKind, size } = info;
+  const codeClass = `language-${lang}${highlighted ? " hljs" : ""}`;
+  const collapsible = !!previewLines && totalLines > previewLines;
+
+  const { cls: sizeCls, style: sizeStyle } = codeSizeStyle(size);
+  const sizeSpec = size.type !== "none" ? sizeSpecToString(size) : "";
+
+  const header =
+    `<div class="cb-code__header" contenteditable="false">` +
+    `<span class="cb-code__lang-icon">${CODE_ICON_SVG}</span>` +
+    `<span class="cb-code__lang">${langLabel(lang)}</span>` +
+    `</div>`;
+
+  const pre = `<pre class="cb-code__pre"><code class="${codeClass}">${bodyHtml}</code></pre>`;
+
+  const toggle = collapsible
+    ? `<button class="cb-code__toggle" type="button" contenteditable="false" ` +
+      `aria-label="Expand code" aria-expanded="false">${CARET_SVG}</button>`
+    : "";
+
+  const wrapperClass = `cb-code${collapsible ? " collapsed" : ""}${sizeCls ? ` ${sizeCls}` : ""}`;
+
+  const styleParts: string[] = [];
+  if (sizeStyle) styleParts.push(sizeStyle);
+  if (collapsible) styleParts.push(`--cb-preview-lines:${previewLines};`);
+  const styleAttr = styleParts.length ? ` style="${styleParts.join(" ")}"` : "";
+
+  const dataAttrs =
+    `data-lines="${totalLines}"` +
+    (collapsible ? ` data-preview-lines="${previewLines}" data-collapse-kind="${collapseKind}"` : "") +
+    (sizeSpec ? ` data-size="${sizeSpec}"` : "");
+
+  return `<div class="${wrapperClass}" ${dataAttrs}${styleAttr}>${header}${pre}${toggle}</div>`;
+}

diff --git a/src/lib/highlight.ts b/src/lib/highlight.ts
new file mode 100644
--- /dev/null
+++ b/src/lib/highlight.ts
@@ -0,0 +1,278 @@
+/**
+ * Shared highlight.js utilities for syntax highlighting.
+ *
+ * Used by both the WYSIWYG editor (live markdown preview) and the rendered
+ * article body in feed cards. The full highlight.js build is loaded once
+ * (registering the ~37 "common" languages), and any additional language is
+ * dynamically imported + registered on demand, giving effectively full
+ * highlight.js language coverage without bloating the initial bundle.
+ *
+ * The active syntax theme stylesheet is chosen by the `data-code-theme`
+ * attribute on <html> (set server-side from the CODE_THEME env var via
+ * resolvedCodeTheme()), e.g. "github-dark", "monokai", "nord".
+ */
+
+let hljsModule: any = null;
+let hljsInitialized = false;
+let loadedCssTheme: string | null = null;
+const loadedLanguages = new Set<string>();
+
+/** Aliases mapping common shorthand language ids to highlight.js module names. */
+const LANG_ALIASES: Record<string, string> = {
+  js: "javascript",
+  jsx: "javascript",
+  ts: "typescript",
+  tsx: "typescript",
+  py: "python",
+  rb: "ruby",
+  "c++": "cpp",
+  "c#": "csharp",
+  cs: "csharp",
+  fs: "fsharp",
+  vb: "vbnet",
+  sh: "bash",
+  shell: "bash",
+  zsh: "bash",
+  yml: "yaml",
+  md: "markdown",
+  htm: "xml",
+  html: "xml",
+  kt: "kotlin",
+  rs: "rust",
+  golang: "go",
+  ps: "powershell",
+  ps1: "powershell",
+  text: "plaintext",
+  txt: "plaintext",
+};
+
+/** Normalise a language id to its canonical highlight.js module name. */
+function canonicalLang(language: string): string {
+  const lower = (language || "").toLowerCase();
+  return LANG_ALIASES[lower] || lower;
+}
+
+export async function initHighlightJs() {
+  if (hljsInitialized) return;
+
+  try {
+    const hljsImport = await import("highlight.js");
+    hljsModule = hljsImport.default || hljsImport;
+    hljsInitialized = true;
+  } catch (error) {
+    console.error("Failed to initialize highlight.js:", error);
+  }
+}
+
+/** The highlight.js stylesheet name configured on <html data-code-theme>. */
+function currentCodeTheme(): string {
+  if (typeof document !== "undefined") {
+    const attr = document.documentElement.getAttribute("data-code-theme");
+    if (attr) return attr;
+    // Fallback: dark site theme -> github-dark, else github.
+    const siteTheme = document.documentElement.getAttribute("data-theme");
+    return siteTheme === "hacker" ? "github-dark" : "github";
+  }
+  return "github-dark";
+}
+
+/**
+ * Load the configured highlight.js theme stylesheet (once). If the theme
+ * changes between calls, the previous stylesheet is swapped out so the page
+ * never carries two competing hljs palettes.
+ */
+export async function loadHighlightJsCss() {
+  if (typeof document === "undefined") return;
+
+  const theme = currentCodeTheme();
+  if (loadedCssTheme === theme) return;
+
+  const href = `/api/highlightjs/styles/${theme}.css`;
+  const linkId = "hljs-theme-css";
+
+  await new Promise<void>((resolve) => {
+    let link = document.getElementById(linkId) as HTMLLinkElement | null;
+    if (!link) {
+      link = document.createElement("link");
+      link.id = linkId;
+      link.rel = "stylesheet";
+      document.head.appendChild(link);
+    }
+    link.onload = () => resolve();
+    link.onerror = () => {
+      console.error(`Failed to load highlight.js CSS: ${href}`);
+      resolve();
+    };
+    link.href = href;
+  });
+
+  loadedCssTheme = theme;
+}
+
+export async function loadHighlightJsLanguage(language: string): Promise<void> {
+  const hljsLang = canonicalLang(language);
+  if (loadedLanguages.has(hljsLang)) return;
+
+  // Already registered by the full build (common language) â€” nothing to do.
+  if (hljsModule && hljsModule.getLanguage(hljsLang)) {
+    loadedLanguages.add(hljsLang);
+    return;
+  }
+
+  try {
+    // Import without .js extension as per highlight.js package exports, then
+    // register so uncommon languages (outside the common set) highlight too.
+    const mod = await import(`highlight.js/lib/languages/${hljsLang}`);
+    const def = mod.default ?? mod;
+    if (hljsModule && typeof def === "function") {
+      hljsModule.registerLanguage(hljsLang, def);
+    }
+    loadedLanguages.add(hljsLang);
+  } catch (error) {
+    console.warn(`Failed to load highlight.js language: ${language}`, error);
+  }
+}
+
+export function hasCodeBlocks(html: string): boolean {
+  return /<pre[^>]*><code/.test(html) || /class="[^"]*language-/.test(html);
+}
+
+export function extractLanguagesFromHtml(html: string): string[] {
+  const regex = /language-([\w+#-]+)/g;
+  const languages = new Set<string>();
+  let match;
+  while ((match = regex.exec(html)) !== null) {
+    languages.add(match[1]);
+  }
+  return Array.from(languages);
+}
+
+export async function ensureHighlightJsReady(html: string): Promise<void> {
+  if (!hasCodeBlocks(html)) return;
+
+  await Promise.all([initHighlightJs(), loadHighlightJsCss()]);
+  const languages = extractLanguagesFromHtml(html);
+  await Promise.all(languages.map((lang) => loadHighlightJsLanguage(lang)));
+}
+
+export function highlightCodeInElement(element: HTMLElement): void {
+  if (!hljsModule) return;
+
+  const codeBlocks = element.querySelectorAll("pre code");
+  codeBlocks.forEach((block) => {
+    if (block.classList.contains("hljs")) return; // already highlighted
+    const langMatch = block.className.match(/language-([\w+#-]+)/);
+    const lang = canonicalLang(langMatch ? langMatch[1] : "plaintext");
+
+    try {
+      const text = block.textContent || "";
+      if (lang !== "plaintext" && hljsModule.getLanguage(lang)) {
+        block.innerHTML = hljsModule.highlight(text, { language: lang }).value;
+        block.classList.add("hljs");
+      } else if (lang === "plaintext") {
+        block.classList.add("hljs");
+      }
+      // If the language isn't available yet, don't add "hljs" â€” allows a
+      // subsequent call (after the language is loaded) to retry highlighting.
+    } catch (error) {
+      console.error("Failed to highlight code block:", error);
+    }
+  });
+}
+
+export interface CodeToggleOptions {
+  /**
+   * Return whether the collapsible block at `index` (its position among all
+   * `.cb-code` wrappers in the element) should currently be expanded. Used to
+   * restore state after the body HTML is re-injected by React.
+   */
+  isExpanded?: (index: number) => boolean;
+  /** Notified whenever the user toggles a block, so callers can persist state. */
+  onToggle?: (index: number, expanded: boolean) => void;
+}
+
+/** Apply the expanded/collapsed classes + ARIA to a wrapper/button pair. */
+function applyToggleState(wrap: Element, btn: Element, expanded: boolean): void {
+  wrap.classList.toggle("expanded", expanded);
+  wrap.classList.toggle("collapsed", !expanded);
+  btn.setAttribute("aria-label", expanded ? "Collapse code" : "Expand code");
+  btn.setAttribute("aria-expanded", expanded ? "true" : "false");
+}
+
+// Latest toggle options per container. Keyed by the (stable, React-owned)
+// `.article-body` element so the single delegated listener below always reads
+// fresh callbacks, even after the options object identity changes on re-render.
+const containerOptions = new WeakMap<HTMLElement, CodeToggleOptions>();
+
+/**
+ * Single delegated click handler shared by every wired container.
+ *
+ * Using delegation (one listener on the stable container) instead of per-button
+ * listeners is the crux of the fix: the article body is re-injected via
+ * `dangerouslySetInnerHTML` and its code is re-written in place by
+ * `highlightCodeInElement`, both of which replace inner nodes. A listener bound
+ * to a specific button would be lost (or stranded on a detached node) whenever
+ * that happens â€” the bug seen on feed/scroll-loaded and freshly edited cards.
+ * The container node, by contrast, survives all inner mutations, so one
+ * listener keeps working for the component's whole lifetime.
+ */
+function handleContainerClick(this: HTMLElement, ev: Event): void {
+  const target = ev.target as HTMLElement | null;
+  const btn = target?.closest<HTMLElement>(".cb-code__toggle");
+  if (!btn || !this.contains(btn)) return;
+  const wrap = btn.closest<HTMLElement>(".cb-code");
+  if (!wrap) return;
+
+  // Recompute the block index at click time so it stays correct regardless of
+  // how the body was last re-injected/re-highlighted.
+  const wraps = Array.from(this.querySelectorAll<HTMLElement>(".cb-code"));
+  const index = wraps.indexOf(wrap);
+
+  const expanded = !wrap.classList.contains("expanded");
+  applyToggleState(wrap, btn, expanded);
+  containerOptions.get(this)?.onToggle?.(index, expanded);
+}
+
+/**
+ * Wire the collapse/expand toggle bars for code blocks within a container.
+ *
+ * Safe and cheap to call after every render, after highlighting, and after the
+ * body HTML is re-injected â€” it (1) refreshes the stored options, (2) restores
+ * each block's persisted expanded/collapsed state, and (3) ensures exactly one
+ * delegated click listener is attached to the container. Adding the same
+ * function reference again is a DOM no-op, so wiring is fully idempotent without
+ * any per-node bookkeeping.
+ *
+ * When `options.isExpanded` is supplied, persisted state is re-applied on every
+ * call so a block stays expanded across re-renders that re-inject the body
+ * (otherwise it would visibly flicker back to collapsed after an edit/refresh).
+ */
+export function wireCodeBlockToggles(
+  element: HTMLElement,
+  options: CodeToggleOptions = {},
+): void {
+  // Always store the latest callbacks for the delegated handler to read.
+  containerOptions.set(element, options);
+
+  // Index across all `.cb-code` wrappers (collapsible or not) so the index is a
+  // stable key for the persisted-state callbacks regardless of block count.
+  const wraps = element.querySelectorAll<HTMLElement>(".cb-code");
+  wraps.forEach((wrap, index) => {
+    const btn = wrap.querySelector<HTMLElement>(".cb-code__toggle");
+    if (!btn) return; // non-collapsible block: nothing to restore
+
+    // Strip any stale flag that leaked into stored HTML from older saves so it
+    // never confuses other logic or re-serializes.
+    if (btn.dataset.wired) delete btn.dataset.wired;
+
+    // Restore persisted state on every (re)wire so it survives re-injection.
+    if (options.isExpanded) applyToggleState(wrap, btn, options.isExpanded(index));
+  });
+
+  // Idempotent: re-adding the identical handler reference is ignored by the DOM.
+  element.addEventListener("click", handleContainerClick);
+}
+
+export function getHljsModule() {
+  return hljsModule;
+}

diff --git a/src/lib/grok.ts b/src/lib/grok.ts
new file mode 100644
--- /dev/null
+++ b/src/lib/grok.ts
@@ -0,0 +1,602 @@
+/**
+ * Grok (x.ai) translation coordinator.
+ *
+ * Article bodies are stored as HTML but translated as Markdown: Markdown is the
+ * reduced, element-addressable representation that the existing WYSIWYG round-
+ * trip (turndown / marked) already preserves losslessly, so the model translates
+ * prose while code fences, embeds (`@[label](url)`), image/link targets, and the
+ * `--END PREVIEW--` marker survive intact.
+ *
+ * Resolution is a two-tier read-through (cache -> database -> Grok) mirroring
+ * lib/cache.ts. Translations are a pure function of an article revision, so they
+ * are safely memoizable but MUST be evicted when the source changes (handled in
+ * lib/articles.ts on update/delete).
+ */
+import { marked } from "marked";
+import TurndownService from "turndown";
+import { env, grokConfigured } from "@/lib/env";
+import { getPrisma } from "@/lib/prisma";
+import { remember, invalidate, invalidateByPrefix, get, set } from "@/lib/cache";
+import {
+  registerEmbedExtension,
+  addEmbedTurndownRule,
+} from "@/lib/embeds";
+import {
+  parseCodeBlockInfo,
+  buildCodeBlock,
+  escapeCode,
+} from "@/lib/code-block-render";
+import {
+  initHighlightJs,
+  loadHighlightJsLanguage,
+  getHljsModule,
+} from "@/lib/highlight";
+import { localeLabel, type Locale } from "@/lib/i18n";
+import { createLogger } from "@/lib/logger";
+
+export { grokConfigured };
+
+const log = createLogger("grok");
+
+/**
+ * Get the current UTC date as a string (YYYY-MM-DD) for rate limit key.
+ */
+function getUtcDateKey(): string {
+  const now = new Date();
+  return now.toISOString().split('T')[0]; // YYYY-MM-DD
+}
+
+/**
+ * Check and increment the global Grok API rate limit.
+ * Throws an error if the limit is exceeded.
+ */
+async function checkGlobalRateLimit(): Promise<void> {
+  const dateKey = getUtcDateKey();
+  const cacheKey = `grok:rate-limit:${dateKey}`;
+
+  const current = await get<number>("grok-rate-limit", cacheKey);
+  const count = current ?? 0;
+
+  if (count >= env.GROK_RATE_LIMIT_DAY) {
+    throw new Error(`Grok API rate limit exceeded: maximum ${env.GROK_RATE_LIMIT_DAY} calls per day`);
+  }
+
+  // Increment the counter
+  await set("grok-rate-limit", cacheKey, count + 1, 86400); // TTL 24 hours
+}
+
+// Enable the `@[name](url)` / sized-image / preview-separator markdown grammar
+// on the shared marked instance (idempotent).
+registerEmbedExtension(marked);
+
+// Configure marked to produce the same `.cb-code` wrapper as the WYSIWYG editor
+// so translated articles get collapse/expand toggles, preview line limiting, and
+// size constraints â€” not bare <pre><code> that would overflow the article card.
+// When highlight.js is initialized (via ensureHljsForMarkdown before rendering),
+// code blocks receive proper hljs token spans and the `hljs` class, matching the
+// WYSIWYG editor's output so the client-side highlightCodeInElement pass skips
+// them (its idempotency guard checks classList.contains("hljs")).
+marked.use({
+  renderer: {
+    code(code: string, language: string | undefined) {
+      const { language: lang, previewLines, collapseKind, size } = parseCodeBlockInfo(language || "");
+      const totalLines = code.split("\n").length;
+      const hljs = getHljsModule();
+
+      if (!hljs) {
+        return buildCodeBlock(escapeCode(code), lang, totalLines, { previewLines, collapseKind, size }, false);
+      }
+
+      const validLang = lang && hljs.getLanguage(lang) ? lang : "plaintext";
+      try {
+        const highlighted = hljs.highlight(code, { language: validLang }).value;
+        return buildCodeBlock(highlighted, validLang, totalLines, { previewLines, collapseKind, size }, true);
+      } catch {
+        return buildCodeBlock(escapeCode(code), validLang, totalLines, { previewLines, collapseKind, size }, false);
+      }
+    },
+  },
+});
+
+/** Reduce article HTML to canonical, translation-safe Markdown. */
+export function htmlToTranslatableMarkdown(html: string): string {
+  const turndown = new TurndownService({
+    headingStyle: "atx",
+    codeBlockStyle: "fenced",
+  });
+  addEmbedTurndownRule(turndown);
+  return turndown.turndown(html);
+}
+
+/** Expand (translated) Markdown back into article-body HTML. */
+export function markdownToHtml(markdown: string): string {
+  return marked.parse(markdown) as string;
+}
+
+/** Extract language identifiers from fenced code blocks in Markdown. */
+function extractLanguagesFromMarkdown(markdown: string): string[] {
+  const regex = /^```([^\s]+)/gm;
+  const languages = new Set<string>();
+  let match;
+  while ((match = regex.exec(markdown)) !== null) {
+    languages.add(match[1]);
+  }
+  return Array.from(languages);
+}
+
+/**
+ * Initialize highlight.js and register all languages referenced by fenced code
+ * blocks in the Markdown. Must be called before `markdownToHtml` so the marked
+ * renderer can produce highlighted HTML with proper `hljs` class names and token
+ * spans, matching the WYSIWYG editor's output.
+ */
+async function ensureHljsForMarkdown(markdown: string): Promise<void> {
+  if (!/```[\s\S]*?```/.test(markdown)) return;
+  await initHighlightJs();
+  const languages = extractLanguagesFromMarkdown(markdown);
+  await Promise.all(languages.map((lang) => loadHighlightJsLanguage(lang)));
+}
+
+/**
+ * Extract fenced code blocks from Markdown, replacing each with a short
+ * placeholder comment (`<!--CB0-->`, `<!--CB1-->`, â€¦). This prevents the code
+ * contents from being sent to the translation model (saving tokens and avoiding
+ * accidental alteration), while keeping the structural position so the block
+ * can be restored verbatim after translation.
+ *
+ * Handles fences of any length (3+ backticks). Turndown uses 4+ backtick
+ * fences when code content contains ``` lines, so we must only close on a
+ * fence with >= backticks than the opening fence.
+ *
+ * Returns the stripped Markdown and an ordered array of the original code
+ * blocks (including their ``` fences and language tags).
+ */
+export function extractCodeBlocks(
+  markdown: string,
+): { markdown: string; codeBlocks: string[] } {
+  const codeBlocks: string[] = [];
+  const lines = markdown.split("\n");
+  const out: string[] = [];
+  let i = 0;
+
+  while (i < lines.length) {
+    const line = lines[i]!;
+    const openMatch = line.trim().match(/^(`{3,})/);
+    if (openMatch) {
+      // Start of a fenced code block â€” collect until a closing fence with
+      // at least as many backticks as the opening fence.
+      const fenceLen = openMatch[1].length;
+      const block: string[] = [line];
+      i++;
+      while (i < lines.length) {
+        const closeMatch = lines[i]!.trim().match(/^(`{3,})$/);
+        if (closeMatch && closeMatch[1].length >= fenceLen) break;
+        block.push(lines[i]!);
+        i++;
+      }
+      // Include the closing fence if present
+      if (i < lines.length) {
+        block.push(lines[i]!);
+        i++;
+      }
+      const placeholder = `<!--CB${codeBlocks.length}-->`;
+      codeBlocks.push(block.join("\n"));
+      out.push(placeholder);
+    } else {
+      out.push(line);
+      i++;
+    }
+  }
+
+  return { markdown: out.join("\n"), codeBlocks };
+}
+
+/**
+ * Restore code block placeholders (`<!--CB0-->`, â€¦) back to the original
+ * fenced code blocks. Inverse of `extractCodeBlocks`.
+ */
+export function restoreCodeBlocks(
+  markdown: string,
+  codeBlocks: string[],
+): string {
+  return markdown.replace(/<!--CB(\d+)-->/g, (_, idx: string) => {
+    const i = parseInt(idx, 10);
+    return codeBlocks[i] ?? `<!--CB${idx}-->`;
+  });
+}
+
+/**
+ * Split Markdown into chunks for translation, each no larger than `maxChars`.
+ * Splitting happens on line boundaries only â€” never through a line, and never
+ * through a fenced code block. If a single code block exceeds `maxChars`, it
+ * gets its own chunk (oversized but intact).
+ *
+ * Handles fences of any length (3+ backticks). Turndown uses 4+ backtick
+ * fences when code content contains ``` lines, so we must only close on a
+ * fence with >= backticks than the opening fence.
+ *
+ * Returns an array of Markdown strings, each ending with a newline.
+ */
+export function chunkMarkdown(markdown: string, maxChars: number): string[] {
+  if (markdown.length === 0) return [];
+
+  const lines = markdown.split("\n");
+  // If the input ends with \n, split produces a trailing "" â€” remove it
+  // since flush already adds \n to each chunk.
+  if (lines[lines.length - 1] === "") lines.pop();
+
+  const chunks: string[] = [];
+  let current: string[] = [];
+  let currentLen = 0;
+  let inCodeBlock = false;
+  let codeFenceLen = 0;
+
+  const flush = () => {
+    if (current.length > 0) {
+      chunks.push(current.join("\n") + "\n");
+      current = [];
+      currentLen = 0;
+    }
+  };
+
+  for (const line of lines) {
+    const lineLen = line.length + 1; // +1 for the \n
+    const fenceMatch = line.trim().match(/^(`{3,})/);
+
+    if (fenceMatch) {
+      const fenceLen = fenceMatch[1].length;
+      if (!inCodeBlock) {
+        // Opening fence
+        inCodeBlock = true;
+        codeFenceLen = fenceLen;
+        current.push(line);
+        currentLen += lineLen;
+        continue;
+      } else if (fenceLen >= codeFenceLen) {
+        // Closing fence (must have >= backticks than opening)
+        inCodeBlock = false;
+        codeFenceLen = 0;
+        current.push(line);
+        currentLen += lineLen;
+        // Flush after the code block closes if we're over the limit
+        if (currentLen >= maxChars) flush();
+        continue;
+      }
+      // Inner fence with fewer backticks â€” treat as content, fall through
+    }
+
+    if (inCodeBlock) {
+      current.push(line);
+      currentLen += lineLen;
+      continue;
+    }
+
+    // Outside code blocks: flush before starting a new chunk if this line
+    // would push us over the limit.
+    if (currentLen > 0 && currentLen + lineLen > maxChars) {
+      flush();
+    }
+
+    current.push(line);
+    currentLen += lineLen;
+  }
+
+  flush();
+  return chunks;
+}
+
+/**
+ * Substitute the supported placeholders in a prompt template. Unknown
+ * placeholders are left untouched so custom templates fail visibly rather than
+ * silently dropping text.
+ */
+export function fillPromptTemplate(
+  template: string,
+  vars: {
+    sourceLocale: string;
+    targetLocale: string;
+    sourceLang: string;
+    targetLang: string;
+    content: string;
+  },
+): string {
+  return template
+    .replaceAll("{sourceLocale}", vars.sourceLocale)
+    .replaceAll("{targetLocale}", vars.targetLocale)
+    .replaceAll("{sourceLang}", vars.sourceLang)
+    .replaceAll("{targetLang}", vars.targetLang)
+    .replaceAll("{content}", vars.content);
+}
+
+function promptVars(content: string, sourceLocale: string, targetLocale: string) {
+  return {
+    sourceLocale,
+    targetLocale,
+    sourceLang: localeLabel(sourceLocale),
+    targetLang: localeLabel(targetLocale),
+    content,
+  };
+}
+
+export function buildTranslationPrompt(
+  contentMarkdown: string,
+  sourceLocale: string,
+  targetLocale: string,
+): string {
+  return fillPromptTemplate(
+    env.GROK_TRANSLATION_PROMPT,
+    promptVars(contentMarkdown, sourceLocale, targetLocale),
+  );
+}
+
+export function buildTitlePrompt(
+  title: string,
+  sourceLocale: string,
+  targetLocale: string,
+): string {
+  return fillPromptTemplate(
+    env.GROK_TITLE_PROMPT,
+    promptVars(title, sourceLocale, targetLocale),
+  );
+}
+
+/** A function that maps a prompt to Grok's completion text. Injectable for tests. */
+export type CompletionFn = (prompt: string) => Promise<string>;
+
+/**
+ * Call the Grok chat-completions endpoint and return the message content.
+ * Uses the OpenAI-compatible schema exposed by the x.ai API.
+ *
+ * Enforces a global rate limit (GROK_RATE_LIMIT_DAY) before making the API call.
+ */
+export const callGrok: CompletionFn = async (prompt: string): Promise<string> => {
+  if (!grokConfigured()) throw new Error("Grok is not configured");
+
+  // Check global rate limit before making the API call
+  await checkGlobalRateLimit();
+
+  const url = `${env.GROK_BASE_URL.replace(/\/$/, "")}/chat/completions`;
+  const res = await fetch(url, {
+    method: "POST",
+    headers: {
+      "Content-Type": "application/json",
+      Authorization: `Bearer ${env.GROK_API_KEY}`,
+    },
+    body: JSON.stringify({
+      model: env.GROK_MODEL,
+      temperature: env.GROK_TEMPERATURE,
+      messages: [{ role: "user", content: prompt }],
+    }),
+  });
+  if (!res.ok) {
+    // Surface the upstream detail so misconfiguration is diagnosable. A 400 is
+    // most commonly an invalid/inaccessible GROK_MODEL (e.g. the deprecated
+    // "grok-2-latest"); 401/403 indicate a bad/expired GROK_API_KEY.
+    const detail = await res.text().catch(() => "");
+    const hint =
+      res.status === 400
+        ? " (check GROK_MODEL â€” 'grok-2-latest' is deprecated; try 'grok-4.3')"
+        : res.status === 401 || res.status === 403
+          ? " (check GROK_API_KEY)"
+          : "";
+    throw new Error(
+      `Grok API error ${res.status} ${res.statusText}${hint}${detail ? `: ${detail.slice(0, 500)}` : ""}`,
+    );
+  }
+  const data = (await res.json()) as {
+    choices?: Array<{ message?: { content?: string } }>;
+  };
+  const content = data.choices?.[0]?.message?.content;
+  if (typeof content !== "string" || content.length === 0) {
+    throw new Error("Grok API returned an empty completion");
+  }
+  return content;
+};
+
+export interface TranslateBodyInput {
+  title: string;
+  contentHtml: string;
+  sourceLocale: string;
+  targetLocale: string;
+  /** Override the completion backend (defaults to the live Grok call). */
+  complete?: CompletionFn;
+}
+
+/**
+ * Translate a single article's title + body. Pure with respect to storage: it
+ * only performs the HTML->Markdown->translate->HTML transformation. Persistence
+ * and caching are layered on by `translateArticle`.
+ */
+export async function translateArticleBody(
+  input: TranslateBodyInput,
+): Promise<{ title: string; content: string }> {
+  const complete = input.complete ?? callGrok;
+  const markdown = htmlToTranslatableMarkdown(input.contentHtml);
+
+  // Strip code blocks before translation: replace each with a short placeholder
+  // so the model never sees code contents (saves tokens, prevents alteration).
+  const { markdown: stripped, codeBlocks } = extractCodeBlocks(markdown);
+  const chunks = chunkMarkdown(stripped, env.GROK_CHUNK_SIZE);
+
+  log.info(
+    "translateArticleBody: %d chunks (max %d chars each), %d code blocks extracted",
+    chunks.length,
+    env.GROK_CHUNK_SIZE,
+    codeBlocks.length,
+  );
+
+  // Translate the title and all body chunks in parallel.
+  const titlePromise = complete(
+    buildTitlePrompt(input.title, input.sourceLocale, input.targetLocale),
+  );
+
+  const chunkPromises = chunks.map((chunk, i) => {
+    log.info("translating chunk %d/%d (%d chars)", i + 1, chunks.length, chunk.length);
+    const prompt = buildTranslationPrompt(chunk, input.sourceLocale, input.targetLocale);
+    return complete(prompt).then((result) =>
+      result.endsWith("\n") ? result : result + "\n",
+    );
+  });
+
+  const translatedChunks = await Promise.all(chunkPromises);
+  const translatedMarkdown = restoreCodeBlocks(translatedChunks.join(""), codeBlocks);
+  const translatedTitle = await titlePromise;
+
+  // Ensure highlight.js is initialized and all code-block languages are
+  // registered before rendering, so the marked renderer produces highlighted
+  // HTML with `hljs` class names and token spans baked into the stored content.
+  await ensureHljsForMarkdown(translatedMarkdown);
+
+  return {
+    title: translatedTitle.trim() || input.title,
+    content: markdownToHtml(translatedMarkdown),
+  };
+}
+
+export interface ArticleTranslationResult {
+  locale: string;
+  title: string;
+  content: string;
+}
+
+const cacheKey = (articleId: string, locale: string) => `${articleId}:${locale}`;
+
+/**
+ * Resolve a translation for (articleId, targetLocale) through the read-through
+ * chain: translation cache -> ArticleTranslation row -> Grok. On a Grok miss
+ * the result is persisted (durable) and cached (hot). If the target locale
+ * equals the source, the original is returned unchanged (no API call).
+ *
+ * Enforces a rate limit of 10 translations per day per article, reset when
+ * the article is updated or deleted.
+ */
+export async function translateArticle(opts: {
+  articleId: string;
+  targetLocale: Locale;
+  title: string;
+  contentHtml: string;
+  sourceLocale: string;
+  complete?: CompletionFn;
+}): Promise<ArticleTranslationResult> {
+  const { articleId, targetLocale, sourceLocale } = opts;
+
+  if (targetLocale === sourceLocale) {
+    return { locale: targetLocale, title: opts.title, content: opts.contentHtml };
+  }
+
+  return remember<ArticleTranslationResult>(
+    "translation",
+    cacheKey(articleId, targetLocale),
+    async () => {
+      const prisma = getPrisma();
+
+      // Durable tier: reuse a previously persisted translation if present.
+      const existing = await prisma.articleTranslation.findUnique({
+        where: { articleId_locale: { articleId, locale: targetLocale } },
+      });
+      if (existing) {
+        return { locale: targetLocale, title: existing.title, content: existing.content };
+      }
+
+      // Check rate limit: 10 translations per day per article
+      const article = await prisma.article.findUnique({
+        where: { id: articleId },
+        select: { translationCount: true, lastTranslationAt: true },
+      });
+
+      if (!article) {
+        throw new Error("Article not found");
+      }
+
+      const now = new Date();
+      const lastTranslation = article.lastTranslationAt ? new Date(article.lastTranslationAt) : null;
+      const oneDayMs = 24 * 60 * 60 * 1000;
+
+      // Reset count if it's a new day (more than 24 hours since last translation)
+      let currentCount = article.translationCount;
+      if (lastTranslation && (now.getTime() - lastTranslation.getTime()) > oneDayMs) {
+        currentCount = 0;
+      }
+
+      // Enforce limit
+      if (currentCount >= 10) {
+        throw new Error("Translation rate limit exceeded: maximum 10 translations per day per article");
+      }
+
+      // Miss: translate via Grok, then persist write-through (DB first).
+      const translated = await translateArticleBody({
+        title: opts.title,
+        contentHtml: opts.contentHtml,
+        sourceLocale,
+        targetLocale,
+        complete: opts.complete,
+      });
+
+      await prisma.articleTranslation.upsert({
+        where: { articleId_locale: { articleId, locale: targetLocale } },
+        update: { title: translated.title, content: translated.content, sourceLocale },
+        create: {
+          articleId,
+          locale: targetLocale,
+          sourceLocale,
+          title: translated.title,
+          content: translated.content,
+        },
+      });
+
+      // Increment translation count and update timestamp
+      await prisma.article.update({
+        where: { id: articleId },
+        data: {
+          translationCount: currentCount + 1,
+          lastTranslationAt: now,
+        },
+      });
+
+      return { locale: targetLocale, title: translated.title, content: translated.content };
+    },
+  );
+}
+
+/**
+ * Drop all cached + persisted translations for an article. Called from
+ * lib/articles.ts whenever the source article is edited so a stale revision is
+ * never served.
+ *
+ * Also resets the translation rate limit counters (translationCount and
+ * lastTranslationAt) since the article content has changed.
+ *
+ * Cache eviction is scoped to the article (prefix `cache:translation:${id}:`)
+ * so other articles' translations are not collateral damage.
+ */
+export async function invalidateArticleTranslations(articleId: string): Promise<void> {
+  try {
+    await getPrisma().articleTranslation.deleteMany({ where: { articleId } });
+  } catch (err) {
+    log.warn("failed to delete translations for", articleId, err);
+  }
+  // Reset rate limit counters
+  try {
+    await getPrisma().article.update({
+      where: { id: articleId },
+      data: {
+        translationCount: 0,
+        lastTranslationAt: null,
+      },
+    });
+  } catch (err) {
+    log.warn("failed to reset translation rate limit for", articleId, err);
+  }
+  // Per-article cache eviction: keys are `cache:translation:${articleId}:${locale}`
+  await invalidateByPrefix("translation", `${articleId}:`);
+}
+
+/**
+ * Evict cached translations for an article whose DB rows have already been
+ * cascade-deleted (i.e. the article itself was deleted). Only clears the
+ * cache â€” no DB writes needed since the rows are gone and the article no
+ * longer exists for rate-limit reset.
+ */
+export async function evictArticleTranslationCache(articleId: string): Promise<void> {
+  await invalidateByPrefix("translation", `${articleId}:`);
+}

diff --git a/src/components/wysiwyg.tsx b/src/components/wysiwyg.tsx
new file mode 100644
--- /dev/null
+++ b/src/components/wysiwyg.tsx
@@ -0,0 +1,608 @@
+"use client";
+
+/**
+ * Dual-mode article editor: rich WYSIWYG (contentEditable) or Markdown with live
+ * preview. The value is always HTML; switching to Markdown converts HTMLâ†’md on
+ * entry and mdâ†’HTML on exit via `turndown` and `marked`. Image upload (admin
+ * only) inserts <img> into the active surface.
+ */
+import { useCallback, useEffect, useMemo, useRef, useState } from "react";
+import {
+  Bold,
+  Italic,
+  Heading2,
+  List,
+  Link2,
+  Code2,
+  Quote,
+  Image as ImageIcon,
+  Paperclip,
+  Type,
+  Eye,
+  EyeOff,
+  SeparatorHorizontal,
+  Globe,
+  ChevronLeft,
+  ChevronRight,
+} from "lucide-react";
+import { api, ApiClientError } from "@/lib/api-client";
+import { useToast } from "@/components/toast";
+// Markdown <-> HTML conversion (client-side only).
+import { marked } from "marked";
+import TurndownService from "turndown";
+import {
+  FILE_ACCEPT,
+  buildEmbedHtml,
+  buildEmbedMarkdown,
+  buildUrlEmbedHtml,
+  buildUrlEmbedMarkdown,
+  buildPreviewEndHtml,
+  PREVIEW_END_MARKER,
+  registerEmbedExtension,
+  addEmbedTurndownRule,
+  isExternalHttpUrl,
+} from "@/lib/embeds";
+import {
+  parseCodeBlockInfo,
+  buildCodeBlock,
+  escapeCode,
+} from "@/lib/code-block-render";
+import { hydrateLinkEmbeds } from "@/lib/link-embeds";
+import {
+  initHighlightJs,
+  loadHighlightJsCss,
+  loadHighlightJsLanguage,
+  getHljsModule,
+  wireCodeBlockToggles,
+  type CodeToggleOptions,
+} from "@/lib/highlight";
+
+interface Props {
+  value: string;
+  onChange: (html: string) => void;
+}
+
+// Enable the `@[name](url)` attachment tag in markdown rendering globally.
+registerEmbedExtension(marked);
+
+// Detect if markdown contains code blocks
+function hasCodeBlocks(markdown: string): boolean {
+  return /```[\s\S]*?```/.test(markdown);
+}
+
+// Extract all languages from code blocks in markdown
+function extractLanguages(markdown: string): string[] {
+  const regex = /```(\w+)/g;
+  const languages = new Set<string>();
+  let match;
+  while ((match = regex.exec(markdown)) !== null) {
+    languages.add(match[1]);
+  }
+  return Array.from(languages);
+}
+
+// Configure marked to use highlight.js for syntax highlighting (lazy-loaded)
+marked.use({
+  renderer: {
+    code(code: string, language: string | undefined) {
+      const { language: lang, previewLines, collapseKind, size } = parseCodeBlockInfo(language || "");
+      const totalLines = code.split("\n").length;
+      const hljs = getHljsModule();
+
+      // If highlight.js isn't loaded yet, emit escaped plain code (the wrapper
+      // is re-rendered once hljs becomes ready).
+      if (!hljs) {
+        return buildCodeBlock(escapeCode(code), lang, totalLines, { previewLines, collapseKind, size }, false);
+      }
+
+      const validLang = lang && hljs.getLanguage(lang) ? lang : "plaintext";
+      try {
+        const highlighted = hljs.highlight(code, { language: validLang }).value;
+        return buildCodeBlock(highlighted, validLang, totalLines, { previewLines, collapseKind, size }, true);
+      } catch (error) {
+        console.error("Highlight.js error:", error);
+        return buildCodeBlock(escapeCode(code), validLang, totalLines, { previewLines, collapseKind, size }, false);
+      }
+    },
+  },
+});
+
+const turndown = new TurndownService({ headingStyle: "atx" });
+addEmbedTurndownRule(turndown);
+
+/* ------------------ caret preservation across mode switch ---------------- */
+// "Blocks" are the top-level children of the rich surface and the blank-line
+// separated segments of the markdown source. We anchor the caret to the block
+// it currently sits in ("the equivalent element above it") and, after the mode
+// switch, drop the caret at the end of the matching block â€” or at the very
+// start if none maps across.
+
+/** Index of the top-level block in `root` that contains the current caret. */
+function getRichCaretBlockIndex(root: HTMLElement): number {
+  const sel = window.getSelection();
+  if (!sel || sel.rangeCount === 0) return 0;
+  let node: Node | null = sel.getRangeAt(0).startContainer;
+  if (!node || !root.contains(node)) return 0;
+  while (node && node.parentNode !== root) node = node.parentNode;
+  if (!node) return 0;
+  const idx = Array.from(root.children).indexOf(node as Element);
+  return idx < 0 ? 0 : idx;
+}
+
+/** Drop the caret at the end of the `index`-th top-level block (start if none). */
+function placeRichCaretAtBlock(root: HTMLElement, index: number): void {
+  const sel = window.getSelection();
+  if (!sel) return;
+  const blocks = Array.from(root.children);
+  const range = document.createRange();
+  const target = index >= 0 ? blocks[Math.min(index, blocks.length - 1)] : undefined;
+  if (target) {
+    range.selectNodeContents(target);
+    range.collapse(false); // end of the equivalent block
+  } else {
+    range.selectNodeContents(root);
+    range.collapse(true); // start
+  }
+  sel.removeAllRanges();
+  sel.addRange(range);
+}
+
+/** Char ranges of each blank-line-separated markdown block. */
+function mdBlockRanges(md: string): Array<{ start: number; end: number }> {
+  const ranges: Array<{ start: number; end: number }> = [];
+  const re = /\n[ \t]*\n/g;
+  let start = 0;
+  let m: RegExpExecArray | null;
+  while ((m = re.exec(md)) !== null) {
+    ranges.push({ start, end: m.index });
+    start = m.index + m[0].length;
+  }
+  ranges.push({ start, end: md.length });
+  return ranges;
+}
+
+/** Index of the markdown block containing the textarea caret. */
+function getMdCaretBlockIndex(ta: HTMLTextAreaElement): number {
+  const pos = ta.selectionStart ?? 0;
+  const ranges = mdBlockRanges(ta.value);
+  for (let i = 0; i < ranges.length; i++) {
+    if (pos <= ranges[i]!.end) return i;
+  }
+  return Math.max(0, ranges.length - 1);
+}
+
+/** Drop the textarea caret at the end of the `index`-th block (start if none). */
+function placeMdCaretAtBlock(ta: HTMLTextAreaElement, index: number): void {
+  const ranges = mdBlockRanges(ta.value);
+  if (index < 0 || ranges.length === 0) {
+    ta.setSelectionRange(0, 0);
+    return;
+  }
+  const pos = ranges[Math.min(index, ranges.length - 1)]!.end;
+  ta.setSelectionRange(pos, pos);
+}
+
+export function Wysiwyg({ value, onChange }: Props) {
+  const ref = useRef<HTMLDivElement>(null);
+  const mdRef = useRef<HTMLTextAreaElement>(null);
+  const fileRef = useRef<HTMLInputElement>(null);
+  const attachRef = useRef<HTMLInputElement>(null);
+  // Block index captured at toggle time, applied to the textarea once it mounts.
+  const pendingCaretRef = useRef<number | null>(null);
+  const toast = useToast();
+  const [mode, setMode] = useState<"rich" | "md">("rich");
+  const [md, setMd] = useState("");
+  const [hljsReady, setHljsReady] = useState(false);
+  const [hljsInitialized, setHljsInitialized] = useState(false);
+  // Live-preview pane collapse state (markdown mode). When collapsed the preview
+  // is not rendered and its HTML is never computed (see previewHtml below).
+  const [previewCollapsed, setPreviewCollapsed] = useState(false);
+  const previewRef = useRef<HTMLDivElement>(null);
+  // Remembers which code blocks the editor expanded, keyed by block index, so
+  // the state survives the markdown preview being re-injected via
+  // `dangerouslySetInnerHTML` on every keystroke / highlight pass (otherwise an
+  // expanded block would flicker back to collapsed as you type).
+  const expandedBlocksRef = useRef<Set<number>>(new Set());
+
+  const codeToggleOptions = useMemo<CodeToggleOptions>(
+    () => ({
+      isExpanded: (i) => expandedBlocksRef.current.has(i),
+      onToggle: (i, expanded) => {
+        if (expanded) expandedBlocksRef.current.add(i);
+        else expandedBlocksRef.current.delete(i);
+      },
+    }),
+    [],
+  );
+
+  // Preview HTML for markdown mode. Collapsed preview skips the marked() render
+  // entirely so typing stays cheap when the pane is hidden. `hljsReady` re-runs
+  // it once highlight.js loads. Note: this only feeds the *visible* preview; the
+  // saved value is emitted independently by the onChange effect below, so
+  // collapsing the preview never affects the data written on save.
+  const previewHtml = useMemo(
+    () => (previewCollapsed ? "" : (marked(md) as string)),
+    [md, previewCollapsed, hljsReady],
+  );
+
+  // Initialize rich content and keep it in sync with value prop. Re-wire the
+  // code block collapse toggles after every sync so they work in rich mode too
+  // (e.g. right after clicking Edit on an existing article).
+  useEffect(() => {
+    if (ref.current && ref.current.innerHTML !== value) {
+      ref.current.innerHTML = value;
+    }
+    if (mode === "rich" && ref.current) {
+      wireCodeBlockToggles(ref.current, codeToggleOptions);
+      hydrateLinkEmbeds(ref.current);
+    }
+  }, [value, mode, codeToggleOptions]);
+
+  // Clear markdown state when switching to rich mode. Reset persisted block
+  // state too, since indices belong to the previously rendered content.
+  useEffect(() => {
+    if (mode === "rich") {
+      setMd("");
+    }
+    expandedBlocksRef.current.clear();
+  }, [mode]);
+
+  // When in markdown mode, convert markdown to HTML and emit to parent
+  // This ensures the parent always has the HTML representation for saving
+  useEffect(() => {
+    if (mode === "md" && md) {
+      // Lazy load highlight.js, CSS, and required languages only if code blocks are present
+      if (hasCodeBlocks(md) && !hljsInitialized) {
+        const languages = extractLanguages(md);
+        void Promise.all([
+          initHighlightJs(),
+          loadHighlightJsCss(),
+          ...languages.map(lang => loadHighlightJsLanguage(lang))
+        ]).then(() => {
+          setHljsReady(true);
+          setHljsInitialized(true);
+        });
+      } else if (hasCodeBlocks(md) && hljsInitialized) {
+        // Load CSS if not loaded yet and any new languages
+        const languages = extractLanguages(md);
+        void Promise.all([
+          loadHighlightJsCss(),
+          ...languages.map(lang => loadHighlightJsLanguage(lang))
+        ]).then(() => {
+          setHljsReady(true);
+        });
+      }
+      const html = marked(md) as string;
+      onChange(html);
+    }
+  }, [md, mode, onChange, hljsInitialized]);
+
+  // Re-render markdown when hljs becomes ready
+  useEffect(() => {
+    if (hljsReady && mode === "md" && md) {
+      const html = marked(md) as string;
+      onChange(html);
+    }
+  }, [hljsReady, mode, md, onChange]);
+
+  // Wire the code block collapse/expand toggle bars in the markdown preview.
+  // Re-runs whenever the rendered markdown changes or hljs becomes ready. The
+  // delegated listener lives on the stable preview container, and the persisted
+  // options keep blocks expanded across the per-keystroke re-injection.
+  useEffect(() => {
+    if (mode === "md" && !previewCollapsed && previewRef.current) {
+      wireCodeBlockToggles(previewRef.current, codeToggleOptions);
+      hydrateLinkEmbeds(previewRef.current);
+    }
+  }, [mode, md, hljsReady, codeToggleOptions, previewCollapsed]);
+
+  // When toggling to md, convert current HTML â†’ md.
+  const toggleToMd = useCallback(() => {
+    // Capture the caret's block position before the surface is torn down.
+    const caretIdx = ref.current ? getRichCaretBlockIndex(ref.current) : 0;
+    const html = ref.current?.innerHTML ?? value;
+    // Clear the contentEditable div immediately to prevent it from showing
+    if (ref.current) {
+      ref.current.innerHTML = "";
+    }
+    // Create a fresh turndown instance to avoid any state issues
+    const turndownService = new TurndownService({
+      headingStyle: "atx",
+      codeBlockStyle: "fenced",
+    });
+    // Register the embed rule so embed HTML collapses back to @[name](url)
+    addEmbedTurndownRule(turndownService);
+    const markdown = turndownService.turndown(html);
+    pendingCaretRef.current = caretIdx;
+    setMd(markdown);
+    setMode("md");
+  }, [value]);
+
+  // When toggling to rich, convert md â†’ HTML and emit.
+  const toggleToRich = useCallback(() => {
+    // Capture the caret's markdown block before conversion.
+    const caretIdx = mdRef.current ? getMdCaretBlockIndex(mdRef.current) : 0;
+    const html = marked(md) as string;
+    onChange(html);
+    setMd(""); // Clear markdown state when switching back to rich
+    setMode("rich");
+    // Sync the contentEditable surface after render, then wire code toggles and
+    // hand the caret off to the equivalent block, focusing seamlessly.
+    requestAnimationFrame(() => {
+      if (ref.current) {
+        ref.current.innerHTML = html;
+        wireCodeBlockToggles(ref.current, codeToggleOptions);
+        hydrateLinkEmbeds(ref.current);
+        ref.current.focus();
+        placeRichCaretAtBlock(ref.current, caretIdx);
+      }
+    });
+  }, [md, onChange, codeToggleOptions]);
+
+  // After switching to Markdown, restore the caret to the block mirroring the
+  // rich-mode position and focus the textarea (seamless hand-off). Guarded by
+  // pendingCaretRef so it only fires on an actual mode toggle, not keystrokes.
+  useEffect(() => {
+    if (mode !== "md" || pendingCaretRef.current === null) return;
+    const idx = pendingCaretRef.current;
+    pendingCaretRef.current = null;
+    const ta = mdRef.current;
+    if (!ta) return;
+    requestAnimationFrame(() => {
+      ta.focus();
+      placeMdCaretAtBlock(ta, idx);
+    });
+  }, [mode, md]);
+
+  const exec = useCallback(
+    (command: string, arg?: string) => {
+      document.execCommand(command, false, arg);
+      ref.current?.focus();
+      if (ref.current) onChange(ref.current.innerHTML);
+    },
+    [onChange],
+  );
+
+  // Insert raw HTML at the caret (rich mode) and emit the updated value.
+  const insertHtml = useCallback(
+    (html: string) => {
+      ref.current?.focus();
+      document.execCommand("insertHTML", false, `${html}<p><br></p>`);
+      if (ref.current) onChange(ref.current.innerHTML);
+    },
+    [onChange],
+  );
+
+  // Insert the `--END PREVIEW--` separator at the caret in either mode. In rich
+  // mode it drops the <hr data-preview-end> chrome; in markdown mode it splices
+  // the marker in at the textarea caret (falling back to an append).
+  const insertPreviewSeparator = useCallback(() => {
+    if (mode === "rich") {
+      insertHtml(buildPreviewEndHtml());
+      return;
+    }
+    const ta = mdRef.current;
+    if (ta) {
+      const start = ta.selectionStart ?? md.length;
+      const end = ta.selectionEnd ?? md.length;
+      setMd(`${md.slice(0, start)}\n\n${PREVIEW_END_MARKER}\n\n${md.slice(end)}`);
+    } else {
+      setMd((prev) => `${prev}\n\n${PREVIEW_END_MARKER}\n\n`);
+    }
+  }, [mode, md, insertHtml]);
+
+  const handleInput = useCallback(() => {
+    if (ref.current) onChange(ref.current.innerHTML);
+  }, [onChange]);
+
+  // Insert an external URL embed (rich provider embed or generic link preview).
+  // Works in both modes; rich mode also hydrates the freshly inserted card.
+  const handleInsertLinkEmbed = useCallback(() => {
+    const raw = prompt("Embed URL (YouTube, SoundCloud, Vimeo, X, â€¦)");
+    if (!raw) return;
+    const url = raw.trim();
+    if (!isExternalHttpUrl(url)) {
+      toast.error("Enter a full http(s) URL");
+      return;
+    }
+    if (mode === "rich") {
+      insertHtml(buildUrlEmbedHtml({ url }));
+      requestAnimationFrame(() => hydrateLinkEmbeds(ref.current));
+    } else {
+      setMd((prev) => `${prev}\n\n${buildUrlEmbedMarkdown({ url })}\n\n`);
+    }
+  }, [insertHtml, mode, toast]);
+
+  const handleUpload = useCallback(
+    async (file: File) => {
+      const fd = new FormData();
+      fd.append("file", file);
+      try {
+        const { url } = await api.post<{ url: string }>("/api/upload", fd);
+        if (mode === "rich") {
+          exec("insertImage", url);
+        } else {
+          setMd((prev) => `${prev}\n
+![image](${url})
+`);
+        }
+        toast.success("Image uploaded");
+      } catch (err) {
+        toast.error(err instanceof ApiClientError ? err.message : "Upload failed");
+      }
+    },
+    [exec, mode, toast],
+  );
+
+  // Upload an arbitrary file (document/video/audio/archive) and insert an
+  // attachment embed. Works in both rich and markdown modes.
+  const handleFileUpload = useCallback(
+    async (file: File) => {
+      const fd = new FormData();
+      fd.append("file", file);
+      try {
+        const { url } = await api.post<{ url: string }>("/api/upload", fd);
+        if (mode === "rich") {
+          insertHtml(buildEmbedHtml({ name: file.name, src: url }));
+        } else {
+          setMd((prev) => `${prev}\n\n${buildEmbedMarkdown({ name: file.name, src: url })}\n\n`);
+        }
+        toast.success("File uploaded");
+      } catch (err) {
+        toast.error(err instanceof ApiClientError ? err.message : "Upload failed");
+      }
+    },
+    [insertHtml, mode, toast],
+  );
+
+  const Btn = ({
+    onClick,
+    title,
+    children,
+  }: {
+    onClick: () => void;
+    title: string;
+    children: React.ReactNode;
+  }) => (
+    <button
+      type="button"
+      title={title}
+      onClick={onClick}
+      className="rounded p-2 text-fg transition-colors hover:bg-border/40"
+    >
+      {children}
+    </button>
+  );
+
+  return (
+    <div className="rounded-md border border-border bg-card">
+      <div className="sticky top-0 z-20 flex flex-wrap items-center justify-between gap-1 rounded-t-md border-b border-border bg-card/90 p-1.5 backdrop-blur">
+        <div className="flex flex-wrap items-center gap-1">
+          <button
+            type="button"
+            onClick={() => (mode === "rich" ? toggleToMd() : toggleToRich())}
+            title={mode === "rich" ? "Switch to Markdown" : "Switch to rich text"}
+            className="rounded p-2 text-fg transition-colors hover:bg-border/40"
+          >
+            {mode === "rich" ? <Type className="h-4 w-4" /> : <Eye className="h-4 w-4" />}
+          </button>
+          {mode === "rich" && (
+            <>
+              <Btn title="Bold" onClick={() => exec("bold")}>
+                <Bold className="h-4 w-4" />
+              </Btn>
+              <Btn title="Italic" onClick={() => exec("italic")}>
+                <Italic className="h-4 w-4" />
+              </Btn>
+              <Btn title="Heading" onClick={() => exec("formatBlock", "<h2>")}>
+                <Heading2 className="h-4 w-4" />
+              </Btn>
+              <Btn title="Quote" onClick={() => exec("formatBlock", "<blockquote>")}>
+                <Quote className="h-4 w-4" />
+              </Btn>
+              <Btn title="Code block" onClick={() => exec("formatBlock", "<pre>")}>
+                <Code2 className="h-4 w-4" />
+              </Btn>
+              <Btn title="List" onClick={() => exec("insertUnorderedList")}>
+                <List className="h-4 w-4" />
+              </Btn>
+              <Btn
+                title="Link"
+                onClick={() => {
+                  const url = prompt("Link URL");
+                  if (url) exec("createLink", url);
+                }}
+              >
+                <Link2 className="h-4 w-4" />
+              </Btn>
+            </>
+          )}
+        </div>
+        <div className="flex items-center gap-1">
+          <Btn title="Insert preview separator (--END PREVIEW--)" onClick={insertPreviewSeparator}>
+            <SeparatorHorizontal className="h-4 w-4" />
+          </Btn>
+          <Btn title="Embed link (YouTube, SoundCloud, Vimeo, Xâ€¦)" onClick={handleInsertLinkEmbed}>
+            <Globe className="h-4 w-4" />
+          </Btn>
+          <Btn title="Insert image" onClick={() => fileRef.current?.click()}>
+            <ImageIcon className="h-4 w-4" />
+          </Btn>
+          <Btn title="Attach file (video, audio, documentâ€¦)" onClick={() => attachRef.current?.click()}>
+            <Paperclip className="h-4 w-4" />
+          </Btn>
+        </div>
+        <input
+          ref={fileRef}
+          type="file"
+          accept="image/*"
+          className="hidden"
+          onChange={(e) => {
+            const f = e.target.files?.[0];
+            if (f) void handleUpload(f);
+            e.target.value = "";
+          }}
+        />
+        <input
+          ref={attachRef}
+          type="file"
+          accept={FILE_ACCEPT}
+          className="hidden"
+          onChange={(e) => {
+            const f = e.target.files?.[0];
+            if (f) void handleFileUpload(f);
+            e.target.value = "";
+          }}
+        />
+      </div>
+
+      {mode === "rich" ? (
+        <div
+          ref={ref}
+          contentEditable
+          onInput={handleInput}
+          className="article-body min-h-[260px] px-4 py-3 text-fg outline-none"
+          suppressContentEditableWarning
+        />
+      ) : (
+        <div className="flex">
+          <textarea
+            ref={mdRef}
+            value={md}
+            onChange={(e) => setMd(e.target.value)}
+            className={`article-body min-h-[260px] bg-bg px-4 py-3 text-fg outline-none resize-none ${
+              previewCollapsed ? "flex-1" : "w-1/2"
+            }`}
+            placeholder="Write in Markdown..."
+          />
+          {/* Thin, clickable divider that collapses/expands the live preview.
+              While collapsed, the preview below is not rendered at all, so its
+              marked() HTML is never computed. */}
+          <button
+            type="button"
+            data-testid="md-preview-toggle"
+            onClick={() => setPreviewCollapsed((v) => !v)}
+            title={previewCollapsed ? "Show preview" : "Hide preview"}
+            aria-label={previewCollapsed ? "Show preview" : "Hide preview"}
+            aria-expanded={!previewCollapsed}
+            className="flex w-4 flex-none cursor-pointer items-center justify-center border-l border-border bg-card/60 text-muted transition-colors hover:bg-border/40 hover:text-fg"
+          >
+            {previewCollapsed ? (
+              <ChevronLeft className="h-4 w-4" />
+            ) : (
+              <ChevronRight className="h-4 w-4" />
+            )}
+          </button>
+          {!previewCollapsed && (
+            <div
+              ref={previewRef}
+              data-testid="md-preview"
+              className="article-body min-h-[260px] w-1/2 overflow-auto px-4 py-3 text-fg"
+              dangerouslySetInnerHTML={{ __html: previewHtml }}
+            />
+          )}
+        </div>
+      )}
+    </div>
+  );
+}

diff --git a/src/components/code-block.tsx b/src/components/code-block.tsx
new file mode 100644
--- /dev/null
+++ b/src/components/code-block.tsx
@@ -0,0 +1,80 @@
+"use client";
+
+/**
+ * Code block component with expand/collapse functionality.
+ * Used for displaying code blocks with optional line preview.
+ */
+import { useState } from "react";
+import { ChevronDown, ChevronUp } from "lucide-react";
+
+interface Props {
+  code: string;
+  language: string;
+  previewLines?: number;
+  highlighted?: string;
+  highlightedPreview?: string;
+}
+
+export function CodeBlock({
+  code,
+  language,
+  previewLines,
+  highlighted,
+  highlightedPreview,
+}: Props) {
+  const [isCollapsed, setIsCollapsed] = useState(
+    previewLines ? code.split("\n").length > previewLines : false
+  );
+
+  const lines = code.split("\n");
+  const hasPreview = previewLines && lines.length > previewLines;
+
+  if (!hasPreview) {
+    // No preview needed, show full code
+    return (
+      <pre>
+        <code className={`hljs language-${language}`}>
+          {highlighted || code}
+        </code>
+      </pre>
+    );
+  }
+
+  return (
+    <div className="code-block-wrapper">
+      {isCollapsed ? (
+        <pre>
+          <code className={`hljs language-${language}`}>
+            {highlightedPreview || lines.slice(0, previewLines).join("\n")}
+            {"\n..."}
+          </code>
+        </pre>
+      ) : (
+        <pre>
+          <code className={`hljs language-${language}`}>
+            {highlighted || code}
+          </code>
+        </pre>
+      )}
+
+      {hasPreview && (
+        <button
+          className="code-expand-btn"
+          onClick={() => setIsCollapsed(!isCollapsed)}
+          type="button"
+        >
+          <span className="icon">
+            {isCollapsed ? (
+              <ChevronDown className="h-4 w-4" />
+            ) : (
+              <ChevronUp className="h-4 w-4" />
+            )}
+          </span>
+          <span className="text">
+            {isCollapsed ? `Show all ${lines.length} lines` : "Show less"}
+          </span>
+        </button>
+      )}
+    </div>
+  );
+}

