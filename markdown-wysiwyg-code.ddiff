+
+  it("PREVIEW_END_MARKER should be the canonical markdown form", () => {
+    expect(PREVIEW_END_MARKER).toBe("--END PREVIEW--");
+  });
+});
+
+describe("extractPreviewHtml", () => {
+  it("returns null when no separator is present", () => {
+    expect(extractPreviewHtml("<p>Just a body</p>")).toBeNull();
+  });
+
+  it("returns the HTML before the separator, trimmed", () => {
+    const html = `<p>Intro</p>${buildPreviewEndHtml()}<p>Hidden</p>`;
+    expect(extractPreviewHtml(html)).toBe("<p>Intro</p>");
+  });
+
+  it("keeps a full code block before the separator intact", () => {
+    const codeBlock =
+      '<div class="cb-code"><pre class="cb-code__pre"><code class="language-ts">const x = 1;</code></pre></div>';
+    const html = `${codeBlock}${buildPreviewEndHtml()}<p>After</p>`;
+    const preview = extractPreviewHtml(html);
+    expect(preview).toBe(codeBlock);
+    expect(preview).not.toContain("After");
+  });
+
+  it("matches the separator regardless of attribute order", () => {
+    const html =
+      '<p>Intro</p><hr class="cb-preview-end" data-preview-end="1" /><p>Rest</p>';
+    expect(extractPreviewHtml(html)).toBe("<p>Intro</p>");
+  });
+});
+
+describe("Preview Separator Markdown Round-Trip", () => {
+  let turndown: TurndownService;
+
+  beforeAll(() => {
+    registerPreviewEndExtension(marked);
+  });
+
+  beforeEach(() => {
+    turndown = new TurndownService({
+      headingStyle: "atx",
+      codeBlockStyle: "fenced",
+    });
+    addPreviewEndTurndownRule(turndown);
+  });
+
+  it("renders --END PREVIEW-- as an <hr data-preview-end>", () => {
+    const html = marked.parse("--END PREVIEW--") as string;
+    expect(html).toContain("data-preview-end");
+    expect(html).toContain("cb-preview-end");
+  });
+
+  it("round-trips the bare separator back to --END PREVIEW--", () => {
+    const html = marked.parse("--END PREVIEW--") as string;
+    const md = turndown.turndown(html).trim();
+    expect(md).toBe("--END PREVIEW--");
+  });
+
+  it("preserves the separator inside a larger document", () => {
+    const markdown = [
+      "# Title",
+      "",
+      "Intro paragraph.",
+      "",
+      "--END PREVIEW--",
+      "",
+      "Hidden paragraph.",
+    ].join("\n");
+    const html = marked.parse(markdown) as string;
+    expect(html).toContain("data-preview-end");
+
+    const md = turndown.turndown(html).trim();
+    expect(md).toContain("# Title");
+    expect(md).toContain("Intro paragraph.");
+    expect(md).toContain("--END PREVIEW--");
+    expect(md).toContain("Hidden paragraph.");
+    // Order is preserved: separator sits between the intro and the hidden body.
+    expect(md.indexOf("Intro paragraph.")).toBeLessThan(md.indexOf("--END PREVIEW--"));
+    expect(md.indexOf("--END PREVIEW--")).toBeLessThan(md.indexOf("Hidden paragraph."));
+  });
+
+  it("leaves a normal horizontal rule (---) untouched", () => {
+    const html = marked.parse("above\n\n---\n\nbelow") as string;
+    expect(html).not.toContain("data-preview-end");
+    const md = turndown.turndown(html).trim();
+    expect(md).not.toContain("--END PREVIEW--");
+  });
+});
+
+/* ----------------------------- URL embeds -------------------------------- */
+// The two canonical fixtures requested for verification.
+const SOUNDCLOUD_URL =
+  "https://soundcloud.com/elaina-hannah/overwerk-virtue?si=957df22c7ab74dd2a3412cfc5675be41&utm_source=clipboard&utm_medium=text&utm_campaign=social_sharing";
+const YOUTUBE_URL = "https://www.youtube.com/watch?v=Z_UOmAed5O8";
+
+describe("URL Embed Detection", () => {
+  it("treats external pages as URL embeds", () => {
+    expect(shouldTreatAsUrlEmbed(YOUTUBE_URL)).toBe(true);
+    expect(shouldTreatAsUrlEmbed(SOUNDCLOUD_URL)).toBe(true);
+    expect(shouldTreatAsUrlEmbed("https://example.com/some-post")).toBe(true);
+  });
+
+  it("leaves local uploads and direct file links as file embeds", () => {
+    expect(shouldTreatAsUrlEmbed("/api/uploads/1234-file.pdf")).toBe(false);
+    expect(shouldTreatAsUrlEmbed("https://cdn.example.com/clip.mp4")).toBe(false);
+    expect(shouldTreatAsUrlEmbed("https://cdn.example.com/photo.jpg")).toBe(false);
+  });
+
+  it("detects providers by host", () => {
+    expect(detectProvider(YOUTUBE_URL)).toBe("youtube");
+    expect(detectProvider(SOUNDCLOUD_URL)).toBe("soundcloud");
+    expect(detectProvider("https://music.youtube.com/watch?v=abc")).toBe("youtubemusic");
+    expect(detectProvider("https://example.com/x")).toBeNull();
+  });
+});
+
+describe("URL Embed Bracket Parser", () => {
+  it("parses an empty bracket", () => {
+    expect(parseUrlBracket("")).toEqual({ size: { type: "none" }, urlOnly: false });
+  });
+  it("parses a size spec", () => {
+    expect(parseUrlBracket("640x360")).toEqual({
+      size: { type: "pixels", width: 640, height: 360 },
+      urlOnly: false,
+    });
+  });
+  it("parses the urlOnly keyword (case-insensitive)", () => {
+    expect(parseUrlBracket("urlOnly")).toEqual({ size: { type: "none" }, urlOnly: true });
+    expect(parseUrlBracket("URLONLY")).toEqual({ size: { type: "none" }, urlOnly: true });
+  });
+  it("parses size + urlOnly together", () => {
+    expect(parseUrlBracket("50% urlOnly")).toEqual({
+      size: { type: "percent", width: 50 },
+      urlOnly: true,
+    });
+  });
+});
+
+describe("Provider Embed Generation", () => {
+  it("builds a YouTube iframe from the video id", () => {
+    const frame = buildProviderEmbed(YOUTUBE_URL);
+    expect(frame?.provider).toBe("youtube");
+    expect(frame?.shape).toBe("video");
+    expect(frame?.html).toContain("https://www.youtube.com/embed/Z_UOmAed5O8");
+  });
+
+  it("builds a SoundCloud player from the track permalink", () => {
+    const frame = buildProviderEmbed(SOUNDCLOUD_URL);
+    expect(frame?.provider).toBe("soundcloud");
+    expect(frame?.shape).toBe("audio");
+    expect(frame?.html).toContain("https://w.soundcloud.com/player/?url=");
+    // The permalink is encoded and the tracking query stripped from the player.
+    expect(frame?.html).toContain(
+      encodeURIComponent("https://soundcloud.com/elaina-hannah/overwerk-virtue"),
+    );
+    expect(frame?.html).not.toContain("utm_source");
+  });
+});
+
+describe("URL Embed Round-Trip", () => {
+  let turndown: TurndownService;
+
+  beforeAll(() => {
+    registerEmbedExtension(marked);
+  });
+
+  beforeEach(() => {
+    turndown = new TurndownService({ headingStyle: "atx", codeBlockStyle: "fenced" });
+    addEmbedTurndownRule(turndown);
+  });
+
+  const cases = [
+    { name: "YouTube (default rich embed)", markdown: `@[](${YOUTUBE_URL})` },
+    { name: "SoundCloud (default rich embed)", markdown: `@[](${SOUNDCLOUD_URL})` },
+    { name: "YouTube short link", markdown: "@[](https://youtu.be/Z_UOmAed5O8)" },
+    { name: "Sized YouTube embed", markdown: "@[640x360](https://youtu.be/Z_UOmAed5O8)" },
+    { name: "Percent-sized SoundCloud", markdown: `@[50%](${SOUNDCLOUD_URL})` },
+    { name: "Generic page (preview fallback)", markdown: "@[](https://example.com/some-post)" },
+    { name: "urlOnly plain link", markdown: "@[urlOnly](https://example.com/some-post)" },
+    { name: "Sized + urlOnly", markdown: "@[50% urlOnly](https://example.com/some-post)" },
+  ];
+
+  cases.forEach(({ name, markdown }) => {
+    it(`round-trips ${name}`, () => {
+      const html = marked.parse(markdown) as string;
+      expect(html).toContain('data-embed-type="url"');
+      const roundTripped = turndown.turndown(html);
+      expect(roundTripped.trim()).toBe(markdown);
+    });
+  });
+
+  it("renders a YouTube rich embed with the player iframe", () => {
+    const html = marked.parse(`@[](${YOUTUBE_URL})`) as string;
+    expect(html).toContain('data-provider="youtube"');
+    expect(html).toContain("https://www.youtube.com/embed/Z_UOmAed5O8");
+    expect(html).toContain('data-shape="video"');
+  });
+
+  it("renders a SoundCloud rich embed with the player iframe", () => {
+    const html = marked.parse(`@[](${SOUNDCLOUD_URL})`) as string;
+    expect(html).toContain('data-provider="soundcloud"');
+    expect(html).toContain("https://w.soundcloud.com/player/?url=");
+    expect(html).toContain('data-shape="audio"');
+    // The full original URL (with tracking params) is preserved for round-trip.
+    expect(html).toContain("utm_campaign=social_sharing");
+  });
+
+  it("renders a generic page as a link-preview card with a Visit-site button", () => {
+    const html = marked.parse("@[](https://example.com/some-post)") as string;
+    expect(html).toContain("cb-embed--link");
+    expect(html).toContain('data-link-hydrate="1"');
+    expect(html).toContain("Visit site");
+    expect(html).toContain("example.com");
+  });
+
+  it("renders urlOnly as a plain anchor without a preview", () => {
+    const html = marked.parse("@[urlOnly](https://example.com/some-post)") as string;
+    expect(html).toContain("cb-embed--urlonly");
+    expect(html).toContain('data-url-only="1"');
+    expect(html).not.toContain("cb-embed__frame");
+    expect(html).not.toContain("Visit site");
+  });
+
+  it("keeps file/media embeds unaffected by URL-embed detection", () => {
+    const markdown = "@[video.mp4](https://cdn.example.com/video.mp4)";
+    const html = marked.parse(markdown) as string;
+    expect(html).not.toContain('data-embed-type="url"');
+    expect(html).toContain("data-embed");
+    const roundTripped = turndown.turndown(html);
+    expect(roundTripped.trim()).toBe(markdown);
+  });
+
+  it("keeps the WYSIWYG-built HTML and markdown preview consistent (same builder)", () => {
+    // The editor inserts buildUrlEmbedHtml output directly in rich mode; the
+    // markdown preview renders buildUrlEmbedMarkdown through marked. Both must
+    // yield identical HTML so the two surfaces stay visually consistent.
+    const fromBuilder = buildUrlEmbedHtml({ url: YOUTUBE_URL });
+    const fromMarkdown = marked.parse(buildUrlEmbedMarkdown({ url: YOUTUBE_URL })) as string;
+    expect(fromMarkdown).toContain(fromBuilder);
+  });
+});

diff --git a/tests/unit/code-block-roundtrip.test.ts b/tests/unit/code-block-roundtrip.test.ts
new file mode 100644
--- /dev/null
+++ b/tests/unit/code-block-roundtrip.test.ts
@@ -0,0 +1,113 @@
+/**
+ * Test for code block round-trip conversion between wysiwyg and markdown.
+ * Ensures that code blocks with preview functionality are properly preserved
+ * when converting HTML back to markdown.
+ */
+import TurndownService from "turndown";
+import { addEmbedTurndownRule } from "@/lib/embeds";
+
+describe("Code Block Round-trip Conversion", () => {
+  const turndown = new TurndownService({ headingStyle: "atx" });
+  addEmbedTurndownRule(turndown);
+
+  it("should preserve simple code blocks", () => {
+    const html = `<pre><code class="language-javascript">const x = 5;</code></pre>`;
+    const markdown = turndown.turndown(html);
+    expect(markdown).toContain("```javascript");
+    expect(markdown).toContain("const x = 5;");
+    expect(markdown).toContain("```");
+  });
+
+  it("should preserve collapsible code blocks (.cb-code)", () => {
+    const html = `<div class="cb-code collapsed" data-lines="10" data-preview-lines="2" data-collapse-kind="preview">
+      <pre class="cb-code__pre" style="--cb-preview-lines:2"><code class="language-javascript hljs">const x = 5;</code></pre>
+      <button class="cb-code__toggle" type="button" aria-label="Expand code"><svg class="cb-code__caret"></svg></button>
+    </div>`;
+    const markdown = turndown.turndown(html);
+    // Should preserve the code block content
+    expect(markdown).toContain("const x = 5;");
+    // Should not leak the toggle bar into markdown
+    expect(markdown).not.toContain("cb-code__caret");
+  });
+
+  it("should preserve expanded collapsible code blocks (.cb-code)", () => {
+    const html = `<div class="cb-code expanded" data-lines="10" data-preview-lines="2" data-collapse-kind="preview">
+      <pre class="cb-code__pre" style="--cb-preview-lines:2"><code class="language-javascript hljs">const x = 5;</code></pre>
+      <button class="cb-code__toggle" type="button" aria-label="Collapse code"><svg class="cb-code__caret"></svg></button>
+    </div>`;
+    const markdown = turndown.turndown(html);
+    expect(markdown).toContain("const x = 5;");
+    expect(markdown).toContain("```javascript preview=2");
+  });
+
+  it("should preserve multi-line code blocks", () => {
+    const html = `<pre><code class="language-javascript">const x = 5;
+const y = 10;
+const z = x + y;</code></pre>`;
+    const markdown = turndown.turndown(html);
+    expect(markdown).toContain("const x = 5;");
+    expect(markdown).toContain("const y = 10;");
+    expect(markdown).toContain("const z = x + y;");
+  });
+
+  it("should handle code blocks without language class", () => {
+    const html = `<pre><code>plain text code</code></pre>`;
+    const markdown = turndown.turndown(html);
+    expect(markdown).toContain("```");
+    expect(markdown).toContain("plain text code");
+  });
+
+  it("should preserve hljs class for syntax highlighted code", () => {
+    const html = `<pre><code class="hljs language-javascript">const x = 5;</code></pre>`;
+    const markdown = turndown.turndown(html);
+    expect(markdown).toContain("```javascript");
+    expect(markdown).toContain("const x = 5;");
+  });
+
+  it("should preserve preview=N parameter in code blocks", () => {
+    const html = `<div class="cb-code collapsed" data-lines="3" data-preview-lines="2" data-collapse-kind="preview">
+      <pre class="cb-code__pre" style="--cb-preview-lines:2"><code class="language-javascript hljs">const x = 5;
+const y = 10;
+const z = 15;</code></pre>
+      <button class="cb-code__toggle" type="button" aria-label="Expand code"><svg class="cb-code__caret"></svg></button>
+    </div>`;
+    const markdown = turndown.turndown(html);
+    expect(markdown).toContain("```javascript preview=2");
+    expect(markdown).toContain("const x = 5;");
+  });
+
+  it("should preserve a size preset together with preview=N", () => {
+    const html = `<div class="cb-code collapsed cb-code--size-small" data-lines="6" data-preview-lines="3" data-collapse-kind="preview" data-size="small" style="--cb-preview-lines:3">
+      <div class="cb-code__header"><span class="cb-code__lang-icon"><svg></svg></span><span class="cb-code__lang">TypeScript</span></div>
+      <pre class="cb-code__pre"><code class="language-typescript hljs">const a = 1;</code></pre>
+      <button class="cb-code__toggle" type="button"><svg class="cb-code__caret"></svg></button>
+    </div>`;
+    const markdown = turndown.turndown(html);
+    expect(markdown).toContain("```typescript small preview=3");
+    expect(markdown).toContain("const a = 1;");
+    // Header label must not leak into the markdown output.
+    expect(markdown).not.toContain("TypeScript");
+  });
+
+  it("should preserve a width= size on a non-collapsible block", () => {
+    const html = `<div class="cb-code cb-code--size-pixels" data-lines="1" data-size="width=300" style="max-width:300px;">
+      <div class="cb-code__header"><span class="cb-code__lang">Python</span></div>
+      <pre class="cb-code__pre"><code class="language-python hljs">x = 1</code></pre>
+    </div>`;
+    const markdown = turndown.turndown(html);
+    expect(markdown).toContain("```python width=300");
+    expect(markdown).toContain("x = 1");
+  });
+
+  it("should preserve collapse=N parameter (alias of preview)", () => {
+    const html = `<div class="cb-code collapsed" data-lines="3" data-preview-lines="2" data-collapse-kind="collapse">
+      <pre class="cb-code__pre" style="--cb-preview-lines:2"><code class="language-python hljs">a = 1
+b = 2
+c = 3</code></pre>
+      <button class="cb-code__toggle" type="button" aria-label="Expand code"><svg class="cb-code__caret"></svg></button>
+    </div>`;
+    const markdown = turndown.turndown(html);
+    expect(markdown).toContain("```python collapse=2");
+    expect(markdown).toContain("a = 1");
+  });
+});

diff --git a/tests/unit/grok-translation.test.ts b/tests/unit/grok-translation.test.ts
new file mode 100644
--- /dev/null
+++ b/tests/unit/grok-translation.test.ts
@@ -0,0 +1,383 @@
+/**
+ * Unit tests for the Grok translation pipeline.
+ *
+ * The pipeline translates article *Markdown* (not raw HTML) so that structural
+ * elements survive: fenced code blocks, `@[label](url)` embeds, image/link
+ * targets, and the `--END PREVIEW--` marker must all pass through untouched
+ * while prose is translated.
+ *
+ * Two committed fixtures are reused here (kept after creation):
+ *   - tests/fixtures/translation/article.html  â€” a representative source body
+ *   - tests/fixtures/translation/grok-result.md â€” a recorded Grok translation
+ * The live network call is never made; a recorded/mocked completion function is
+ * injected instead, keeping the suite deterministic and offline.
+ */
+import { readFileSync } from "fs";
+import { resolve } from "path";
+import {
+  htmlToTranslatableMarkdown,
+  markdownToHtml,
+  fillPromptTemplate,
+  buildTranslationPrompt,
+  buildTitlePrompt,
+  translateArticleBody,
+  chunkMarkdown,
+  extractCodeBlocks,
+  restoreCodeBlocks,
+  grokConfigured,
+  type CompletionFn,
+} from "@/lib/grok";
+
+const FIXTURES = resolve(__dirname, "../fixtures/translation");
+const articleHtml = readFileSync(resolve(FIXTURES, "article.html"), "utf8");
+const grokResultMd = readFileSync(resolve(FIXTURES, "grok-result.md"), "utf8");
+
+/**
+ * Recorded completion: body prompts contain "Markdown document", title prompts
+ * contain "blog article title". Code blocks are stripped before sending, so
+ * we can no longer use ``` to distinguish â€” use the prompt text instead.
+ */
+const recordedComplete: CompletionFn = async (prompt: string) =>
+  prompt.includes("Markdown document") ? grokResultMd : "Prise en main de cHackerBlog";
+
+describe("grok integration gating", () => {
+  it("reports configured when GROK_API_KEY is present (.env.test)", () => {
+    expect(grokConfigured()).toBe(true);
+  });
+});
+
+describe("htmlToTranslatableMarkdown (source HTML -> Markdown)", () => {
+  const md = htmlToTranslatableMarkdown(articleHtml);
+
+  it("reduces headings and prose to Markdown", () => {
+    expect(md).toContain("# Getting Started with cHackerBlog");
+    expect(md).toContain("## Installation");
+    expect(md).toContain("introduction paragraph");
+  });
+
+  it("preserves fenced code blocks with their language", () => {
+    expect(md).toContain("```ts");
+    expect(md).toContain('const greeting = "hello";');
+  });
+
+  it("collapses embeds back to the @[name](url) tag", () => {
+    expect(md).toContain("@[report.pdf](http://example.com/report.pdf)");
+  });
+
+  it("preserves the --END PREVIEW-- marker", () => {
+    expect(md).toContain("--END PREVIEW--");
+  });
+});
+
+describe("markdownToHtml (translated Markdown -> HTML)", () => {
+  const html = markdownToHtml(grokResultMd);
+
+  it("renders translated prose", () => {
+    expect(html).toContain("Prise en main de cHackerBlog");
+    expect(html).toContain("Ce contenu masquĂ©");
+  });
+
+  it("keeps code blocks intact and untranslated", () => {
+    expect(html).toContain("language-ts");
+    expect(html).toContain("const greeting =");
+  });
+
+  it("re-expands the embed tag to embed HTML", () => {
+    expect(html).toContain("data-embed");
+    expect(html).toContain("http://example.com/report.pdf");
+  });
+
+  it("re-renders the preview separator", () => {
+    expect(html).toContain("data-preview-end");
+  });
+});
+
+describe("prompt templating", () => {
+  it("substitutes all supported placeholders", () => {
+    const out = fillPromptTemplate("[{sourceLang}->{targetLang}] {sourceLocale}/{targetLocale}: {content}", {
+      sourceLocale: "en",
+      targetLocale: "fr",
+      sourceLang: "English",
+      targetLang: "French",
+      content: "BODY",
+    });
+    expect(out).toBe("[English->French] en/fr: BODY");
+  });
+
+  it("leaves unknown placeholders untouched", () => {
+    expect(
+      fillPromptTemplate("{content} {unknown}", {
+        sourceLocale: "en",
+        targetLocale: "fr",
+        sourceLang: "English",
+        targetLang: "French",
+        content: "X",
+      }),
+    ).toBe("X {unknown}");
+  });
+
+  it("buildTranslationPrompt names the human-readable languages", () => {
+    const md = htmlToTranslatableMarkdown(articleHtml);
+    const prompt = buildTranslationPrompt(md, "en", "fr");
+    expect(prompt).toContain("English");
+    expect(prompt).toContain("French");
+    expect(prompt).toContain("@[report.pdf](http://example.com/report.pdf)");
+  });
+
+  it("buildTitlePrompt carries the raw title as content", () => {
+    const prompt = buildTitlePrompt("Getting Started", "en", "de");
+    expect(prompt).toContain("Getting Started");
+    expect(prompt).toContain("German");
+  });
+});
+
+describe("translateArticleBody (end-to-end with recorded completion)", () => {
+  it("returns a translated title and structurally-preserved HTML body", async () => {
+    const result = await translateArticleBody({
+      title: "Getting Started with cHackerBlog",
+      contentHtml: articleHtml,
+      sourceLocale: "en",
+      targetLocale: "fr",
+      complete: recordedComplete,
+    });
+
+    // Title translated.
+    expect(result.title).toBe("Prise en main de cHackerBlog");
+    // Prose translated in the body.
+    expect(result.content).toContain("Ce contenu masquĂ©");
+    // Structure preserved through the round-trip.
+    expect(result.content).toContain("language-ts");
+    expect(result.content).toContain("data-embed");
+    expect(result.content).toContain("data-preview-end");
+    // Code blocks are highlighted server-side with hljs token spans and class.
+    expect(result.content).toContain("hljs");
+    expect(result.content).toContain("hljs-keyword");
+  });
+
+  it("keeps the original title when the model returns an empty string", async () => {
+    const emptyComplete: CompletionFn = async (prompt: string) =>
+      prompt.includes("Markdown document") ? grokResultMd : "   ";
+    const result = await translateArticleBody({
+      title: "Original Title",
+      contentHtml: articleHtml,
+      sourceLocale: "en",
+      targetLocale: "fr",
+      complete: emptyComplete,
+    });
+    expect(result.title).toBe("Original Title");
+  });
+});
+
+describe("translateArticleBody with multiple chunks", () => {
+  it("translates each chunk and reassembles correctly", async () => {
+    // Build a large HTML body that will produce markdown exceeding the default
+    // GROK_CHUNK_SIZE (1000 chars). Each paragraph is ~80 chars in markdown, so
+    // ~20 paragraphs will exceed 1000.
+    const paragraphs = Array.from({ length: 20 }, (_, i) =>
+      `<p>This is paragraph number ${i + 1} with enough text to fill a chunk nicely and then some more.</p>`
+    ).join("\n");
+    const largeHtml = `<h1>Large Article</h1>\n${paragraphs}`;
+
+    // Mock that "translates" by prefixing each chunk with [FR]
+    let callCount = 0;
+    const multiChunkComplete: CompletionFn = async (prompt: string) => {
+      callCount++;
+      // Title prompt contains "blog article title"
+      if (prompt.includes("blog article title")) {
+        return "Traduction du titre";
+      }
+      // Body prompt â€” return the content portion with a marker
+      const contentStart = prompt.indexOf("{content}");
+      const body = contentStart >= 0 ? prompt.slice(contentStart + 9) : prompt;
+      return `[FR] ` + body;
+    };
+
+    const result = await translateArticleBody({
+      title: "Large Article",
+      contentHtml: largeHtml,
+      sourceLocale: "en",
+      targetLocale: "fr",
+      complete: multiChunkComplete,
+    });
+
+    // Title should be translated
+    expect(result.title).toBe("Traduction du titre");
+    // Content should be HTML
+    expect(result.content).toContain("<p>");
+    // Multiple calls should have been made (title + at least 2 body chunks)
+    expect(callCount).toBeGreaterThan(2);
+  });
+});
+
+describe("extractCodeBlocks / restoreCodeBlocks", () => {
+  it("extracts fenced code blocks and replaces with placeholders", () => {
+    const md = "# Heading\n\nIntro text.\n\n```ts\nconst x = 1;\n```\n\nOutro text.\n";
+    const { markdown, codeBlocks } = extractCodeBlocks(md);
+
+    // Code block content is gone, replaced by placeholder
+    expect(markdown).not.toContain("const x = 1;");
+    expect(markdown).not.toContain("```ts");
+    expect(markdown).toContain("<!--CB0-->");
+    // Surrounding text is preserved
+    expect(markdown).toContain("# Heading");
+    expect(markdown).toContain("Intro text.");
+    expect(markdown).toContain("Outro text.");
+    // Code block is stored with fences and language tag
+    expect(codeBlocks).toHaveLength(1);
+    expect(codeBlocks[0]).toBe("```ts\nconst x = 1;\n```");
+  });
+
+  it("handles multiple code blocks", () => {
+    const md = "```js\nfoo()\n```\n\nText between.\n\n```python\nbar()\n```";
+    const { markdown, codeBlocks } = extractCodeBlocks(md);
+
+    expect(markdown).toContain("<!--CB0-->");
+    expect(markdown).toContain("<!--CB1-->");
+    expect(markdown).toContain("Text between.");
+    expect(codeBlocks).toHaveLength(2);
+    expect(codeBlocks[0]).toBe("```js\nfoo()\n```");
+    expect(codeBlocks[1]).toBe("```python\nbar()\n```");
+  });
+
+  it("handles markdown with no code blocks", () => {
+    const md = "# Just text\n\nNo code here.\n";
+    const { markdown, codeBlocks } = extractCodeBlocks(md);
+    expect(markdown).toBe(md);
+    expect(codeBlocks).toEqual([]);
+  });
+
+  it("restores code blocks verbatim", () => {
+    const md = "# Title\n\n```ts\nconst x = 1;\n```\n\nText.\n\n```py\nprint('hi')\n```";
+    const { markdown, codeBlocks } = extractCodeBlocks(md);
+    const restored = restoreCodeBlocks(markdown, codeBlocks);
+    expect(restored).toBe(md);
+  });
+
+  it("restores code blocks in translated content", () => {
+    // Simulate: extract, "translate" the prose, restore
+    const md = "# Title\n\n```ts\nconst x = 1;\n```\n\nSome text.\n";
+    const { markdown, codeBlocks } = extractCodeBlocks(md);
+    // Mock translation: just uppercase the non-code parts
+    const translated = markdown.toUpperCase();
+    const restored = restoreCodeBlocks(translated, codeBlocks);
+    // Code block should be back in original form
+    expect(restored).toContain("```ts");
+    expect(restored).toContain("const x = 1;");
+    // Translated prose is preserved
+    expect(restored).toContain("# TITLE");
+  });
+
+  it("handles 4-backtick fences from Turndown (code containing nested ```)", () => {
+    // Turndown uses 4-backtick fences when code content contains ``` lines
+    const md = "````ts\nlet x = 1;\n```nested\nfoo()\n```\nlet y = 2;\n````\n\nText.\n";
+    const { markdown, codeBlocks } = extractCodeBlocks(md);
+
+    // The entire code block should be extracted as one unit
+    expect(codeBlocks).toHaveLength(1);
+    expect(codeBlocks[0]).toBe(md.split("\n").slice(0, 7).join("\n"));
+    // The inner ``` lines should NOT appear in the stripped markdown
+    expect(markdown).not.toContain("```nested");
+    expect(markdown).not.toContain("foo()");
+    expect(markdown).not.toContain("let y = 2;");
+    // Placeholder should be present
+    expect(markdown).toContain("<!--CB0-->");
+    // Surrounding text preserved
+    expect(markdown).toContain("Text.");
+  });
+
+  it("round-trips 4-backtick code blocks through extract + restore", () => {
+    const md = "# Title\n\n````ts\nlet x = 1;\n```inner\nbar()\n```\nlet y = 2;\n````\n\nEnd.\n";
+    const { markdown, codeBlocks } = extractCodeBlocks(md);
+    const restored = restoreCodeBlocks(markdown, codeBlocks);
+    expect(restored).toBe(md);
+  });
+});
+
+describe("translated body survives a second HTML -> Markdown reduction", () => {
+  it("still contains code, embed, and preview marker", () => {
+    const html = markdownToHtml(grokResultMd);
+    const backToMd = htmlToTranslatableMarkdown(html);
+    expect(backToMd).toContain("```ts");
+    expect(backToMd).toContain("@[report.pdf](http://example.com/report.pdf)");
+    expect(backToMd).toContain("--END PREVIEW--");
+  });
+});
+
+describe("chunkMarkdown (line-boundary splitting)", () => {
+  it("returns a single chunk when content is under the limit", () => {
+    const md = "# Title\n\nShort paragraph.\n";
+    const chunks = chunkMarkdown(md, 4000);
+    expect(chunks).toHaveLength(1);
+    // chunkMarkdown adds \n to each chunk; the input's trailing \n is
+    // preserved because split removes the trailing "" and flush re-adds \n
+    expect(chunks[0]).toBe("# Title\n\nShort paragraph.\n");
+  });
+
+  it("splits on line boundaries when exceeding the limit", () => {
+    const lines = Array.from({ length: 10 }, (_, i) => `Line ${i + 1} with some text.`);
+    const md = lines.join("\n") + "\n";
+    // 10 lines * ~25 chars each = ~250 chars. Use maxChars=100 to force splitting.
+    const chunks = chunkMarkdown(md, 100);
+    expect(chunks.length).toBeGreaterThan(1);
+
+    // Reassembly should equal the original (trailing \n preserved by flush)
+    expect(chunks.join("")).toBe(md);
+
+    // No chunk (except possibly one containing a code block) should exceed
+    // the limit by more than the longest single line
+    for (const chunk of chunks) {
+      // Each chunk ends with \n, and the max line in this test is ~25 chars
+      // so no chunk should be wildly over the limit
+      expect(chunk.length).toBeLessThanOrEqual(100 + 30);
+    }
+  });
+
+  it("never splits through a fenced code block", () => {
+    const codeBlock = "```ts\n" + "x".repeat(200) + "\n```";
+    const md = `# Heading\n\nIntro paragraph.\n\n${codeBlock}\n\nOutro paragraph.\n`;
+    // Use a small maxChars that would normally split the code block
+    const chunks = chunkMarkdown(md, 80);
+
+    // Reassembly preserves the original
+    expect(chunks.join("")).toBe(md);
+
+    // Find the chunk containing the code block
+    const codeChunk = chunks.find((c) => c.includes("```ts"));
+    expect(codeChunk).toBeDefined();
+    // The code block must be intact within a single chunk
+    expect(codeChunk).toContain("```ts");
+    expect(codeChunk).toContain("```");
+  });
+
+  it("handles empty input", () => {
+    const chunks = chunkMarkdown("", 4000);
+    expect(chunks).toEqual([]);
+  });
+
+  it("handles single-line input", () => {
+    const chunks = chunkMarkdown("Just one line.", 4000);
+    expect(chunks).toHaveLength(1);
+    expect(chunks[0]).toBe("Just one line.\n");
+  });
+
+  it("each chunk ends with a newline", () => {
+    const lines = Array.from({ length: 20 }, (_, i) => `Line ${i + 1}.`);
+    const md = lines.join("\n") + "\n";
+    const chunks = chunkMarkdown(md, 50);
+    for (const chunk of chunks) {
+      expect(chunk.endsWith("\n")).toBe(true);
+    }
+  });
+
+  it("preserves embed tags within a single chunk", () => {
+    const embed = "@[report.pdf](http://example.com/report.pdf)";
+    const md = `# Heading\n\n${embed}\n\nParagraph after.\n`;
+    const chunks = chunkMarkdown(md, 50);
+    // Reassembly preserves content (flush adds trailing \n)
+    expect(chunks.join("")).toBe(md);
+    // The embed tag should be in one piece in some chunk
+    const embedChunk = chunks.find((c) => c.includes("@[report.pdf]"));
+    expect(embedChunk).toBeDefined();
+    expect(embedChunk).toContain("http://example.com/report.pdf");
+  });
+});


