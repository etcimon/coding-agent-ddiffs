+import { useI18n } from "@/lib/use-i18n";
+import { buildLocalePath, DEFAULT_LOCALE } from "@/lib/i18n";
+import { CommentBar } from "@/components/comment-bar";
+import { useCommentsEnabled } from "@/lib/use-comments-enabled";
+import {
+  ensureHighlightJsReady,
+  highlightCodeInElement,
+  wireCodeBlockToggles,
+  type CodeToggleOptions,
+} from "@/lib/highlight";
+import { hydrateLinkEmbeds } from "@/lib/link-embeds";
+
+// useLayoutEffect on the server logs a warning; fall back to useEffect there.
+const useIsoLayoutEffect = typeof window !== "undefined" ? useLayoutEffect : useEffect;
#   ... omitted lines 37-43 ...
@@ lines 44-137 @@
+export function ArticleCard({ item, expanded = false, onEdit }: Props) {
+  const [open, setOpen] = useState(expanded);
+  const [expandedDone, setExpandedDone] = useState(false);
+  const [content, setContent] = useState<string | undefined>(item.content);
+  const [loading, setLoading] = useState(false);
+  const [pinned, setPinned] = useState(item.pinned);
+  const [pinning, setPinning] = useState(false);
+  const [published, setPublished] = useState(item.published);
+  const [publishing, setPublishing] = useState(false);
+  // Translation state (Grok-powered). `translated` toggles the view between the
+  // original body/title and the fetched translation for the visitor's locale.
+  const [translated, setTranslated] = useState(false);
+  const [translating, setTranslating] = useState(false);
+  const [translatedTitle, setTranslatedTitle] = useState<string | undefined>(undefined);
+  const [translatedContent, setTranslatedContent] = useState<string | undefined>(undefined);
+  const toast = useToast();
+  const { isAdmin } = useAdmin();
+  const config = useSiteConfig();
+  const { locale: userLocale, t } = useI18n();
+  const commentsEnabled = useCommentsEnabled();
+  const defaultLocale = config?.defaultLocale ?? DEFAULT_LOCALE;
+  const articleHref = buildLocalePath(`/article/${item.slug}`, userLocale, defaultLocale);
+  const articleBodyRef = useRef<HTMLDivElement>(null);
+  // Remembers which code blocks the reader expanded, keyed by block index, so
+  // the state survives content re-injection (e.g. after an admin edit refresh).
+  const expandedBlocksRef = useRef<Set<number>>(new Set());
+
+  // Keep the rendered body in sync with the feed item's content. Without this,
+  // an article edited in the WYSIWYG keeps showing the stale body (useState only
+  // reads its initial value once). Guard on `undefined` so lazily fetched
+  // bodies (item.content omitted by the feed API) are not wiped.
+  useEffect(() => {
+    if (item.content !== undefined) setContent(item.content);
+  }, [item.content]);
+
+  const codeToggleOptions = useMemo<CodeToggleOptions>(
+    () => ({
+      isExpanded: (i) => expandedBlocksRef.current.has(i),
+      onToggle: (i, expanded) => {
+        if (expanded) expandedBlocksRef.current.add(i);
+        else expandedBlocksRef.current.delete(i);
+      },
+    }),
+    [],
+  );
+
+  // What to render in the article body: the full content when open, otherwise
+  // the HTML preview (present only when the article defines a `--END PREVIEW--`
+  // separator). Undefined means "nothing to render yet" (e.g. body not fetched).
+  // Whether the Grok "show translation" affordance applies: the integration is
+  // configured and the visitor's resolved locale (from the /[lang]/ URL prefix,
+  // browser, or site policy) differs from the article's own language.
+  const canTranslate = !!config?.grokConfigured && userLocale !== item.locale;
+
+  const displayTitle = translated && translatedTitle !== undefined ? translatedTitle : item.title;
+
+  // When showing a translation we always render the full translated body;
+  // otherwise the original full content (when open) or the preview HTML.
+  const bodyHtml =
+    translated && translatedContent !== undefined
+      ? translatedContent
+      : open
+        ? content
+        : item.previewHtml;
+
+  // Wire the collapse toggles synchronously after every body (re-)render. Doing
+  // this in a layout effect (not gated behind async highlighting) guarantees the
+  // toggles work no matter how many code blocks/languages are present, and
+  // re-applies the persisted expanded state before paint so it never flickers
+  // back to collapsed.
+  useIsoLayoutEffect(() => {
+    if (bodyHtml !== undefined && articleBodyRef.current) {
+      wireCodeBlockToggles(articleBodyRef.current, codeToggleOptions);
+      hydrateLinkEmbeds(articleBodyRef.current);
+    }
+  }, [bodyHtml, codeToggleOptions]);
+
+  // Apply syntax highlighting asynchronously (lazy-loads hljs + languages), then
+  // re-wire/restore in case highlighting replaced any markup. The stale flag
+  // ensures that if bodyHtml changes before the promise resolves (e.g. user
+  // toggles translation while hljs is still loading), the stale callback is
+  // skipped and only the latest bodyHtml gets highlighted.
+  useEffect(() => {
+    let stale = false;
+    if (bodyHtml !== undefined && articleBodyRef.current) {
+      ensureHighlightJsReady(bodyHtml).then(() => {
+        if (!stale && articleBodyRef.current) {
+          highlightCodeInElement(articleBodyRef.current);
+          wireCodeBlockToggles(articleBodyRef.current, codeToggleOptions);
+        }
+      });
+    }
+    return () => { stale = true; };
+  }, [bodyHtml, codeToggleOptions]);
#   ... omitted lines 138-198 ...
@@ lines 199-233 @@
+  const handleTranslate = useCallback(async () => {
+    if (translated) {
+      setTranslated(false);
+      return;
+    }
+    // Reuse a previously fetched translation without another round-trip.
+    if (translatedContent !== undefined) {
+      setExpandedDone(false);
+      setTranslated(true);
+      setOpen(true);
+      return;
+    }
+    setTranslating(true);
+    try {
+      const data = await api.translateArticle<{
+        enabled: boolean;
+        locale?: string;
+        title?: string;
+        content?: string;
+      }>(item.id, userLocale);
+      if (!data.enabled || data.content === undefined) {
+        toast.error(t("translation.failed"));
+        return;
+      }
+      setTranslatedTitle(data.title);
+      setTranslatedContent(data.content);
+      setExpandedDone(false);
+      setTranslated(true);
+      setOpen(true);
+    } catch (err) {
+      toast.error(err instanceof ApiClientError ? err.message : t("translation.failed"));
+    } finally {
+      setTranslating(false);
+    }
+  }, [translated, translatedContent, item.id, userLocale, toast, t]);
#   ... omitted lines 234-291 ...
@@ lines 292-338 @@
+        {canTranslate && (
+          <button
+            onClick={handleTranslate}
+            disabled={translating}
+            className="mb-2 inline-flex items-center gap-1.5 rounded-md border border-border px-3 py-1 text-xs text-muted transition-colors hover:text-accent disabled:opacity-50"
+            title={translated ? t("translation.showOriginal") : t("translation.show")}
+          >
+            <Languages className="h-3.5 w-3.5" />
+            {translating
+              ? t("translation.translating")
+              : translated
+                ? `${t("translation.translated")} ${t("translation.showOriginal")}`
+                : t("translation.show")}
+          </button>
+        )}
+        <h2 className="font-heading text-3xl font-bold leading-tight text-fg">
+          <a
+            href={articleHref}
+            className="transition-colors hover:text-accent"
+          >
+            {displayTitle}
+          </a>
+        </h2>
+        <p className="mt-1 text-sm text-muted">{date}</p>
+      </header>
+
+      {item.coverUrl && (
+        // eslint-disable-next-line @next/next/no-img-element
+        <img
+          src={item.coverUrl}
+          alt={item.title}
+          className="mb-4 w-full rounded-lg border border-border object-cover"
+        />
+      )}
+
+      {!open && !item.previewHtml && (
+        <p className="text-lg leading-relaxed text-fg/90">{item.preview}</p>
+      )}
+
+      {bodyHtml !== undefined && (
+        <div
+          ref={articleBodyRef}
+          className={`article-body article-rendered text-lg text-fg/90${open && !expandedDone ? " animate-expand overflow-hidden" : ""}`}
+          onAnimationEnd={() => setExpandedDone(true)}
+          dangerouslySetInnerHTML={{ __html: bodyHtml }}
+        />
+      )}

diff --git a/src/app/api/upload/route.ts b/src/app/api/upload/route.ts
new file mode 100644
--- /dev/null
+++ b/src/app/api/upload/route.ts
@@ -0,0 +1,73 @@
+/**
+ * File upload endpoint (admin only). Accepts multipart/form-data with a `file`
+ * field, validates type/size, writes to UPLOAD_DIR (self-hosted under /public),
+ * and returns the public URL for in-place insertion into a new article.
+ *
+ * Supports images plus the attachment types in `ALLOWED_FILE_EXTS` (documents,
+ * spreadsheets, slides, archives, video, audio). Validation prefers the file
+ * extension (browser MIME types are unreliable for office/archive formats) and
+ * falls back to the reported MIME type for images.
+ */
+import { writeFile, mkdir } from "node:fs/promises";
+import path from "node:path";
+import { randomBytes } from "node:crypto";
+import { handler, ok, AppError } from "@/lib/errors";
+import { requireAdmin } from "@/lib/auth";
+import { env } from "@/lib/env";
+import { ALLOWED_FILE_EXTS, extOf } from "@/lib/embeds";
+
+export const runtime = "nodejs";
+
+// Allow large file uploads (up to 1GB as configured by UPLOAD_MAX_SIZE env var).
+export const config = {
+  bodySizeLimit: "1gb",
+};
+
+// Image MIME -> canonical extension (kept for the existing image button).
+const IMAGE_MIME = new Map<string, string>([
+  ["image/jpeg", "jpg"],
+  ["image/png", "png"],
+  ["image/gif", "gif"],
+  ["image/webp", "webp"],
+  ["image/svg+xml", "svg"],
+]);
+
+const ALLOWED_EXTS = new Set<string>([
+  "jpg",
+  "jpeg",
+  "png",
+  "gif",
+  "webp",
+  "svg",
+  ...ALLOWED_FILE_EXTS,
+]);
+
+export const POST = handler(async (req: Request) => {
+  await requireAdmin();
+
+  const form = await req.formData();
+  const file = form.get("file");
+  if (!(file instanceof File)) {
+    throw new AppError("No file provided", 400, "NO_FILE");
+  }
+  // Resolve extension from the filename first, then fall back to image MIME.
+  let ext = extOf(file.name);
+  if (!ext || !ALLOWED_EXTS.has(ext)) {
+    ext = IMAGE_MIME.get(file.type) ?? "";
+  }
+  if (!ext || !ALLOWED_EXTS.has(ext)) {
+    throw new AppError("Unsupported file type", 415, "UNSUPPORTED_TYPE");
+  }
+  if (file.size > env.UPLOAD_MAX_SIZE) {
+    throw new AppError("File too large", 413, "TOO_LARGE");
+  }
+
+  const buffer = Buffer.from(await file.arrayBuffer());
+  const name = `${Date.now()}-${randomBytes(6).toString("hex")}.${ext}`;
+  const dir = path.resolve(env.UPLOAD_DIR);
+  await mkdir(dir, { recursive: true });
+  await writeFile(path.join(dir, name), buffer);
+
+  // UPLOAD_DIR lives under /public, so the public URL is /api/uploads/<name>.
+  return ok({ url: `/api/uploads/${name}` }, 201);
+});

diff --git a/src/app/api/uploads/[...path]/route.ts b/src/app/api/uploads/[...path]/route.ts
new file mode 100644
--- /dev/null
+++ b/src/app/api/uploads/[...path]/route.ts
@@ -0,0 +1,55 @@
+import { NextRequest, NextResponse } from 'next/server';
+import { readFile, stat } from 'fs/promises';
+import { join } from 'path';
+import { existsSync } from 'fs';
+import { CONTENT_TYPES } from '@/lib/embeds';
+
+export const runtime = 'nodejs';
+
+export async function GET(
+  request: NextRequest,
+  { params }: { params: Promise<{ path: string[] }> }
+) {
+  const uploadDir = process.env.UPLOAD_DIR || './public/uploads';
+  const { path } = await params;
+  const filePath = join(process.cwd(), uploadDir, ...path);
+  
+  // Security check: ensure the path is within the upload directory
+  const resolvedPath = join(process.cwd(), uploadDir);
+  if (!filePath.startsWith(resolvedPath)) {
+    return new NextResponse('Forbidden', { status: 403 });
+  }
+  
+  // Check if file exists
+  if (!existsSync(filePath)) {
+    return new NextResponse('Not Found', { status: 404 });
+  }
+  
+  // Check if it's a file (not a directory)
+  const stats = await stat(filePath);
+  if (stats.isDirectory()) {
+    return new NextResponse('Not Found', { status: 404 });
+  }
+  
+  // Read file
+  try {
+    const file = await readFile(filePath);
+    
+    // Determine content type based on extension (shared registry).
+    const ext = filePath.split('.').pop()?.toLowerCase();
+    const contentType = CONTENT_TYPES[ext || ''] || 'application/octet-stream';
+    
+    // Cache headers
+    const response = new NextResponse(file, {
+      headers: {
+        'Content-Type': contentType,
+        'Cache-Control': 'public, max-age=2592000, immutable', // 30 days
+        'X-Content-Type-Options': 'nosniff',
+      },
+    });
+    
+    return response;
+  } catch (error) {
+    return new NextResponse('Internal Server Error', { status: 500 });
+  }
+}

diff --git a/src/app/api/highlightjs/[...path]/route.ts b/src/app/api/highlightjs/[...path]/route.ts
new file mode 100644
--- /dev/null
+++ b/src/app/api/highlightjs/[...path]/route.ts
@@ -0,0 +1,51 @@
+/**
+ * API endpoint to serve highlight.js CSS and JS files from node_modules.
+ * This allows dynamic loading of highlight.js resources without exposing
+ * the node_modules directory directly.
+ */
+import { NextRequest, NextResponse } from "next/server";
+import { readFile } from "fs/promises";
+import { join } from "path";
+
+export const runtime = "nodejs";
+
+export async function GET(
+  request: NextRequest,
+  { params }: { params: Promise<{ path: string[] }> }
+) {
+  const { path } = await params;
+  const filePath = path.join("/");
+
+  // Security: ensure the path doesn't escape node_modules/highlight.js
+  if (filePath.includes("..") || filePath.includes("\\")) {
+    return NextResponse.json({ error: "Invalid path" }, { status: 400 });
+  }
+
+  try {
+    // Resolve the file path from node_modules/highlight.js
+    const fullPath = join(process.cwd(), "node_modules", "highlight.js", filePath);
+
+    // Read the file
+    const fileContent = await readFile(fullPath);
+
+    // Determine content type based on file extension
+    const ext = filePath.split(".").pop();
+    const contentTypeMap: Record<string, string> = {
+      js: "application/javascript",
+      css: "text/css",
+      json: "application/json",
+    };
+    const contentType = contentTypeMap[ext || ""] || "application/octet-stream";
+
+    // Return the file with appropriate headers
+    return new NextResponse(fileContent, {
+      headers: {
+        "Content-Type": contentType,
+        "Cache-Control": "public, max-age=31536000, immutable", // Cache for 1 year
+      },
+    });
+  } catch (error) {
+    console.error(`Failed to serve highlight.js file: ${filePath}`, error);
+    return NextResponse.json({ error: "File not found" }, { status: 404 });
+  }
+}

diff --git a/src/app/api/link-preview/route.ts b/src/app/api/link-preview/route.ts
new file mode 100644
--- /dev/null
+++ b/src/app/api/link-preview/route.ts
@@ -0,0 +1,86 @@
+/**
+ * Link-preview metadata endpoint.
+ *
+ * GET /api/link-preview?url=<external http(s) URL>
+ *
+ * Fetches the target page and extracts Open Graph / Twitter Card / <title>
+ * metadata for the generic link-embed card (thumbnail, title, description,
+ * site name). Recognized platform URLs (YouTube, SoundCloud, â€¦) never reach
+ * this endpoint â€” they render deterministically via `ext-embeds` â€” so this is
+ * strictly the fallback path.
+ *
+ * Safety:
+ *  - IP-rate-limited (scope "linkpreview") to blunt abuse,
+ *  - SSRF-guarded: only http(s), and the resolved address must be public
+ *    (private / loopback / link-local ranges are rejected),
+ *  - response is capped in size and time, and only text/html is parsed.
+ */
+import { handler, ok, AppError, Errors } from "@/lib/errors";
+import { getClientIp, rateLimit } from "@/lib/rate-limit";
+import { assertSafeUrl, parseHtmlMeta, type LinkPreview } from "@/lib/link-preview";
+
+export const runtime = "nodejs";
+
+/** Max bytes of HTML we will read before bailing (metadata lives in <head>). */
+const MAX_BYTES = 512 * 1024;
+/** Fetch timeout. */
+const TIMEOUT_MS = 6000;
+
+export const GET = handler(async (req: Request) => {
+  const ip = getClientIp(req.headers);
+  const rl = await rateLimit(ip, "linkpreview", { max: 30, windowSeconds: 60 });
+  if (!rl.allowed) throw Errors.rateLimited();
+
+  const raw = new URL(req.url).searchParams.get("url");
+  if (!raw) throw new AppError("Missing url parameter", 400, "MISSING_URL");
+
+  const target = await assertSafeUrl(raw);
+
+  const controller = new AbortController();
+  const timer = setTimeout(() => controller.abort(), TIMEOUT_MS);
+  let res: Response;
+  try {
+    res = await fetch(target.href, {
+      signal: controller.signal,
+      redirect: "follow",
+      headers: {
+        // A desktop UA elicits richer OG tags from many sites.
+        "user-agent":
+          "Mozilla/5.0 (compatible; cHackerBlog-LinkPreview/1.0; +https://github.com/etcimon)",
+        accept: "text/html,application/xhtml+xml",
+      },
+    });
+  } catch {
+    clearTimeout(timer);
+    throw new AppError("Failed to fetch the URL", 502, "FETCH_FAILED");
+  }
+  clearTimeout(timer);
+
+  const contentType = res.headers.get("content-type") || "";
+  if (!/text\/html|application\/xhtml\+xml/i.test(contentType)) {
+    // Not an HTML page (e.g. a direct file). Nothing to preview; return bare.
+    return ok<LinkPreview>({ url: target.href });
+  }
+
+  // Read up to MAX_BYTES so we never buffer an enormous document.
+  const reader = res.body?.getReader();
+  let html = "";
+  if (reader) {
+    const decoder = new TextDecoder();
+    let received = 0;
+    for (;;) {
+      const { done, value } = await reader.read();
+      if (done) break;
+      received += value.byteLength;
+      html += decoder.decode(value, { stream: true });
+      if (received >= MAX_BYTES || /<\/head>/i.test(html)) {
+        await reader.cancel().catch(() => {});
+        break;
+      }
+    }
+  } else {
+    html = (await res.text()).slice(0, MAX_BYTES);
+  }
+
+  return ok<LinkPreview>(parseHtmlMeta(html, target.href));
+});

diff --git a/src/app/api/articles/[id]/translate/route.ts b/src/app/api/articles/[id]/translate/route.ts
new file mode 100644
--- /dev/null
+++ b/src/app/api/articles/[id]/translate/route.ts
@@ -0,0 +1,67 @@
+/**
+ * Article translation endpoint.
+ *   POST { locale } -> translated { title, content } for the given target locale.
+ *
+ * Gated on the Grok integration being configured; when it is not, the route
+ * reports `enabled: false` so the client simply never renders the affordance.
+ * Reads through the translation cache -> ArticleTranslation table -> Grok.
+ */
+import { z } from "zod";
+import { handler, ok, Errors, AppError } from "@/lib/errors";
+import { getArticleTranslationSource } from "@/lib/articles";
+import { translateArticle } from "@/lib/grok";
+import { grokConfigured } from "@/lib/env";
+import { isSupportedLocale, type Locale } from "@/lib/i18n";
+import { isAdmin } from "@/lib/auth";
+
+export const runtime = "nodejs";
+
+type Ctx = { params: Promise<{ id: string }> };
+
+const bodySchema = z.object({
+  locale: z.custom<Locale>(isSupportedLocale, "Unsupported locale"),
+});
+
+export const POST = handler<Ctx>(async (req, { params }) => {
+  const { id } = await params;
+
+  if (!grokConfigured()) {
+    return ok({ enabled: false as const });
+  }
+
+  const json = await req.json().catch(() => ({}));
+  const { locale } = bodySchema.parse(json);
+
+  const admin = await isAdmin();
+  const source = await getArticleTranslationSource(id, { includeUnpublished: admin });
+  if (!source) throw Errors.notFound("Article not found");
+
+  let result;
+  try {
+    result = await translateArticle({
+      articleId: source.id,
+      targetLocale: locale,
+      title: source.title,
+      contentHtml: source.content,
+      sourceLocale: source.locale,
+    });
+  } catch (err) {
+    const message = err instanceof Error ? err.message : "Translation failed";
+
+    // Rate limit exceeded -> 429 Too Many Requests
+    if (message.includes("rate limit exceeded")) {
+      throw new AppError(message, 429, "RATE_LIMIT_EXCEEDED");
+    }
+
+    // Upstream (Grok) failure -> 502 Bad Gateway with the real reason so the
+    // client toast is actionable (e.g. invalid GROK_MODEL / GROK_API_KEY).
+    throw new AppError(message, 502, "GROK_ERROR");
+  }
+
+  return ok({
+    enabled: true as const,
+    locale: result.locale,
+    title: result.title,
+    content: result.content,
+  });
+});

diff --git a/prisma/schema.prisma b/prisma/schema.prisma
new file mode 100644
--- /dev/null
+++ b/prisma/schema.prisma
# NOTE: Only the models the subsystem touches: Article (rich HTML body + translation-rate fields) and ArticleTranslation. SiteSettings/Tag/Comment omitted (Article still references Tag[]/Comment[] relations â€” drop or stub those lines in the target).
@@ lines 1-16 @@
+// cHackerBlog data layer.
+//
+// NOTE on multi-provider: Prisma's `datasource.provider` must be a string
+// literal (it cannot read env()). For local development it is "sqlite"; for
+// production deploys swap it to "postgresql" (the models below are written to
+// be compatible with both â€” no enums, no native arrays, JSON stored as String).
+// The `url` is env-driven via DATABASE_URL.
+
+generator client {
+  provider = "prisma-client"
+  output   = "../src/generated/prisma/client"
+}
+
+datasource db {
+  provider = "sqlite"
+}
#   ... omitted lines 17-54 ...
@@ lines 55-123 @@
+/// A blog article. Feed is ordered by `publishedAt` desc and filtered by tag.
+/// `locale` allows multilingual entries (one row per language variant).
+model Article {
+  id          String    @id @default(cuid()) @map("id")
+  slug        String    @unique @map("slug")
+  locale      String    @default("en") @map("locale")
+
+  title       String    @map("title")
+  // Full rich HTML body produced by the WYSIWYG editor.
+  content     String    @default("") @map("content")
+  coverUrl    String?   @map("cover_url")
+
+  // --- Auto-derived SEO / social metadata (no manual editing) --------------
+  // Recomputed on every create/update by lib/seo.ts. Stored (not computed on
+  // read) so feed/article cache and per-article OG <meta> stay cheap. Keywords
+  // are a comma-separated String (SQLite has no native arrays â€” see header).
+  seoKeywords    String  @default("") @map("seo_keywords")
+  seoDescription String  @default("") @map("seo_description")
+  // Resolved share image: explicit coverUrl -> first content <img> -> favicon.
+  thumbnailUrl   String? @map("thumbnail_url")
+
+  published   Boolean   @default(true) @map("published")
+  publishedAt DateTime  @default(now()) @map("published_at")
+  createdAt   DateTime  @default(now()) @map("created_at")
+  updatedAt   DateTime  @updatedAt @map("updated_at")
+
+  // Pinning: pinned articles appear first in the feed, ordered by pinnedAt desc
+  pinned      Boolean   @default(false) @map("pinned")
+  pinnedAt    DateTime? @map("pinned_at")
+
+  // Translation rate limiting: track daily translation count per article
+  translationCount    Int      @default(0) @map("translation_count")
+  lastTranslationAt   DateTime? @map("last_translation_at")
+
+  tags         Tag[]                @relation("ArticleTags")
+  comments     Comment[]
+  translations ArticleTranslation[]
+
+  @@map("articles")
+  @@index([published, publishedAt, pinned, pinnedAt])
+  @@index([locale])
+  @@index([slug])
+  @@index([pinned, pinnedAt, publishedAt])
+  @@index([published])
+}
+
+/// A cached/persisted machine translation of an article into a target locale.
+/// Produced on demand by lib/grok.ts. `content` stores translated HTML (the
+/// canonical body representation), `title` the translated title. Exactly one
+/// row per (article, locale). Cascade-deleted with the source article and
+/// wiped on source edits so a stale revision is never served.
+model ArticleTranslation {
+  id           String   @id @default(cuid()) @map("id")
+  articleId    String   @map("article_id")
+  article      Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
+
+  locale       String   @map("locale")
+  sourceLocale String   @default("en") @map("source_locale")
+  title        String   @map("title")
+  content      String   @map("content")
+  published    Boolean  @default(true) @map("published")
+
+  createdAt    DateTime @default(now()) @map("created_at")
+  updatedAt    DateTime @updatedAt @map("updated_at")
+
+  @@unique([articleId, locale])
+  @@map("article_translations")
+  @@index([articleId, locale])
+}

diff --git a/src/styles/themes/_tokens.scss b/src/styles/themes/_tokens.scss
new file mode 100644
--- /dev/null
+++ b/src/styles/themes/_tokens.scss
@@ -0,0 +1,17 @@
+// Token contract shared by every theme. A theme is a Sass map of logical
+// tokens; `emit()` writes them as the --cb-* custom properties that Tailwind
+// consumes (see tailwind.config.ts). Colors are space-separated "r g b"
+// triplets so Tailwind's `rgb(var(--cb-x) / <alpha-value>)` works.
+@use "sass:map";
+
+@mixin emit($t) {
+  --cb-bg: #{map.get($t, bg)};
+  --cb-fg: #{map.get($t, fg)};
+  --cb-accent: #{map.get($t, accent)};
+  --cb-muted: #{map.get($t, muted)};
+  --cb-card: #{map.get($t, card)};
+  --cb-border: #{map.get($t, border)};
+  --cb-font-body: #{map.get($t, font-body)};
+  --cb-font-heading: #{map.get($t, font-heading)};
+  --cb-font-mono: #{map.get($t, font-mono)};
+}

diff --git a/src/styles/themes/_palettes.scss b/src/styles/themes/_palettes.scss
new file mode 100644
--- /dev/null
+++ b/src/styles/themes/_palettes.scss
@@ -0,0 +1,45 @@
+// Theme palettes (the "subsets"). `$substack` is intentionally derived from
+// `$medium` via map.merge â€” Substack is a Medium-style theme with a different
+// accent, warmer paper background, and a serif display face. This is the
+// "extending medium-style to substack style" relationship in one place.
+@use "sass:map";
+
+// --- Hacker terminal: green-on-black monospace ------------------------------
+$hacker: (
+  bg: "0 0 0",
+  fg: "51 255 102",
+  accent: "0 255 153",
+  muted: "20 80 40",
+  card: "8 12 8",
+  border: "20 60 30",
+  font-body: "'JetBrains Mono', ui-monospace, SFMono-Regular, monospace",
+  font-heading: "'JetBrains Mono', ui-monospace, SFMono-Regular, monospace",
+  font-mono: "'JetBrains Mono', ui-monospace, SFMono-Regular, monospace",
+);
+
+// --- Medium: clean white, serif body, green accent --------------------------
+$medium: (
+  bg: "255 255 255",
+  fg: "41 41 41",
+  accent: "26 137 23",
+  muted: "117 117 117",
+  card: "255 255 255",
+  border: "230 230 230",
+  font-body: "Georgia, 'Times New Roman', Times, serif",
+  font-heading: "'Helvetica Neue', Helvetica, Arial, sans-serif",
+  font-mono: "'SFMono-Regular', Menlo, Consolas, monospace",
+);
+
+// --- Substack: extends Medium (warm paper, orange accent, serif display) ----
+$substack: map.merge(
+  $medium,
+  (
+    bg: "255 255 255",
+    fg: "30 30 28",
+    accent: "255 102 0",
+    muted: "107 107 107",
+    card: "253 251 247",
+    border: "234 230 222",
+    font-heading: "'Spectral', Georgia, 'Times New Roman', serif",
+  )
+);

diff --git a/src/styles/themes/_themes.scss b/src/styles/themes/_themes.scss
new file mode 100644
--- /dev/null
+++ b/src/styles/themes/_themes.scss
@@ -0,0 +1,171 @@
+// Emits each palette as a [data-theme="â€¦"] block of --cb-* custom properties.
+// The layout sets <html data-theme> from the THEME env var; :root defaults to
+// the hacker terminal so the page is styled even before hydration.
+@use "tokens";
+@use "palettes";
+
+:root {
+  @include tokens.emit(palettes.$hacker);
+}
+
+[data-theme="hacker"] {
+  @include tokens.emit(palettes.$hacker);
+
+  // Terminal vibe: tighter, glowing collapse bar with a slim mono feel.
+  .article-body {
+    --cb-code-bar: 1.85rem;
+    .cb-code,
+    .cb-code__pre {
+      border-radius: 0.375rem;
+    }
+    .cb-code__toggle {
+      letter-spacing: 0.04em;
+    }
+    .cb-code__toggle:hover {
+      color: rgb(var(--cb-accent));
+      background: rgb(var(--cb-accent) / 0.12);
+    }
+  }
+
+  // Share modal: sharp, neon-glow terminal panel with uppercase mono labels.
+  .share-modal {
+    border-radius: 0.5rem;
+    box-shadow: 0 0 0 1px rgb(var(--cb-accent) / 0.25),
+      0 0 28px rgb(var(--cb-accent) / 0.18);
+  }
+  .share-net {
+    border-radius: 0.375rem;
+    font-family: var(--cb-font-mono);
+    text-transform: uppercase;
+    letter-spacing: 0.04em;
+  }
+  .share-net:hover {
+    box-shadow: 0 0 14px rgb(var(--cb-accent) / 0.3);
+  }
+  .share-native {
+    text-transform: uppercase;
+    letter-spacing: 0.06em;
+  }
+
+  // Feed loader: neon-glow terminal hacker vibe.
+  .feed-loader__cursor {
+    box-shadow: 0 0 6px rgb(var(--cb-accent) / 0.8);
+  }
+  .feed-loader__bar-fill {
+    box-shadow: 0 0 8px rgb(var(--cb-accent) / 0.6);
+  }
+  .feed-loader__dot {
+    box-shadow: 0 0 4px rgb(var(--cb-accent) / 0.5);
+  }
+  .feed-loader__terminal {
+    text-transform: uppercase;
+    letter-spacing: 0.06em;
+  }
+
+  // Feed next button: sharp, glowing terminal accent.
+  .feed-next-btn {
+    border-radius: 0.375rem;
+    box-shadow: 0 0 0 1px rgb(var(--cb-accent) / 0.2),
+      0 0 16px rgb(var(--cb-accent) / 0.15);
+  }
+  .feed-next-btn:hover {
+    box-shadow: 0 0 0 1px rgb(var(--cb-accent) / 0.4),
+      0 0 24px rgb(var(--cb-accent) / 0.25);
+  }
+}
+
+[data-theme="medium"] {
+  @include tokens.emit(palettes.$medium);
+
+  // Feed loader: soft, editorial sans-serif feel.
+  .feed-loader {
+    font-family: var(--cb-font-body);
+  }
+  .feed-loader__bar {
+    height: 3px;
+    border-radius: 999px;
+  }
+  .feed-loader__bar-fill {
+    border-radius: 999px;
+  }
+
+  // Editorial: roomier bar and softer, paper-like rounded code surface.
+  .article-body {
+    --cb-code-bar: 2.25rem;
+    .cb-code,
+    .cb-code__pre {
+      border-radius: 0.75rem;
+    }
+  }
+
+  // Share modal: soft, generously rounded editorial sheet with a gentle shadow.
+  .share-modal {
+    border-radius: 1rem;
+    box-shadow: 0 20px 50px rgb(0 0 0 / 0.18);
+  }
+  .share-net {
+    border-radius: 0.875rem;
+  }
+  .share-net:hover {
+    box-shadow: 0 8px 20px rgb(0 0 0 / 0.1);
+  }
+
+  // Feed next button: soft, generously rounded editorial button.
+  .feed-next-btn {
+    border-radius: 1rem;
+    box-shadow: 0 4px 12px rgb(0 0 0 / 0.1);
+  }
+  .feed-next-btn:hover {
+    box-shadow: 0 8px 20px rgb(0 0 0 / 0.15);
+  }
+}
+
+[data-theme="substack"] {
+  @include tokens.emit(palettes.$substack);
+
+  // Feed loader: warm, paper-like serif feel.
+  .feed-loader {
+    font-family: var(--cb-font-body);
+  }
+  .feed-loader__bar {
+    height: 3px;
+  }
+  .feed-loader__bar-fill {
+    border-radius: 999px;
+  }
+
+  // Inherits Medium's editorial code chrome with the warm Substack accent.
+  .article-body {
+    --cb-code-bar: 2.25rem;
+    .cb-code,
+    .cb-code__pre {
+      border-radius: 0.75rem;
+    }
+  }
+
+  // Share modal: warm paper sheet; tinted preview + accent-tinted hover.
+  .share-modal {
+    border-radius: 1rem;
+    box-shadow: 0 20px 50px rgb(0 0 0 / 0.12);
+  }
+  .share-preview {
+    background: rgb(var(--cb-accent) / 0.05);
+  }
+  .share-net {
+    border-radius: 0.875rem;
+  }
+  .share-net:hover {
+    background: rgb(var(--cb-accent) / 0.06);
+    box-shadow: 0 8px 20px rgb(0 0 0 / 0.08);
+  }
+
+  // Feed next button: warm, rounded button with accent-tinted hover.
+  .feed-next-btn {
+    border-radius: 1rem;
+    box-shadow: 0 4px 12px rgb(0 0 0 / 0.08);
+  }
+  .feed-next-btn:hover {
+    background: rgb(var(--cb-accent) / 0.08);
+    box-shadow: 0 8px 20px rgb(0 0 0 / 0.12);
+  }
+}

diff --git a/src/styles/globals.scss b/src/styles/globals.scss
new file mode 100644
--- /dev/null
+++ b/src/styles/globals.scss
# NOTE: Rich-element CSS only: .article-body typography, .cb-code (collapsible + preview=N + sizes), .cb-embed (file/video/audio/url/link/urlonly), preview-end, editorial font sizing. Share modal / scrollbar / terminal caret / feed loader omitted.
@@ lines 1-530 @@
+// Global stylesheet. Theme custom properties are emitted by themes/_themes.scss
+// (one block per [data-theme]); the rest is structural styling that reads those
+// --cb-* variables, so all three themes (hacker / medium / substack) share one
+// layout and differ only by tokens.
+@use "themes/themes";
+
+@tailwind base;
+@tailwind components;
+@tailwind utilities;
+
+html,
+body {
+  background-color: rgb(var(--cb-bg));
+  color: rgb(var(--cb-fg));
+  font-family: var(--cb-font-body);
+}
+
+// --- Rich article typography (shared by WYSIWYG output + markdown preview) ---
+.article-body {
+  line-height: 1.75;
+}
+.article-body h1,
+.article-body h2,
+.article-body h3 {
+  font-family: var(--cb-font-heading);
+  font-weight: 700;
+  margin: 1.4em 0 0.6em;
+  color: rgb(var(--cb-fg));
+}
+.article-body p {
+  margin: 0 0 1.1em;
+}
+.article-body a {
+  color: rgb(var(--cb-accent));
+  text-decoration: underline;
+}
+.article-body img {
+  max-width: 100%;
+  border-radius: 0.5rem;
+  margin: 1em 0;
+}
+// Sized images (![alt](url){spec}). Presets cap max-width; pixel/percent sizes
+// come through inline width/height styles on the element itself.
+.article-body img.cb-img--size-small {
+  max-width: 320px;
+}
+.article-body img.cb-img--size-medium {
+  max-width: 640px;
+}
+.article-body img.cb-img--size-large {
+  max-width: 960px;
+}
+.article-body img.cb-img--size-pixels,
+.article-body img.cb-img--size-percent {
+  height: auto;
+}
+.article-body ul,
+.article-body ol {
+  margin: 0 0 1.1em 1.4em;
+  list-style: revert;
+}
+.article-body pre {
+  background: rgb(var(--cb-card));
+  border: 1px solid rgb(var(--cb-border));
+  padding: 1rem;
+  border-radius: 0.5rem;
+  overflow-x: auto;
+  font-family: var(--cb-font-mono);
+}
+.article-body code {
+  font-family: var(--cb-font-mono);
+}
+// Inline code (single-backtick `code`, i.e. <code> outside a <pre>): a subtle
+// rounded chip with a noticeably darkened font. `color-mix` darkens the theme
+// foreground toward black so it dims consistently in every theme (dimmer green
+// on hacker, near-black on the light themes). Block code inside <pre> is
+// excluded so syntax highlighting is untouched.
+.article-body :not(pre) > code {
+  color: color-mix(in srgb, rgb(var(--cb-fg)), #000 28%);
+  background: rgb(var(--cb-muted) / 0.16);
+  border: 1px solid rgb(var(--cb-border) / 0.7);
+  border-radius: 0.35rem;
+  padding: 0.1em 0.38em;
+  font-size: 0.9em;
+}
+.article-body blockquote {
+  border-left: 3px solid rgb(var(--cb-accent));
+  padding-left: 1rem;
+  color: rgb(var(--cb-muted));
+  font-style: italic;
+}
+// Preview separator (`--END PREVIEW--` -> <hr data-preview-end>): a labelled
+// dashed accent rule marking where the feed preview stops. Distinct from a
+// plain <hr> so authors can see the boundary in the full article view.
+.article-body hr.cb-preview-end {
+  position: relative;
+  border: 0;
+  border-top: 2px dashed rgb(var(--cb-accent) / 0.55);
+  margin: 2em 0;
+  overflow: visible;
+}
+.article-body hr.cb-preview-end::after {
+  content: "PREVIEW END";
+  position: absolute;
+  top: 50%;
+  left: 50%;
+  transform: translate(-50%, -50%);
+  padding: 0 0.5rem;
+  background: rgb(var(--cb-bg));
+}
+// Hide the preview separator in the rendered article view (outside the editor).
+.article-rendered hr.cb-preview-end {
+  display: none;
+}
+
+// --- Code blocks (syntax highlighted + collapsible) -------------------------
+// Token colours come from the highlight.js stylesheet selected via CODE_THEME
+// (loaded at runtime, targeting `.hljs*`). The structural chrome below reads
+// only --cb-* tokens so it sits consistently inside every site theme.
+//
+// Collapsible blocks (```lang preview=N / collapse=N) are wrapped in `.cb-code`
+// with a thick bottom toggle bar; the collapsed height is N lines expressed in
+// `em`, so it tracks the code font-size automatically.
+.article-body {
+  // Vertical padding inside the code <pre>; reused in the collapsed-height
+  // maths so exactly N lines stay visible (no off-by-one).
+  --cb-code-pad-y: 0.85rem;
+  // Height of the bottom toggle bar.
+  --cb-code-bar: 2rem;
+
+  // Wrapper owns the border/radius/background; header, code and the optional
+  // toggle bar stack vertically so the bar never overlaps the last code line.
+  .cb-code {
+    display: flex;
+    flex-direction: column;
+    margin: 1.25em 0;
+    border: 1px solid rgb(var(--cb-border));
+    border-radius: 0.625rem;
+    background: rgb(var(--cb-card));
+    overflow: hidden;
+  }
+
+  // Header: subtle language icon + name strip across the top.
+  .cb-code__header {
+    display: flex;
+    align-items: center;
+    gap: 0.4rem;
+    padding: 0.4rem 0.75rem;
+    border-bottom: 1px solid rgb(var(--cb-border));
+    color: rgb(var(--cb-muted));
+    font-family: var(--cb-font-mono);
+    font-size: 0.75rem;
+    letter-spacing: 0.03em;
+    user-select: none;
+  }
+  .cb-code__lang-icon {
+    display: inline-flex;
+    color: rgb(var(--cb-accent));
+  }
+  .cb-code__lang-icon svg {
+    width: 0.9rem;
+    height: 0.9rem;
+  }
+  .cb-code__lang {
+    line-height: 1;
+  }
+
+  .cb-code__pre {
+    margin: 0;
+    padding: var(--cb-code-pad-y) 1rem;
+    border: 0;
+    border-radius: 0;
+    background: transparent;
+    overflow: auto;
+    font-family: var(--cb-font-mono);
+    line-height: 1.5;
+  }
+  .cb-code__pre code {
+    font-family: var(--cb-font-mono);
+    background: transparent;
+  }
+
+  // Collapsed: show exactly N preview lines (font-size aware via em) + the
+  // pre's own vertical padding, then scroll. The bar sits below, not over it.
+  .cb-code.collapsed .cb-code__pre {
+    max-height: calc(var(--cb-preview-lines, 6) * 1.5em + 2 * var(--cb-code-pad-y));
+    overflow: auto;
+  }
+  .cb-code.expanded .cb-code__pre {
+    max-height: none;
+  }
+
+  // Thick bottom bar, flush with the code block, with a subtle centred caret.
+  .cb-code__toggle {
+    flex: 0 0 auto;
+    height: var(--cb-code-bar);
+    display: flex;
+    align-items: center;
+    justify-content: center;
+    padding: 0;
+    border: 0;
+    border-top: 1px solid rgb(var(--cb-border));
+    background: rgb(var(--cb-card));
+    color: rgb(var(--cb-muted));
+    cursor: pointer;
+    transition: color 0.15s ease, background 0.15s ease;
+  }
+  .cb-code__toggle:hover {
+    color: rgb(var(--cb-accent));
+    background: rgb(var(--cb-border) / 0.5);
+  }
+  // Caret points down when collapsed, rotates up (180deg) when expanded.
+  .cb-code__caret {
+    transition: transform 0.25s ease;
+  }
+  .cb-code.expanded .cb-code__caret {
+    transform: rotate(180deg);
+  }
+
+  // Optional width constraints (```lang small / width=N / 50%).
+  .cb-code--size-small {
+    max-width: 360px;
+  }
+  .cb-code--size-medium {
+    max-width: 640px;
+  }
+  .cb-code--size-large {
+    max-width: 900px;
+  }
+
+  // Medium-sized blocks wrap long lines to the next line instead of showing a
+  // horizontal scrollbar. Applies in every state (default, collapsed preview,
+  // and expanded); vertical scrolling still handles the collapsed height.
+  .cb-code--size-medium .cb-code__pre,
+  .cb-code--size-medium .cb-code__pre code {
+    white-space: pre-wrap;
+    overflow-wrap: anywhere;
+    word-break: break-word;
+  }
+  .cb-code--size-medium .cb-code__pre {
+    overflow-x: hidden;
+  }
+}
+
+// --- Attachment embeds (file / video / audio) -------------------------------
+// Shared by the WYSIWYG surface and the rendered article body. Built by
+// src/lib/embeds.ts; styled here purely from --cb-* tokens so all three themes
+// (hacker / medium / substack) stay consistent.
+.article-body .cb-embed {
+  margin: 1.25em 0;
+}
+
+// Size presets for embeds
+.article-body .cb-embed--size-small {
+  max-width: 320px;
+}
+.article-body .cb-embed--size-medium {
+  max-width: 640px;
+}
+.article-body .cb-embed--size-large {
+  max-width: 960px;
+}
+
+// File download card.
+.article-body .cb-embed--file {
+  display: flex;
+  align-items: center;
+  gap: 0.875rem;
+  padding: 0.75rem 0.875rem;
+  border: 1px solid rgb(var(--cb-border));
+  border-radius: 0.625rem;
+  background: rgb(var(--cb-card));
+  transition: border-color 0.15s ease, box-shadow 0.15s ease;
+}
+.article-body .cb-embed--file:hover {
+  border-color: rgb(var(--cb-accent) / 0.6);
+}
+.article-body .cb-embed__icon {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  flex: 0 0 auto;
+  width: 2.5rem;
+  height: 2.5rem;
+  border-radius: 0.5rem;
+  color: rgb(var(--cb-accent));
+  background: rgb(var(--cb-accent) / 0.12);
+}
+.article-body .cb-embed__icon svg {
+  width: 1.375rem;
+  height: 1.375rem;
+}
+.article-body .cb-embed__meta {
+  display: flex;
+  flex-direction: column;
+  min-width: 0;
+  flex: 1 1 auto;
+  gap: 0.125rem;
+}
+.article-body .cb-embed__name {
+  color: rgb(var(--cb-fg));
+  font-weight: 600;
+  line-height: 1.3;
+  word-break: break-word;
+}
+.article-body .cb-embed__type {
+  color: rgb(var(--cb-muted));
+  font-size: 0.75rem;
+  letter-spacing: 0.04em;
+  text-transform: uppercase;
+}
+.article-body .cb-embed__btn {
+  display: inline-flex;
+  align-items: center;
+  gap: 0.4rem;
+  flex: 0 0 auto;
+  padding: 0.45rem 0.8rem;
+  border-radius: 0.5rem;
+  background: rgb(var(--cb-accent));
+  color: rgb(var(--cb-bg));
+  font-size: 0.8125rem;
+  font-weight: 600;
+  text-decoration: none;
+  transition: opacity 0.15s ease;
+}
+.article-body .cb-embed__btn:hover {
+  opacity: 0.85;
+  text-decoration: none;
+}
+.article-body .cb-embed__btn svg {
+  width: 1rem;
+  height: 1rem;
+}
+
+// Native video player.
+.article-body .cb-embed--video {
+  display: flex;
+  flex-direction: column;
+  gap: 0.5rem;
+}
+.article-body .cb-embed--video .cb-embed__media {
+  width: 100%;
+  border-radius: 0.625rem;
+  border: 1px solid rgb(var(--cb-border));
+  background: #000;
+  display: block;
+}
+
+// Native audio player.
+.article-body .cb-embed--audio {
+  display: flex;
+  flex-direction: column;
+  gap: 0.5rem;
+  padding: 0.75rem 0.875rem;
+  border: 1px solid rgb(var(--cb-border));
+  border-radius: 0.625rem;
+  background: rgb(var(--cb-card));
+}
+.article-body .cb-embed--audio .cb-embed__media {
+  width: 100%;
+  display: block;
+}
+.article-body .cb-embed__caption {
+  color: rgb(var(--cb-muted));
+  font-size: 0.875rem;
+  font-weight: 600;
+}
+
+// --- URL embeds (rich providers + generic link preview) --------------------
+// Rich provider embeds: a responsive frame whose height follows the shape's
+// aspect ratio (video 16:9, post ~ portrait, audio a fixed player height).
+.article-body .cb-embed--url {
+  margin: 1.25em 0;
+}
+.article-body .cb-embed--rich {
+  display: flex;
+  flex-direction: column;
+  gap: 0.4rem;
+}
+.article-body .cb-embed__frame {
+  position: relative;
+  width: 100%;
+  overflow: hidden;
+  border-radius: 0.625rem;
+  border: 1px solid rgb(var(--cb-border));
+  background: rgb(var(--cb-card));
+}
+.article-body .cb-embed__frame--video {
+  aspect-ratio: 16 / 9;
+}
+.article-body .cb-embed__frame--post {
+  aspect-ratio: 3 / 4;
+}
+.article-body .cb-embed__frame--audio {
+  height: 166px;
+}
+// The iframe/blockquote fills its frame.
+.article-body .cb-embed__frame-el,
+.article-body .cb-embed__frame iframe {
+  position: absolute;
+  inset: 0;
+  width: 100%;
+  height: 100%;
+  border: 0;
+}
+.article-body .cb-embed__frame .twitter-tweet {
+  position: relative;
+  margin: 0 auto;
+}
+.article-body .cb-embed__caption a {
+  color: rgb(var(--cb-muted));
+  text-decoration: none;
+}
+.article-body .cb-embed__caption a:hover {
+  color: rgb(var(--cb-accent));
+}
+
+// Generic link-preview card: thumbnail + meta + Visit-site button.
+.article-body .cb-embed--link {
+  display: flex;
+  align-items: stretch;
+  gap: 0;
+  overflow: hidden;
+  border: 1px solid rgb(var(--cb-border));
+  border-radius: 0.625rem;
+  background: rgb(var(--cb-card));
+  transition: border-color 0.15s ease, box-shadow 0.15s ease;
+}
+.article-body .cb-embed--link:hover {
+  border-color: rgb(var(--cb-accent) / 0.6);
+}
+.article-body .cb-embed__link {
+  display: flex;
+  align-items: center;
+  gap: 0.875rem;
+  flex: 1 1 auto;
+  min-width: 0;
+  padding: 0.75rem 0.875rem;
+  text-decoration: none;
+  color: inherit;
+}
+.article-body .cb-embed__thumb {
+  flex: 0 0 auto;
+  width: 96px;
+  height: 96px;
+  border-radius: 0.5rem;
+  object-fit: cover;
+  background: rgb(var(--cb-accent) / 0.08);
+}
+.article-body .cb-embed__thumb--empty {
+  display: inline-flex;
+  align-items: center;
+  justify-content: center;
+  color: rgb(var(--cb-accent));
+}
+.article-body .cb-embed__thumb--empty svg {
+  width: 2rem;
+  height: 2rem;
+}
+.article-body .cb-embed--link .cb-embed__meta {
+  display: flex;
+  flex-direction: column;
+  min-width: 0;
+  gap: 0.15rem;
+}
+.article-body .cb-embed__site {
+  color: rgb(var(--cb-muted));
+  font-size: 0.72rem;
+  text-transform: uppercase;
+  letter-spacing: 0.04em;
+}
+.article-body .cb-embed__title {
+  color: rgb(var(--cb-fg));
+  font-weight: 600;
+  line-height: 1.3;
+  overflow: hidden;
+  text-overflow: ellipsis;
+  display: -webkit-box;
+  -webkit-line-clamp: 2;
+  line-clamp: 2;
+  -webkit-box-orient: vertical;
+}
+.article-body .cb-embed__desc {
+  color: rgb(var(--cb-fg) / 0.8);
+  font-size: 0.875rem;
+  line-height: 1.4;
+  overflow: hidden;
+  text-overflow: ellipsis;
+  display: -webkit-box;
+  -webkit-line-clamp: 2;
+  line-clamp: 2;
+  -webkit-box-orient: vertical;
+}
+.article-body .cb-embed__url {
+  color: rgb(var(--cb-muted));
+  font-size: 0.75rem;
+}
+.article-body .cb-embed__visit {
+  align-self: center;
+  margin: 0 0.75rem;
+  white-space: nowrap;
+}
+
+// Plain link (urlOnly): render inline-ish as an accent-colored anchor.
+.article-body a.cb-embed--urlonly {
+  display: inline-block;
+  margin: 0.25em 0;
+  color: rgb(var(--cb-accent));
+  word-break: break-all;
+}
+
+// On narrow screens, let the file card wrap its download button to a new line.
+@media (max-width: 480px) {
+  .article-body .cb-embed--file {
+    flex-wrap: wrap;
+  }
+  .article-body .cb-embed__btn {
+    margin-left: auto;
+  }
+  .article-body .cb-embed--link {
+    flex-direction: column;
+  }
+  .article-body .cb-embed__thumb {
+    width: 100%;
+    height: 160px;
+  }
+  .article-body .cb-embed__visit {
+    margin: 0 0.875rem 0.875rem;
+  }
+}
