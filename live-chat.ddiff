# =============================================================================
# 12. lib/chat/storage.ts  --  per-session on-disk attachment store
# =============================================================================
# intent: the single source of truth for WHERE attachment bytes live and HOW they
# are named, plus the small config helpers the routes read. Node fs/promises only
# (server runtime). Everything is keyed on the STABLE ChatSession.id so cleanup is
# deterministic (the visitorId rotates and must NOT be used for paths).
#
# --- config helpers (read process.env at call time, never cached) -----------
export function chatUploadRoot() { /* path.resolve(process.cwd(), CHAT_UPLOAD_DIR ?? "chat-uploads") */ }
export function maxUploadBytes() { /* (CHAT_MAX_UPLOAD_MB ?? 20) * 1024 * 1024 */ }
# intent: DEFAULT-ON; only the literal "false" disables. Read on BOTH client and
# server from the same NEXT_PUBLIC_* var so the two agree.
export function clientAttachmentsEnabled() { return process.env.NEXT_PUBLIC_LIVE_CHAT_ATTACHMENTS_ENABLED !== "false"; }
# intent: coarse MIME -> attachment kind bucket used for storage + rendering +
# choosing the Telegram send method.
export function attachmentTypeFromMime(mime) { /* image/* video/* audio/* -> kind; else "document" */ }

# --- path helpers (the security boundary) -----------------------------------
# intent: reduce any value to a single safe path component: basename it, replace
# every char outside [A-Za-z0-9._-] with "_", and reject "" / "." / "..".
function sanitizeSegment(value) { /* basename + whitelist regex; throw on empty/./.. */ }
export function sessionDir(sessionId) { return path.join(chatUploadRoot(), sanitizeSegment(sessionId)); }
# intent: build a safe, UNIQUE on-disk name: `${randomUUID()}${ext}` where ext is
# the sanitized (<=16 char, [A-Za-z0-9.] only) extension of the original name. The
# random name means the client filename never influences the path (display name is
# kept separately in attachmentName).
export function safeFileName(originalName) { /* `${uuid}${safeExt}` */ }
# intent: TRAVERSAL GUARD. Resolve a stored RELATIVE path back to an absolute path
# and assert it stays within chatUploadRoot() (equal to root OR startsWith root+sep);
# throw otherwise. Every read/serve goes through this so a crafted
# "../../etc/passwd" attachmentPath cannot escape.
export function resolveStoredPath(relative) { /* resolve + assert within root; else throw */ }

# --- CRUD -------------------------------------------------------------------
# intent: mkdir -p the sessionDir, write bytes to safeFileName(originalName), and
# return the storage-root-RELATIVE path with FORWARD SLASHES ("<sessionId>/<uuid.ext>")
# — that string is what gets stored in ChatMessage.attachmentPath.
export async function saveChatFile(sessionId, originalName, data) { /* -> relativePath */ }
export async function readChatFile(relativePath) { /* fs.readFile(resolveStoredPath(rel)) -> Buffer */ }
# intent: best-effort recursive delete of a whole session's folder; swallow ENOENT
# so calling it twice / on an empty session is harmless.
export async function deleteSessionFiles(sessionId) { /* rm(sessionDir, { recursive, force }) */ }

# =============================================================================
# 13. app/api/chat/attachments/[id]/route.ts  --  authenticated byte serving (GET)
# =============================================================================
export const dynamic = "force-dynamic";
export async function GET(req, { params }) {
  # intent: dedicated rate-limit bucket for byte serving (LIMITS["chat.attachment"]).
  const blocked = await applyRouteLimit(req, "chat.attachment"); if (blocked) return blocked;
  const { id } = await params;                                   # message id (Next 15+ async params)
  const visitorId = req.nextUrl.searchParams.get("visitorId");   # per-conversation shared secret
  const forceDownload = req.nextUrl.searchParams.get("download") === "1";
  if (!visitorId) return apiError({ code: ErrorCode.VALIDATION, message: "visitorId is required" });

  const message = await getChatMessageWithSession(id);
  if (!message || !message.attachmentPath) return apiError({ code: ErrorCode.NOT_FOUND, ... });
  # intent: AUTHORIZATION — the caller's visitorId must equal the owning session's
  # visitorId. This mirrors the visitor-token trust model used across the feature
  # and prevents enumerating other conversations' files by guessing message ids.
  if (message.chatSession.visitorId !== visitorId) return apiError({ code: ErrorCode.FORBIDDEN, ... });

  let bytes; try { bytes = await readChatFile(message.attachmentPath); }  # goes through the traversal guard
  catch { return apiError({ code: ErrorCode.NOT_FOUND, message: "Attachment file is no longer available." }); }

  # intent: inline for rich media, attachment (download) for documents or ?download=1.
  # Sanitize the filename in the header; nosniff + private cache. Stream the bytes.
  const disposition = (forceDownload || message.attachmentType === "document") ? "attachment" : "inline";
  return new Response(bytes, { status: 200, headers: {
    "Content-Type": message.attachmentMime ?? "application/octet-stream",
    "Content-Length": String(bytes.byteLength),
    "Content-Disposition": `${disposition}; filename="${sanitize(message.attachmentName)}"`,
    "Cache-Control": "private, max-age=3600",
    "X-Content-Type-Options": "nosniff",
  } });
}

# =============================================================================
# 14. RETENTION + LIMITS  (glue for attachments)
# =============================================================================
# intent (RATE LIMIT): add a bucket for the serving route in lib/rate-limit.ts:
